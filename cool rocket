local function realityWarpPart(part)
    -- The absolute chaos function that makes parts look normal but they're phantom server-side
    print("🌀 REALITY WARPING: " .. part.Name)
    
    -- Step 1: Claim ownership via group/ungroup batch
    EscalateEvent:FireServer(PartOwnership, {part})
    
    -- Wait for ownership to be claimed
    repeat task.wait(0.01) until part:FindFirstChild("RRPartOwner")
    
    -- Step 2: Store original properties
    local originalSize = part.Size
    local originalTransparency = part.Transparency
    
    -- Step 3: CLIENT-SIDE - Keep part at original size and delete any mesh (fight server replication)
    local clientFixer
    clientFixer = RunService.Heartbeat:Connect(function()
        -- Reset size to original (server keeps trying to make it 0.001x)
        part.Size = originalSize
        
        -- Delete any mesh that appears (server keeps trying to add 1000x mesh)
        local mesh = part:FindFirstChildOfClass("SpecialMesh")
        if mesh then
            mesh:Destroy()
        end
    end)
    
    -- Keep fighting replication for 7 seconds (until part is removed)
    task.delay(7, function()
        if clientFixer then
            clientFixer:Disconnect()
        end
    end)
    
    -- Step 4: SERVER-SIDE CHANGES (multiply size by 0.001x, mesh scale 1000x, no collision)
    task.spawn(function()
        pcall(function()
            -- Multiply current size by 0.001 on server
            local tinySize = originalSize * 0.001
            ep:InvokeServer("SyncResize", {{
                Part = part,
                Size = tinySize
            }})
            
            -- Check if mesh already exists, if not create it
            local existingMesh = part:FindFirstChildOfClass("SpecialMesh")
            if not existingMesh then
                ep:InvokeServer("CreateMeshes", {{Part = part}})
                task.wait(0.05)
            end
            
            -- Set mesh type based on part type
            local meshType = Enum.MeshType.Brick
            if part.ClassName == "WedgePart" then
                meshType = Enum.MeshType.Wedge
            elseif part.ClassName == "CornerWedgePart" then
                meshType = Enum.MeshType.CornerWedge
            elseif part.Shape == Enum.PartType.Ball then
                meshType = Enum.MeshType.Sphere
            elseif part.Shape == Enum.PartType.Cylinder then
                meshType = Enum.MeshType.Cylinder
            end
            
            -- Edit mesh scale to 1000x
            ep:InvokeServer("SyncMesh", {{
                Part = part,
                MeshType = meshType,
                Scale = Vector3.new(1000, 1000, 1000)
            }})
            
            -- Disable collision on server
            ep:InvokeServer("SyncCollision", {{
                Part = part,
                CanCollide = false
            }})
        end)
    end)
    
    -- Step 5: After 5 seconds, fade to transparency over 2 seconds, then remove
    task.delay(5, function()
        if part and part.Parent then
            print("💀 FADING: " .. part.Name)
            local fadeStart = tick()
            local fadeDuration = 2
            
            -- Lerp transparency over 2 seconds
            local fadeConnection
            fadeConnection = RunService.Heartbeat:Connect(function()
                if not part or not part.Parent then
                    if fadeConnection then fadeConnection:Disconnect() end
                    return
                end
                
                local elapsed = tick() - fadeStart
                local alpha = math.min(elapsed / fadeDuration, 1)
                local newTransparency = originalTransparency + (1 - originalTransparency) * alpha
                
                -- Update transparency on server
                task.spawn(function()
                    pcall(function()
                        ep:InvokeServer("SyncMaterial", {{
                            Part = part,
                            Transparency = newTransparency
                        }})
                    end)
                end)
                
                -- When fade complete, keep part at transparency 1 (phantom forever)
                if alpha >= 1 then
                    fadeConnection:Disconnect()
                    print("👻 PHANTOM: " .. part.Name .. " (invisible forever)")
                end
            end)
        end
    end)
end

