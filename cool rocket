-- Create part with ownership (batch operations)
local function createPart(size, cframe, color, material, transparency)
    material = material or Enum.Material.Plastic
    transparency = transparency or 0
    
    -- Create part at server (tiny size for stealth)
    local part = ep:InvokeServer("CreatePart", "Normal", cframe, workspace)
    
    -- Claim ownership
    EscalateEvent:FireServer(PartOwnership, {part})
    repeat task.wait(0.01) until part:FindFirstChild("RRPartOwner")
    
    -- Apply properties in batch (SIMULTANEOUSLY!)
    task.spawn(function()
        -- Set size and position
        ep:InvokeServer("SyncResize", {{
            Part = part,
            Size = size,
            CFrame = cframe
        }})
    end)
    
    task.spawn(function()
        -- Set material and transparency
        SyncAPI:Invoke("SyncMaterial", {{
            Part = part,
            Material = material,
            Transparency = transparency
        }})
    end)
    
    task.spawn(function()
        -- Set color
        SyncAPI:Invoke("SyncColor", {{
            Part = part,
            Color = color,
            UnionColoring = true
        }})
    end)
    
    task.spawn(function()
        -- Set collision
        SyncAPI:Invoke("SyncCollision", {{
            Part = part,
            CanCollide = false
        }})
    end)
    
    task.spawn(function()
        -- Set anchor (ANCHORED ON SERVER!)
        SyncAPI:Invoke("SyncAnchor", {{
            Part = part,
            Anchored = true
        }})
    end)
    
    return part
end

-- Remove part (replicated)
local function removePart(part)
    if part and part.Parent then
        ep:InvokeServer("Remove", {part})
    end
end

-- Create explosion effect with SMOKE PARTICLES!
local function createExplosion(position)
    print("SMOKE EXPLOSION AT:", position)
    
    -- Create multiple smoke particles that fly outward!
    local smokeCount = math.floor(CONFIG.smokeParticles)
    local smokeSpeed = CONFIG.smokeSpeed
    
    for i = 1, smokeCount do
        task.spawn(function()
            -- Random direction for each smoke particle
            local randomDirection = Vector3.new(
                math.random(-100, 100) / 100,
                math.random(-100, 100) / 100,
                math.random(-100, 100) / 100
            ).Unit
            
            -- Create smoke particle (0.01 size, ANCHORED!)
            local smoke = createPart(
                Vector3.new(0.01, 0.01, 0.01), -- Server size (0.01)
                CFrame.new(position),
                Color3.fromRGB(255, math.random(100, 200), 0), -- Orange/yellow smoke
                Enum.Material.Neon,
                0.3
            )
            
            -- Add sphere mesh for smoke particle
            task.spawn(function()
                ep:InvokeServer("CreateMeshes", {{Part = smoke}})
                task.wait(0.05)
                ep:InvokeServer("SyncMesh", {{
                    Part = smoke,
                    MeshType = Enum.MeshType.Sphere,
                    Scale = Vector3.new(0.5, 0.5, 0.5) -- Starting size (smaller)
                }})
            end)
            
            -- Animate smoke particle (move outward, grow, fade)
            task.spawn(function()
                local startTime = tick()
                local lifetime = 1.2 -- Smoke lasts 1.2 seconds
                
                while tick() - startTime < lifetime do
                    local progress = (tick() - startTime) / lifetime
                    
                    -- Calculate new position (move outward)
                    local distance = smokeSpeed * (tick() - startTime)
                    local newPos = position + (randomDirection * distance)
                    local newCFrame = CFrame.new(newPos)
                    
                    -- Update position (CLIENT + SERVER)
                    smoke.CFrame = newCFrame
                    task.spawn(function()
                        pcall(function()
                            ep:InvokeServer("SyncMove", {{
                                Part = smoke,
                                CFrame = newCFrame
                            }})
                        end)
                    end)
                    
                    -- Update size (grow over time) - MUCH SMALLER NOW
                    local scale = 0.5 + (progress * 1.5) -- Grow from 0.5 to 2.0
                    ep:InvokeServer("SyncMesh", {{
                        Part = smoke,
                        Scale = Vector3.new(scale, scale, scale)
                    }})
                    
                    -- Update color (fade to dark gray)
                    local colorProgress = progress
                    local r = 255 - (colorProgress * 155) -- 255 -> 100
                    local g = 150 - (colorProgress * 100) -- 150 -> 50
                    local b = colorProgress * 50 -- 0 -> 50
                    SyncAPI:Invoke("SyncColor", {{
                        Part = smoke,
                        Color = Color3.fromRGB(r, g, b),
                        UnionColoring = true
                    }})
                    
                    -- Update transparency (fade out)
                    local transparency = 0.3 + (progress * 0.7) -- 0.3 -> 1.0
                    SyncAPI:Invoke("SyncMaterial", {{
                        Part = smoke,
                        Transparency = transparency
                    }})
                    
                    task.wait(0.03)
                end
                
                -- Remove smoke particle
                removePart(smoke)
            end)
            
            -- Stagger spawn times slightly
            task.wait(0.02)
        end)
    end
    
    -- Center flash (bright core)
    task.spawn(function()
        local flash = createPart(
            Vector3.new(0.01, 0.01, 0.01),
            CFrame.new(position),
            Color3.fromRGB(255, 255, 200),
            Enum.Material.Neon,
            0
        )
        
        task.spawn(function()
            ep:InvokeServer("CreateMeshes", {{Part = flash}})
            task.wait(0.05)
            ep:InvokeServer("SyncMesh", {{
                Part = flash,
                MeshType = Enum.MeshType.Sphere,
                Scale = Vector3.new(8, 8, 8)
            }})
        end)
        
        -- Flash fade out quickly
        for i = 1, 10 do
            task.wait(0.03)
            SyncAPI:Invoke("SyncMaterial", {{
                Part = flash,
                Transparency = i * 0.1
            }})
        end
        
        removePart(flash)
    end)
    
    -- Create actual Roblox explosion for visual/sound (CLIENT-SIDE ONLY!)
    local exp = Instance.new("Explosion")
    exp.Position = position
    exp.BlastRadius = CONFIG.explosionRadius
    exp.BlastPressure = 0  -- NO PHYSICS FORCE!
    exp.ExplosionType = Enum.ExplosionType.NoCraters
    exp.Parent = workspace
    
    -- Kill players in radius by removing their heads (F3X method)
    task.spawn(function()
        for _, otherPlayer in pairs(Players:GetPlayers()) do
            if otherPlayer ~= player and otherPlayer.Character then
                local hrp = otherPlayer.Character:FindFirstChild("HumanoidRootPart")
                local head = otherPlayer.Character:FindFirstChild("Head")
                
                if hrp and head then
                    local distance = (hrp.Position - position).Magnitude
                    if distance <= CONFIG.explosionRadius then
                        print("Killing player:", otherPlayer.Name, "by removing head")
                        
                        -- Remove head using F3X group/ungroup method (instant kill)
                        task.spawn(function()
                            pcall(function()
                                -- Claim ownership first
                                EscalateEvent:FireServer(PartOwnership, {head})
                                task.wait(0.05)
                                
                                -- Group the head
                                local groupArgs = {
                                    "CreateGroup",
                                    "Model",
                                    workspace,
                                    {head}
                                }
                                ep:InvokeServer(unpack(groupArgs))
                                
                                task.wait(0.05)
                                
                                -- Ungroup to remove (kills player)
                                local ungroupArgs = {
                                    "Ungroup",
                                    {head}
                                }
                                ep:InvokeServer(unpack(ungroupArgs))
                                
                                print("Removed head from:", otherPlayer.Name)
                            end)
                        end)
                    end
                end
            end
        end
    end)
end

