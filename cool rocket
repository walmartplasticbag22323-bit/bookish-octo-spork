    local handle = createPart(
        Vector3.new(0.01, 0.01, 0.01), -- Server size (0.01)
        CFrame.new(0, 0, 0),
        Color3.fromRGB(70, 70, 70),
        Enum.Material.Plastic,
        0
    )
    
    -- Add launcher mesh (FileMesh doesn't multiply with part size!)
    task.spawn(function()
        ep:InvokeServer("CreateMeshes", {{Part = handle}})
        task.wait(0.05)
    end)
    
    -- Sync mesh and texture SIMULTANEOUSLY
    task.spawn(function()
        task.wait(0.05) -- Wait for CreateMeshes
        ep:InvokeServer("SyncMesh", {{
            Part = handle,
            MeshType = Enum.MeshType.FileMesh,
            MeshId = "http://www.roblox.com/asset/?id=94690054",
            TextureId = "http://www.roblox.com/asset/?id=94689966",
            Scale = Vector3.new(1.5, 1.5, 1.5)
        }})
    end)
    
    return handle
end

