end

-- Launch rocket with client-dominant control (THE SAUCE!)
local function launchRocket()
    if controlling then
        print("Rocket already active!")
        return
    end
    
    if humanoid.Health <= 0 then
        print("Cannot launch while dead!")
        return
    end
    
    controlling = true
    print("LAUNCHING ROCKET!")
    
    -- Calculate launch position
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then
        controlling = false
        return
    end
    
    local launchCFrame = rootPart.CFrame * CFrame.new(0, 0, -4)
    local targetPoint = mouse.Hit.Position
    launchCFrame = CFrame.new(launchCFrame.Position, targetPoint)
    
    -- Create rocket (ONE PART!)
    activeRocket = createRocket(launchCFrame)
    intendedCFrame = launchCFrame
    
    -- Rocket physics (use CONFIG values)
    local maxSpeed = CONFIG.rocketSpeed
    local currentVelocity = launchCFrame.LookVector * maxSpeed
    local turnSpeed = CONFIG.rocketTurnSpeed
    
    -- Set camera to follow rocket
    local camera = workspace.CurrentCamera
    local originalCameraSubject = camera.CameraSubject
    camera.CameraSubject = activeRocket
    
    print("Rocket launched! Move mouse to guide!")
    print("CLIENT-DOMINANT MODE: Client calculates, server replicates!")
    
    -- ANTI-RUBBERBANDING: Changed listener (RE-ASSERT #2)
    local changedConnection
    changedConnection = activeRocket:GetPropertyChangedSignal("CFrame"):Connect(function()
        if intendedCFrame then
            -- Server tried to overwrite? STOMP IT BACK!
            activeRocket.CFrame = intendedCFrame
        end
    end)
    
    -- CLIENT-DOMINANT CONTROL LOOP (THE SAUCE!)
    rocketConnection = RunService.Heartbeat:Connect(function(dt)
        if not activeRocket or not activeRocket.Parent then
            -- Rocket destroyed, cleanup
            if rocketConnection then
                rocketConnection:Disconnect()
                rocketConnection = nil
            end
            if changedConnection then
                changedConnection:Disconnect()
            end
            camera.CameraSubject = originalCameraSubject
            controlling = false
            activeRocket = nil
            intendedCFrame = nil
            print("Rocket destroyed")
            return
        end
        
        -- Calculate target direction (mouse position)
        local targetPos = mouse.Hit.Position
        local currentPos = activeRocket.Position
        local targetDirection = (targetPos - currentPos).Unit
        
        -- Smooth turn towards target
        currentVelocity = currentVelocity:Lerp(targetDirection * maxSpeed, turnSpeed * dt * 60)
        
        -- Calculate new CFrame (CLIENT CALCULATES!)
        local newCFrame = CFrame.new(
            currentPos + (currentVelocity * dt),
            currentPos + currentVelocity
        )
        
        -- Store intended CFrame (for anti-rubberbanding)
        intendedCFrame = newCFrame
        
        -- CLIENT: Update position instantly (no lag, CLIENT WINS!)
        activeRocket.CFrame = newCFrame
        
        -- SERVER: Replicate position asynchronously at 55Hz (other players see it!)
        -- This is THE MOVEMENT REPLICATOR (runs on its own routine, never ends)
        local currentTime = tick()
        if currentTime - lastReplication >= 1/REPLICATION_RATE then
            lastReplication = currentTime
            task.spawn(function()
                pcall(function()
                    ep:InvokeServer("SyncMove", {{
                        Part = activeRocket,
                        CFrame = newCFrame
                    }})
                end)
            end)
        end
        
        -- ANTI-RUBBERBANDING: Re-assert #1 (end of Heartbeat)
        activeRocket.CFrame = intendedCFrame
        
        -- Check for collision (raycasting)
        local ray = Ray.new(currentPos, currentVelocity * dt)
        local hit, hitPos = workspace:FindPartOnRay(ray, character)
        
        if hit and hit ~= activeRocket then
            -- Determine what to do based on mode
            local shouldExplode = false
            
            if CONFIG.madmanMode then
                -- MADMAN MODE: Reality warp parts, explode on everything
                print("💥 MADMAN MODE HIT: " .. hit.Name)
                
                -- Check if we should ignore (grass or large parts)
                if hit.Name == "Grass" then
                    print("   Ignoring grass")
                elseif hit.Size.Magnitude > 250 then
                    print("   Ignoring large part (" .. hit.Size.Magnitude .. " studs)")
                else
                    -- Reality warp the part (phantom server-side, normal client-side)
                    realityWarpPart(hit)
                    -- Always explode in madman mode
                    shouldExplode = true
                end
                
            elseif CONFIG.hardcoreMode then
                -- HARDCORE MODE: Destroy parts, but explode on players
                local hitPlayer = game.Players:GetPlayerFromCharacter(hit.Parent)
                
                if hitPlayer then
                    -- Hit a player, explode and kill them
                    print("💀 HARDCORE MODE: Hit player " .. hitPlayer.Name)
                    shouldExplode = true
                elseif hit.Name == "Grass" then
                    -- Ignore grass
                    print("🌿 HARDCORE MODE: Ignoring grass")
                elseif hit.Size.Magnitude > 250 then
                    -- Ignore large parts (baseplate)
                    print("🏗️ HARDCORE MODE: Ignoring large part (" .. hit.Size.Magnitude .. " studs)")
                else
                    -- Destroy blocking part and continue
                    print("💥 HARDCORE MODE: Destroying blocking part " .. hit.Name)
                    removePart(hit)
                end
                
            else
                -- NORMAL MODE: Explode on any hit
                print("💥 IMPACT!")
                shouldExplode = true
            end
            
            -- If we should explode, do cleanup
            if shouldExplode then
                -- Create explosion
                createExplosion(hitPos)
                
                -- Cleanup
                if rocketConnection then
                    rocketConnection:Disconnect()
                    rocketConnection = nil
                end
                if changedConnection then
                    changedConnection:Disconnect()
                end
                camera.CameraSubject = originalCameraSubject
                controlling = false
                intendedCFrame = nil
                
                -- Remove rocket
                removePart(activeRocket)
                activeRocket = nil
            end
        end
    end)
    
    -- ANTI-RUBBERBANDING: RenderStepped re-assert #3 (right before render)
    local renderConnection
    renderConnection = RunService.RenderStepped:Connect(function()
        if activeRocket and intendedCFrame then
            activeRocket.CFrame = intendedCFrame
        else
            if renderConnection then
                renderConnection:Disconnect()
            end
        end
    end)
    
    -- Auto-cleanup after timeout (use CONFIG value)
    task.delay(CONFIG.rocketLifetime, function()
        if activeRocket and activeRocket.Parent then
            print("Rocket timeout")
            if rocketConnection then
                rocketConnection:Disconnect()
                rocketConnection = nil
            end
            if changedConnection then
                changedConnection:Disconnect()
            end
            if renderConnection then
                renderConnection:Disconnect()
            end
            camera.CameraSubject = originalCameraSubject
            controlling = false
            intendedCFrame = nil
            removePart(activeRocket)
            activeRocket = nil
        end
    end)
end

