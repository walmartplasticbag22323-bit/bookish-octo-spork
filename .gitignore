        selectedCharacter = nil
        
        dropdownBtn.Text = "🌍 EVERYONE (All Players)"
        dropdownBtn.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
        
        -- Show all possible body parts (R6 + R15)
        clearBodyPartButtons()
        local allBodyParts = {
            "Head", "Torso", "Left Arm", "Right Arm", "Left Leg", "Right Leg",
            "UpperTorso", "LowerTorso", "LeftUpperArm", "LeftLowerArm", "LeftHand",
            "RightUpperArm", "RightLowerArm", "RightHand", "LeftUpperLeg",
            "LeftLowerLeg", "LeftFoot", "RightUpperLeg", "RightLowerLeg", "RightFoot"
        }
        
        for _, partName in ipairs(allBodyParts) do
            createPartButton(partName, nil)
        end
        
        scrollFrame.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y + 10)
        
        dropdownList.Visible = false
        dropdownOpen = false
        
        print("Selected mode: EVERYONE")
    end)
    
    -- Add "Other" option (second)
    local otherBtn = Instance.new("TextButton")
    otherBtn.Name = "Other"
    otherBtn.Size = UDim2.new(1, -10, 0, 35)
    otherBtn.BackgroundColor3 = Color3.fromRGB(255, 150, 50)
    otherBtn.BorderSizePixel = 0
    otherBtn.Text = "👥 OTHER (All Except You)"
    otherBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    otherBtn.TextSize = 14
    otherBtn.Font = Enum.Font.GothamBold
    otherBtn.TextXAlignment = Enum.TextXAlignment.Left
    otherBtn.ZIndex = 101
    otherBtn.Parent = dropdownList
    
    local otherBtnCorner = Instance.new("UICorner")
    otherBtnCorner.CornerRadius = UDim.new(0, 5)
    otherBtnCorner.Parent = otherBtn
    
    local otherBtnPadding = Instance.new("UIPadding")
    otherBtnPadding.PaddingLeft = UDim.new(0, 10)
    otherBtnPadding.Parent = otherBtn
    
    otherBtn.MouseButton1Click:Connect(function()
        selectedMode = "other"
        selectedPlayer = nil
        selectedCharacter = nil
        
        dropdownBtn.Text = "👥 OTHER (All Except You)"
        dropdownBtn.BackgroundColor3 = Color3.fromRGB(255, 150, 50)
        
        -- Show all possible body parts (R6 + R15)
        clearBodyPartButtons()
        local allBodyParts = {
            "Head", "Torso", "Left Arm", "Right Arm", "Left Leg", "Right Leg",
            "UpperTorso", "LowerTorso", "LeftUpperArm", "LeftLowerArm", "LeftHand",
            "RightUpperArm", "RightLowerArm", "RightHand", "LeftUpperLeg",
            "LeftLowerLeg", "LeftFoot", "RightUpperLeg", "RightLowerLeg", "RightFoot"
        }
        
        for _, partName in ipairs(allBodyParts) do
            createPartButton(partName, nil)
        end
        
        scrollFrame.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y + 10)
        
        dropdownList.Visible = false
        dropdownOpen = false
        
        print("Selected mode: OTHER")
    end)
    
    -- Add all players
    for _, player in ipairs(game.Players:GetPlayers()) do
        local playerBtn = Instance.new("TextButton")
        playerBtn.Name = player.Name
        playerBtn.Size = UDim2.new(1, -10, 0, 30)
        playerBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
        playerBtn.BorderSizePixel = 0
        playerBtn.Text = player.Name .. (player == plr and " (You)" or "")
        playerBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        playerBtn.TextSize = 13
        playerBtn.Font = Enum.Font.Gotham
        playerBtn.TextXAlignment = Enum.TextXAlignment.Left
        playerBtn.ZIndex = 101
        playerBtn.Parent = dropdownList
        
        local playerBtnCorner = Instance.new("UICorner")
        playerBtnCorner.CornerRadius = UDim.new(0, 5)
        playerBtnCorner.Parent = playerBtn
        
        local playerBtnPadding = Instance.new("UIPadding")
        playerBtnPadding.PaddingLeft = UDim.new(0, 10)
        playerBtnPadding.Parent = playerBtn
        
        playerBtn.MouseButton1Click:Connect(function()
            selectedMode = "self"
            selectedPlayer = player
            selectedCharacter = player.Character
            
            -- Wait for character if it doesn't exist
            if not selectedCharacter then
                selectedCharacter = player.CharacterAdded:Wait()
            end
            
            dropdownBtn.Text = "👤 " .. player.Name .. (player == plr and " (You)" or "")
            dropdownBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
            populateBodyParts(selectedCharacter)
            dropdownList.Visible = false
            dropdownOpen = false
            
            print("Selected player:", player.Name, "Character:", selectedCharacter)
        end)
    end
    
    -- Update canvas size
    dropdownList.CanvasSize = UDim2.new(0, 0, 0, dropdownListLayout.AbsoluteContentSize.Y + 10)
end

-- Dropdown toggle
dropdownBtn.MouseButton1Click:Connect(function()
    dropdownOpen = not dropdownOpen
    
    if dropdownOpen then
        -- Update player list first
        updatePlayerDropdown()
        
        -- Make visible and tween size
        dropdownList.Visible = true
        dropdownList.Size = UDim2.new(1, -20, 0, 0)
        dropdownList:TweenSize(
            UDim2.new(1, -20, 0, math.min(150, dropdownListLayout.AbsoluteContentSize.Y + 10)), 
            Enum.EasingDirection.Out, 
            Enum.EasingStyle.Quad, 
            0.2, 
            true
        )
    else
        -- Tween to zero then hide
        dropdownList:TweenSize(
            UDim2.new(1, -20, 0, 0), 
            Enum.EasingDirection.Out, 
            Enum.EasingStyle.Quad, 
            0.2, 
            true, 
            function()
                dropdownList.Visible = false
            end
        )
    end
end)

-- Remove All Button
removeAllBtn.MouseButton1Click:Connect(function()
    task.spawn(function()
        removeAllBtn.Text = "Removing..."
        removeAllBtn.BackgroundColor3 = Color3.fromRGB(150, 30, 30)
        
        -- List of body parts to remove
        local bodyParts = {
            "Head", "Torso", "Left Arm", "Right Arm", "Left Leg", "Right Leg",
            "UpperTorso", "LowerTorso", "LeftUpperArm", "LeftLowerArm", "LeftHand",
            "RightUpperArm", "RightLowerArm", "RightHand", "LeftUpperLeg",
            "LeftLowerLeg", "LeftFoot", "RightUpperLeg", "RightLowerLeg", "RightFoot"
        }
        
        local totalCount = 0
        
        if selectedMode == "everyone" then
            -- Remove from ALL players
            print("🌍 Removing from EVERYONE...")
            for _, player in ipairs(game.Players:GetPlayers()) do
                local character = player.Character
                if character then
                    for _, partName in ipairs(bodyParts) do
                        local part = character:FindFirstChild(partName)
                        if part then
                            removeBodyPart(part)
                            totalCount = totalCount + 1
                            wait(0.05)
                        end
                    end
                end
            end
        elseif selectedMode == "other" then
            -- Remove from all EXCEPT yourself
            print("👥 Removing from OTHER players...")
            for _, player in ipairs(game.Players:GetPlayers()) do
                if player ~= plr then
                    local character = player.Character
                    if character then
                        for _, partName in ipairs(bodyParts) do
                            local part = character:FindFirstChild(partName)
                            if part then
                                removeBodyPart(part)
                                totalCount = totalCount + 1
                                wait(0.05)
                            end
                        end
                    end
                end
            end
        else
            -- Remove from selected player only
            if selectedCharacter then
                for _, partName in ipairs(bodyParts) do
                    local part = selectedCharacter:FindFirstChild(partName)
                    if part then
                        removeBodyPart(part)
                        totalCount = totalCount + 1
                        wait(0.05)
                    end
                end
            end
        end
        
        removeAllBtn.Text = "Removed " .. totalCount .. " parts!"
        wait(2)
        removeAllBtn.Text = "🔴 Remove All Parts"
        removeAllBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    end)
end)

-- Remove Accessories Button
removeAccessoriesBtn.MouseButton1Click:Connect(function()
    task.spawn(function()
        removeAccessoriesBtn.Text = "Removing..."
        removeAccessoriesBtn.BackgroundColor3 = Color3.fromRGB(150, 70, 30)
        
        local totalCount = 0
        
        if selectedMode == "everyone" then
            -- Remove from ALL players
            print("🌍 Removing accessories from EVERYONE...")
            for _, player in ipairs(game.Players:GetPlayers()) do
                local character = player.Character
                if character then
                    totalCount = totalCount + removeAccessories(character)
                end
            end
        elseif selectedMode == "other" then
            -- Remove from all EXCEPT yourself
            print("👥 Removing accessories from OTHER players...")
            for _, player in ipairs(game.Players:GetPlayers()) do
                if player ~= plr then
                    local character = player.Character
                    if character then
                        totalCount = totalCount + removeAccessories(character)
                    end
                end
            end
        else
            -- Remove from selected player only
            if selectedCharacter then
                totalCount = removeAccessories(selectedCharacter)
            end
        end
        
        removeAccessoriesBtn.Text = "Removed " .. totalCount .. " accessories!"
        wait(2)
        removeAccessoriesBtn.Text = "🌐 Remove All Accessories"
        removeAccessoriesBtn.BackgroundColor3 = Color3.fromRGB(200, 100, 50)
    end)
end)

-- Clone & Reset Button
cloneResetBtn.MouseButton1Click:Connect(function()
    task.spawn(function()
        cloneResetBtn.Text = "Cloning..."
        cloneResetBtn.BackgroundColor3 = Color3.fromRGB(30, 100, 150)
        
        if selectedMode == "self" then
            -- Single player mode
            local success = cloneAndResetPlayer(selectedPlayer, selectedCharacter)
            
            if success then
                cloneResetBtn.Text = "Clone Created!"
            else
                cloneResetBtn.Text = "Clone Failed!"
            end
        elseif selectedMode == "other" then
            -- Other mode: Clone all players except local player
            local successCount = 0
            for _, player in ipairs(game.Players:GetPlayers()) do
                if player ~= plr then
                    local success, character = pcall(function()
                        return player.Character
                    end)
                    
                    if success and character then
                        statusLabel.Text = "Cloning player: " .. player.Name
                        local cloneSuccess = cloneAndResetPlayer(player, character)
                        if cloneSuccess then
                            successCount = successCount + 1
                        end
                        task.wait(0.1)
                    end
                end
            end
            cloneResetBtn.Text = "Cloned " .. successCount .. " players!"
        elseif selectedMode == "everyone" then
            -- Everyone mode: Clone ALL players including local player
            local successCount = 0
            for _, player in ipairs(game.Players:GetPlayers()) do
                local success, character = pcall(function()
                    return player.Character
                end)
                
                if success and character then
                    statusLabel.Text = "Cloning player: " .. player.Name
                    local cloneSuccess
                    
                    -- Don't reset local player (use clone-only function)
                    if player == plr then
                        cloneSuccess = cloneCharacterOnly(character)
                    else
                        cloneSuccess = cloneAndResetPlayer(player, character)
                    end
                    
                    if cloneSuccess then
                        successCount = successCount + 1
                    end
                    task.wait(0.1)
                end
            end
            cloneResetBtn.Text = "Cloned " .. successCount .. " players!"
        end
        
        wait(2)
        cloneResetBtn.Text = "🎭 Clone & Reset Player"
        cloneResetBtn.BackgroundColor3 = Color3.fromRGB(50, 150, 200)
        statusLabel.Text = "Ready"
    end)
end)

-- Bulk Clone Button
bulkCloneBtn.MouseButton1Click:Connect(function()
    task.spawn(function()
        local amount = tonumber(bulkCloneInput.Text) or 10
        if amount < 1 then amount = 1 end
        if amount > 100 then amount = 100 end
        
        bulkCloneBtn.Text = "Cloning..."
        bulkCloneBtn.BackgroundColor3 = Color3.fromRGB(70, 30, 150)
        
        if selectedMode == "self" then
            -- Single player mode
            local count = bulkCloneCharacter(selectedCharacter, amount)
            bulkCloneBtn.Text = "Created " .. count .. " clones!"
        elseif selectedMode == "other" then
            -- Other mode: Bulk clone all players except local player
            local totalCount = 0
            for _, player in ipairs(game.Players:GetPlayers()) do
                if player ~= plr then
                    local success, character = pcall(function()
                        return player.Character
                    end)
                    
                    if success and character then
                        statusLabel.Text = "Bulk cloning: " .. player.Name
                        local count = bulkCloneCharacter(character, amount)
                        totalCount = totalCount + count
                        task.wait(0.1)
                    end
                end
            end
            bulkCloneBtn.Text = "Created " .. totalCount .. " clones!"
        elseif selectedMode == "everyone" then
            -- Everyone mode: Bulk clone ALL players including local player
            local totalCount = 0
            for _, player in ipairs(game.Players:GetPlayers()) do
                local success, character = pcall(function()
                    return player.Character
                end)
                
                if success and character then
                    statusLabel.Text = "Bulk cloning: " .. player.Name
                    local count = bulkCloneCharacter(character, amount)
                    totalCount = totalCount + count
                    task.wait(0.1)
                end
            end
            bulkCloneBtn.Text = "Created " .. totalCount .. " clones!"
        end
        
        wait(2)
        bulkCloneBtn.Text = "💥 Bulk Clone"
        bulkCloneBtn.BackgroundColor3 = Color3.fromRGB(100, 50, 200)
        statusLabel.Text = "Ready"
    end)
end)

