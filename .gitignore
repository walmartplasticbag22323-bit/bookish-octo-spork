-- Variable to track dropdown state
local dropdownOpen = false

-- Function to get Building Tools
local function getBuildingTools()
    local toolName = useBToolsPlus and "Building Tools Plus" or "Building Tools"
    return plr.Backpack:WaitForChild(toolName, 5) or chr:FindFirstChild(toolName)
end

-- 3D Drag Selection Functions
-- Function to get ServerEndpoint
local function getServerEndpoint()
    local buildingTools = getBuildingTools()
    if not buildingTools then return nil end
    return buildingTools:WaitForChild("SyncAPI"):WaitForChild("ServerEndpoint")
end

-- Function to check if player is whitelisted
local function isWhitelisted(playerName)
    for _, name in ipairs(whitelistedPlayers) do
        if name == playerName then
            return true
        end
    end
    return false
end

local function cancelDragSelection()
    dragSelectionActive = false
    dragPhase = 0
    dragStartPos = nil
    dragCurrentPos = nil
    dragSelectedParts = {}
    dragLockedX = nil
    dragLockedZ = nil
    dragStartMouseY = nil
    dragCurrentY = nil
    
    if dragSelectionBox then
        dragSelectionBox:Destroy()
        dragSelectionBox = nil
    end
    
    if dragCountLabel then
        dragCountLabel:Destroy()
        dragCountLabel = nil
    end
    
    print("🚫 Drag selection cancelled")
end

local function updateDragSelectionBox()
    if not dragStartPos or not dragCurrentPos then return end
    
    -- Calculate bounds based on phase (ONE AXIS AT A TIME)
    local minPos = dragStartPos
    local maxPos = dragStartPos
    
    if dragPhase == 1 then
        -- X axis only - drag from start position along X
        maxPos = Vector3.new(dragCurrentPos.X, dragStartPos.Y, dragStartPos.Z)
        minPos = Vector3.new(dragStartPos.X, dragStartPos.Y, dragStartPos.Z)
    elseif dragPhase == 2 then
        -- Z axis only - use locked X dimensions, drag along Z from start
        local xMin = math.min(dragStartPos.X, dragLockedX or dragStartPos.X)
        local xMax = math.max(dragStartPos.X, dragLockedX or dragStartPos.X)
        minPos = Vector3.new(xMin, dragStartPos.Y, dragStartPos.Z)
        maxPos = Vector3.new(xMax, dragStartPos.Y, dragCurrentPos.Z)
    elseif dragPhase == 3 then
        -- Y axis only - use locked X and Z dimensions, use dragCurrentY instead of raycast
        local xMin = math.min(dragStartPos.X, dragLockedX or dragStartPos.X)
        local xMax = math.max(dragStartPos.X, dragLockedX or dragStartPos.X)
        local zMin = math.min(dragStartPos.Z, dragLockedZ or dragStartPos.Z)
        local zMax = math.max(dragStartPos.Z, dragLockedZ or dragStartPos.Z)
        local yValue = dragCurrentY or dragStartPos.Y
        minPos = Vector3.new(xMin, dragStartPos.Y, zMin)
        maxPos = Vector3.new(xMax, yValue, zMax)
    end
    
    -- Ensure min is actually minimum and max is maximum
    local actualMin = Vector3.new(
        math.min(minPos.X, maxPos.X),
        math.min(minPos.Y, maxPos.Y),
        math.min(minPos.Z, maxPos.Z)
    )
    local actualMax = Vector3.new(
        math.max(minPos.X, maxPos.X),
        math.max(minPos.Y, maxPos.Y),
        math.max(minPos.Z, maxPos.Z)
    )
    
    -- Calculate center and size
    local center = (actualMin + actualMax) / 2
    local size = (actualMax - actualMin)
    
    -- Create or update selection box
    if not dragSelectionBox then
        dragSelectionBox = Instance.new("Part")
        dragSelectionBox.Name = "DragSelectionBox"
        dragSelectionBox.Anchored = true
        dragSelectionBox.CanCollide = false
        dragSelectionBox.Transparency = 0.5  -- More visible
        dragSelectionBox.Material = Enum.Material.Neon
        dragSelectionBox.Parent = workspace
        
        -- Add selection box visual
        local selBox = Instance.new("SelectionBox")
        selBox.LineThickness = 0.1  -- Thicker lines
        selBox.Transparency = 0.1  -- More visible
        selBox.Adornee = dragSelectionBox
        selBox.Parent = dragSelectionBox
        selBox.Color3 = Color3.fromRGB(0, 255, 255)
        
        -- Add part count label
        local billboardGui = Instance.new("BillboardGui")
        billboardGui.Name = "PartCountLabel"
        billboardGui.Size = UDim2.new(0, 200, 0, 50)
        billboardGui.StudsOffset = Vector3.new(0, 3, 0)
        billboardGui.AlwaysOnTop = true
        billboardGui.Parent = dragSelectionBox
        
        dragCountLabel = Instance.new("TextLabel")
        dragCountLabel.Size = UDim2.new(1, 0, 1, 0)
        dragCountLabel.BackgroundTransparency = 0.3
        dragCountLabel.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
        dragCountLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        dragCountLabel.TextScaled = true
        dragCountLabel.Font = Enum.Font.GothamBold
        dragCountLabel.Text = "0 parts"
        dragCountLabel.Parent = billboardGui
        
        print("✅ Created drag selection box with counter!")
    end
    
    -- Update color based on phase
    if dragPhase == 1 then
        dragSelectionBox.Color = Color3.fromRGB(255, 100, 100) -- Red for X
        dragSelectionBox:FindFirstChildOfClass("SelectionBox").Color3 = Color3.fromRGB(255, 100, 100)
    elseif dragPhase == 2 then
        dragSelectionBox.Color = Color3.fromRGB(100, 100, 255) -- Blue for Z
        dragSelectionBox:FindFirstChildOfClass("SelectionBox").Color3 = Color3.fromRGB(100, 100, 255)
    elseif dragPhase == 3 then
        dragSelectionBox.Color = Color3.fromRGB(100, 255, 100) -- Green for Y
        dragSelectionBox:FindFirstChildOfClass("SelectionBox").Color3 = Color3.fromRGB(100, 255, 100)
    end
    
    -- Add minimum size to make box visible
    local minSize = 0.5
    size = Vector3.new(
        math.max(size.X, minSize),
        math.max(size.Y, minSize),
        math.max(size.Z, minSize)
    )
    
    dragSelectionBox.Size = size
    dragSelectionBox.CFrame = CFrame.new(center)
    
    -- Update part count every 10 frames to reduce lag (only if enabled)
    if dragShowLiveCount then
        dragCountUpdateTick = dragCountUpdateTick + 1
        if dragCountLabel and dragCountUpdateTick % 10 == 0 then
            task.spawn(function()
                local quickCount = 0
                local min = center - size / 2
                local max = center + size / 2
                
                -- Only check parts in a reasonable area (use Region3 for initial filter)
                local region = Region3.new(min, max)
                region = region:ExpandToGrid(4)
                local nearbyParts = workspace:FindPartsInRegion3(region, nil, 1000) -- Limit to 1000 parts max
                
                for _, obj in ipairs(nearbyParts) do
                    if obj:IsA("BasePart") and obj ~= dragSelectionBox and obj.Name ~= "DragSelectionBox" and obj.Name ~= "Grass" then
                        local pos = obj.Position
                        if pos.X >= min.X and pos.X <= max.X and
                           pos.Y >= min.Y and pos.Y <= max.Y and
                           pos.Z >= min.Z and pos.Z <= max.Z then
                            quickCount = quickCount + 1
                        end
                    end
                end
                
                dragCountLabel.Text = quickCount .. " parts"
                if quickCount > 0 then
                    dragCountLabel.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
                else
                    dragCountLabel.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
                end
            end)
        end
    elseif dragCountLabel then
        -- Show "Press F" message instead
        dragCountLabel.Text = "Press F to select"
        dragCountLabel.BackgroundColor3 = Color3.fromRGB(100, 100, 255)
    end
end

local function getPartsInDragSelection()
    if not dragSelectionBox then 
        print("❌ No selection box!")
        return {} 
    end
    
    local parts = {}
    local boxPos = dragSelectionBox.Position
    local boxSize = dragSelectionBox.Size
    local min = boxPos - boxSize / 2
    local max = boxPos + boxSize / 2
    
    print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    print("📦 SELECTION BOX:")
    print("   Position:", boxPos)
    print("   Size:", boxSize)
    print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    
    -- Get ALL parts in workspace
    local allParts = {}
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") then
            table.insert(allParts, obj)
        end
    end
    
    print("🔍 Scanning " .. #allParts .. " parts...")
    
    for _, part in ipairs(allParts) do
        -- Skip the selection box itself
        if part == dragSelectionBox or part.Name == "DragSelectionBox" then
            continue
        end
        
        -- Skip grass
        if part.Name == "Grass" or string.find(part.Name, "Grass") then
            continue
        end
        
        -- Skip GUI parts
        if part:IsDescendantOf(plr.PlayerGui) then
            continue
        end
        
        -- Skip camera parts
        if part:IsDescendantOf(workspace.CurrentCamera) then
            continue
        end
        
        -- Check if part belongs to a player character
        local partOwner = nil
        local ancestor = part.Parent
        while ancestor do
            if ancestor:IsA("Model") and game.Players:GetPlayerFromCharacter(ancestor) then
                partOwner = game.Players:GetPlayerFromCharacter(ancestor)
                break
            end
            ancestor = ancestor.Parent
        end
        
        -- Skip if part belongs to whitelisted player
        if partOwner and isWhitelisted(partOwner.Name) then
            continue
        end
        
        -- Skip own character parts unless in steal mode with stealFromSelf enabled
        if partOwner == plr then
            if not (stealMode and stealFromSelf) then
                continue
            end
        end
        
        -- Check if part is within bounds
        local pos = part.Position
        
        local inBounds = pos.X >= min.X and pos.X <= max.X and
                        pos.Y >= min.Y and pos.Y <= max.Y and
                        pos.Z >= min.Z and pos.Z <= max.Z
        
        if inBounds then
            table.insert(parts, part)
        end
    end
    
    print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    print("✅ SELECTED " .. #parts .. " PARTS!")
    print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    
    return parts
end

local function finalizeDragSelection()
    print("🎯 Finalizing drag selection...")
    print("📦 Selection box exists:", dragSelectionBox ~= nil)
    
    if dragSelectionBox then
        print("📦 Box position:", dragSelectionBox.Position)
        print("📦 Box size:", dragSelectionBox.Size)
    end
    
    dragSelectedParts = getPartsInDragSelection()
    
    print("✅ Selected " .. #dragSelectedParts .. " parts!")
    
    if #dragSelectedParts == 0 then
        print("⚠️ No parts found in selection!")
        print("⚠️ Make sure you're selecting actual parts in the workspace!")
        cancelDragSelection()
        return
    end
    
    -- Process selected parts based on mode
    print("🔧 Mode check - Steal:", stealMode, "Unanchor:", unanchorMode)
    
    if stealMode then
        -- Steal all selected parts
        print("🐀 Starting steal mode...")
        
        -- First, select all parts in the tool
        local buildingTools = getBuildingTools()
        if buildingTools then
            local Core = buildingTools:FindFirstChild("Core")
            if Core then
                print("🔧 Selecting parts in Building Tools...")
                local success = pcall(function()
                    local Selection = require(Core).Selection
                    
                    -- Clear current selection
                    for i = #Selection.Parts, 1, -1 do
                        table.remove(Selection.Parts, i)
                    end
                    
                    -- Add all parts to selection
                    for _, part in ipairs(dragSelectedParts) do
                        table.insert(Selection.Parts, part)
                    end
                    
                    print("✅ Added " .. #dragSelectedParts .. " parts to tool selection!")
                    print("✅ Tool now has " .. #Selection.Parts .. " parts selected!")
                end)
                
                if not success then
                    warn("⚠️ Failed to select parts in tool (might not be needed)")
                end
            else
                warn("⚠️ Building Tools Core not found")
            end
        end
        
        task.spawn(function()
            local count = 0
            for _, part in ipairs(dragSelectedParts) do
                print("🐀 Attempting to steal:", part.Name)
                if stealPart(part) then
                    count = count + 1
                    print("✅ Stole:", part.Name)
                else
                    print("❌ Failed to steal:", part.Name)
                end
                task.wait(0.05)
            end
            print("🐀 FINAL: Stolen " .. count .. " parts!")
        end)
    elseif unanchorMode then
        -- Unanchor all selected parts
        print("🔓 Starting unanchor mode...")
        task.spawn(function()
            local serverEndpoint = getServerEndpoint()
            if not serverEndpoint then
                warn("❌ Building Tools ServerEndpoint not found!")
                return
            end
            print("✅ ServerEndpoint found!")
            
            local count = 0
            for _, part in ipairs(dragSelectedParts) do
                if part:IsA("BasePart") or part:IsA("MeshPart") then
                    local success = pcall(function()
                        serverEndpoint:InvokeServer("SetProperty", part, "Anchored", false)
                    end)
                    if success then
                        count = count + 1
                        print("✅ Unanchored:", part.Name)
                    else
                        print("❌ Failed to unanchor:", part.Name)
                    end
                end
            end
            print("🔓 FINAL: Unanchored " .. count .. " parts!")
        end)
    else
        -- Delete all selected parts
        print("⚔️ Starting delete mode...")
        task.spawn(function()
            local serverEndpoint = getServerEndpoint()
            if not serverEndpoint then
                warn("❌ Building Tools not found!")
                cancelDragSelection()
                return
            end
            print("✅ ServerEndpoint found!")
            print("🔄 Claiming ownership of " .. #dragSelectedParts .. " parts...")
            
            -- Claim ownership first
            local claimSuccess = pcall(function()
                local EscalateEvent = RS.raidRoleplay.Events.EscalateEvent
                local PartOwnership = RS.raidRoleplay.Modules.PartOwnership
                EscalateEvent:FireServer(PartOwnership, dragSelectedParts)
            end)
            
            if claimSuccess then
                print("✅ Ownership claim sent!")
            else
                print("⚠️ Ownership claim failed (might not be needed)")
            end
            
            task.wait(0.3)
            
            print("⚔️ Deleting parts...")
            
            -- Delete parts one by one with proper method
            local deletedCount = 0
            for _, part in ipairs(dragSelectedParts) do
                if part and part.Parent then
                    local success = pcall(function()
                        -- Method 1: Group then ungroup (most reliable)
                        local groupArgs = {
                            "CreateGroup",
                            "Model",
                            workspace,
                            {part}
                        }
                        serverEndpoint:InvokeServer(unpack(groupArgs))
                        task.wait(0.03)
                        
                        local ungroupArgs = {
                            "Ungroup",
                            {part}
                        }
                        serverEndpoint:InvokeServer(unpack(ungroupArgs))
                        deletedCount = deletedCount + 1
                        print("✅ Deleted:", part.Name)
                    end)
                    
                    if not success then
                        -- Fallback: Try direct remove
                        local fallbackSuccess = pcall(function()
                            serverEndpoint:InvokeServer("Remove", {part})
                            deletedCount = deletedCount + 1
                            print("✅ Deleted (fallback):", part.Name)
                        end)
                        
                        if not fallbackSuccess then
                            print("❌ Failed to delete:", part.Name)
                        end
                    end
                    
                    task.wait(0.05)
                end
            end
            
            print("⚔️ FINAL: Deleted " .. deletedCount .. "/" .. #dragSelectedParts .. " parts!")
        end)
    end
    
    -- Clean up
    cancelDragSelection()
end

-- Function to remove a body part
local function removeBodyPart(part)
    if not part or not part.Parent then
        warn("Part not found or not in character")
        return
    end
    
    local serverEndpoint = getServerEndpoint()
    if not serverEndpoint then
        warn("Building Tools not found!")
        return
    end
    
    -- Group the part
    local groupArgs = {
        "CreateGroup",
        "Model",
        workspace,
        {part}
    }
    serverEndpoint:InvokeServer(unpack(groupArgs))
    
    wait(0.05)
    
    -- Ungroup to remove
    local ungroupArgs = {
        "Ungroup",
        {part}
    }
    serverEndpoint:InvokeServer(unpack(ungroupArgs))
end

-- NEW: Steal part using group/ungroup exploit (from TheRat)
local function stealPart(part)
    if not part or not part.Parent then return false end
    
    local serverEndpoint = getServerEndpoint()
    if not serverEndpoint then return false end
    
    local success = false
    pcall(function()
        -- Step 1: Claim ownership
        local EscalateEvent = RS.raidRoleplay.Events.EscalateEvent
        local PartOwnership = RS.raidRoleplay.Modules.PartOwnership
        EscalateEvent:FireServer(PartOwnership, {part})
        
        task.wait(0.03)
        
        -- Step 2: Create a group (union) with the part
        local union = serverEndpoint:InvokeServer("CreateUnion", {part})
        
        if union then
            task.wait(0.01)
            
            -- Step 3: Ungroup (separate) - this gives us ownership
            serverEndpoint:InvokeServer("SeparateUnion", {union})
            
            -- The part is now ours!
            table.insert(stolenParts, part)
            
            -- Step 4: UNLOCK THE PART IMMEDIATELY (LOCALLY)
            task.wait(0.05)
            pcall(function()
                part.Locked = false
            end)
            
            success = true
        end
    end)
    
    return success
end

-- Function to remove entire model (for lightsaber mode)
local function removeModel(model)
    if not model or not model.Parent then
        warn("Model not found")
        return
    end
    
    -- Check if it's a player character
    local player = game.Players:GetPlayerFromCharacter(model)
    if player and isWhitelisted(player.Name) then
        warn("Cannot remove whitelisted player:", player.Name)
        return
    end
    
    local serverEndpoint = getServerEndpoint()
    if not serverEndpoint then
        warn("Building Tools not found!")
        return
    end
    
    -- Group the entire model
    local groupArgs = {
        "CreateGroup",
        "Model",
        workspace,
        {model}
    }
    
    pcall(function()
        serverEndpoint:InvokeServer(unpack(groupArgs))
    end)
    
    wait(0.05)
    
    -- Ungroup to remove
    local ungroupArgs = {
        "Ungroup",
        {model}
    }
    
    pcall(function()
        serverEndpoint:InvokeServer(unpack(ungroupArgs))
    end)
end

-- Function to clone character (without reset)
local function cloneCharacter(character)
    if not character or not character.Parent then
        warn("Character not found!")
        return false
    end
    
    local serverEndpoint = getServerEndpoint()
    if not serverEndpoint then
        warn("Building Tools not found!")
        return false
    end
    
    -- Create a group with the entire character (clones it)
    local cloneArgs = {
        "CreateGroup",
        "Model",
        workspace,
        {character}
    }
    
    local success = pcall(function()
        serverEndpoint:InvokeServer(unpack(cloneArgs))
    end)
    
    return success
end

-- Function to clone character and reset player
local function cloneAndResetPlayer(player, character)
    if not character or not character.Parent then
        warn("Character not found!")
        return false
    end
    
    local serverEndpoint = getServerEndpoint()
    if not serverEndpoint then
        warn("Building Tools not found!")
        return false
    end
    
    -- Create a group with the entire character (clones it)
    local cloneArgs = {
        "CreateGroup",
        "Model",
        workspace,
        {character}
    }
    
    local success = pcall(function()
        serverEndpoint:InvokeServer(unpack(cloneArgs))
    end)
    
    if not success then
        return false
    end
    
    wait(0.1)
    
    -- Now ungroup the original character (resets them)
    local ungroupArgs = {
        "Ungroup",
        {character}
    }
    
    success = pcall(function()
        serverEndpoint:InvokeServer(unpack(ungroupArgs))
    end)
    
    return success
end

-- Function to clone character WITHOUT resetting (no ungroup)
local function cloneCharacterOnly(character)
    if not character or not character.Parent then
        warn("Character not found!")
        return false
    end
    
    local serverEndpoint = getServerEndpoint()
    if not serverEndpoint then
        warn("Building Tools not found!")
        return false
    end
    
    -- Create a group with the entire character (clones it)
    local cloneArgs = {
        "CreateGroup",
        "Model",
        workspace,
        {character}
    }
    
    local success = pcall(function()
        serverEndpoint:InvokeServer(unpack(cloneArgs))
    end)
    
    return success
end

-- Function to bulk clone character
local function bulkCloneCharacter(character, amount)
    if not character or not character.Parent then
        warn("Character not found!")
        return 0
    end
    
    local serverEndpoint = getServerEndpoint()
    if not serverEndpoint then
        warn("Building Tools not found!")
        return 0
    end
    
    local successCount = 0
    
    for i = 1, amount do
        local cloneArgs = {
            "CreateGroup",
            "Model",
            workspace,
            {character}
        }
        
        local success = pcall(function()
            serverEndpoint:InvokeServer(unpack(cloneArgs))
        end)
        
        if success then
            successCount = successCount + 1
        end
        
        wait(0.05)
    end
    
    return successCount
end

-- Function to remove accessories
local function removeAccessories(character)
    if not character or not character.Parent then
        warn("Character not found!")
        return 0
    end
    
    local serverEndpoint = getServerEndpoint()
    if not serverEndpoint then
        warn("Building Tools not found!")
        return 0
    end
    
    local count = 0
    
    -- Find all accessories
    for _, child in ipairs(character:GetChildren()) do
        if child:IsA("Accessory") then
            -- Group the accessory
            local groupArgs = {
                "CreateGroup",
                "Model",
                workspace,
                {child}
            }
            
            pcall(function()
                serverEndpoint:InvokeServer(unpack(groupArgs))
            end)
            
            wait(0.05)
            
            -- Ungroup to remove
            local ungroupArgs = {
                "Ungroup",
                {child}
            }
            
            pcall(function()
                serverEndpoint:InvokeServer(unpack(ungroupArgs))
            end)
            
            count = count + 1
            wait(0.05)
        end
    end
    
    return count
end

-- Function to clear all body part buttons
local function clearBodyPartButtons()
    for _, child in ipairs(scrollFrame:GetChildren()) do
        if child:IsA("TextButton") then
            child:Destroy()
        end
    end
end

-- Function to create a button for each body part
local function createPartButton(partName, character)
    local button = Instance.new("TextButton")
    button.Name = partName .. "Button"
    button.Size = UDim2.new(1, -10, 0, 35)
    button.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    button.BorderSizePixel = 0
    button.Text = "Remove " .. partName
    button.TextColor3 = Color3.fromRGB(255, 255, 255)
    button.TextSize = 14
    button.Font = Enum.Font.Gotham
    button.Parent = scrollFrame
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 6)
    btnCorner.Parent = button
    
    button.MouseButton1Click:Connect(function()
        task.spawn(function()
            if selectedMode == "self" then
                -- Single player mode
                local currentPart = character:FindFirstChild(partName)
                if currentPart then
                    removeBodyPart(currentPart)
                    button.BackgroundColor3 = Color3.fromRGB(100, 30, 30)
                    button.Text = partName .. " (Removed)"
                    wait(2)
                    button.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
                    button.Text = "Remove " .. partName
                end
            elseif selectedMode == "other" then
                -- Other mode: Remove part from all players except local player
                button.BackgroundColor3 = Color3.fromRGB(255, 150, 50)
                button.Text = "Removing..."
                local count = 0
                
                for _, player in ipairs(game.Players:GetPlayers()) do
                    if player ~= plr then
                        local success, char = pcall(function()
                            return player.Character
                        end)
                        
                        if success and char then
                            local part = char:FindFirstChild(partName)
                            if part then
                                removeBodyPart(part)
                                count = count + 1
                                task.wait(0.1)
                            end
                        end
                    end
                end
                
                button.Text = "Removed from " .. count .. " players"
                wait(2)
                button.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
                button.Text = "Remove " .. partName
            elseif selectedMode == "everyone" then
                -- Everyone mode: Remove part from ALL players including local player
                button.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
                button.Text = "Removing..."
                local count = 0
                
                for _, player in ipairs(game.Players:GetPlayers()) do
                    local success, char = pcall(function()
                        return player.Character
                    end)
                    
                    if success and char then
                        local part = char:FindFirstChild(partName)
                        if part then
                            removeBodyPart(part)
                            count = count + 1
                            task.wait(0.1)
                        end
                    end
                end
                
                button.Text = "Removed from " .. count .. " players"
                wait(2)
                button.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
                button.Text = "Remove " .. partName
            end
        end)
    end)
end

-- Function to populate body part buttons
local function populateBodyParts(character)
    clearBodyPartButtons()
    
    -- List of body parts to check (R6 and R15)
    local bodyParts = {
        "Head", "Torso", "Left Arm", "Right Arm", "Left Leg", "Right Leg",
        "UpperTorso", "LowerTorso", "LeftUpperArm", "LeftLowerArm", "LeftHand",
        "RightUpperArm", "RightLowerArm", "RightHand", "LeftUpperLeg",
        "LeftLowerLeg", "LeftFoot", "RightUpperLeg", "RightLowerLeg", "RightFoot"
    }
    
    for _, partName in ipairs(bodyParts) do
        if character:FindFirstChild(partName) then
            createPartButton(partName, character)
        end
    end
    
    -- Update canvas size
    scrollFrame.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y + 10)
end

-- Function to update player dropdown
