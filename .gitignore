    toggleBoxBtn.Parent = lightsaberGui
    
    local toggleBoxBtnCorner = Instance.new("UICorner")
    toggleBoxBtnCorner.CornerRadius = UDim.new(0, 6)
    toggleBoxBtnCorner.Parent = toggleBoxBtn
    
    -- Info Label (replaces delete button since it auto-deletes)
    local infoLabel = Instance.new("TextLabel")
    infoLabel.Name = "InfoLabel"
    infoLabel.Size = UDim2.new(1, -20, 0, 50)
    infoLabel.Position = UDim2.new(0, 10, 0, 235)
