    infoLabel.BorderSizePixel = 0
    infoLabel.Text = "⚔️ DELETE: Click to remove!\n🔓 UNANCHOR: Click to unanchor!"
    infoLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    infoLabel.TextSize = 12
    infoLabel.Font = Enum.Font.GothamBold
    infoLabel.Parent = lightsaberGui
    
    local infoLabelCorner = Instance.new("UICorner")
    infoLabelCorner.CornerRadius = UDim.new(0, 6)
    infoLabelCorner.Parent = infoLabel
    
    -- Steal Mode Button (NEW!)
    local stealModeBtn = Instance.new("TextButton")
    stealModeBtn.Name = "StealModeButton"
    stealModeBtn.Size = UDim2.new(1, -20, 0, 40)
    stealModeBtn.Position = UDim2.new(0, 10, 0, 295)
    stealModeBtn.BackgroundColor3 = Color3.fromRGB(255, 150, 50)
    stealModeBtn.BorderSizePixel = 0
    stealModeBtn.Text = "🐀 STEAL MODE: OFF"
    stealModeBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    stealModeBtn.TextSize = 13
    stealModeBtn.Font = Enum.Font.GothamBold
    stealModeBtn.Parent = lightsaberGui
    
    local stealModeBtnCorner = Instance.new("UICorner")
    stealModeBtnCorner.CornerRadius = UDim.new(0, 6)
    stealModeBtnCorner.Parent = stealModeBtn
    
    -- Steal Mode Button Click
    stealModeBtn.MouseButton1Click:Connect(function()
        stealMode = not stealMode
        if stealMode then
            stealModeBtn.Text = "🐀 STEAL MODE: ON"
            stealModeBtn.BackgroundColor3 = Color3.fromRGB(50, 255, 50)
            infoLabel.Text = "🐀 STEAL: Click to steal!\n🔓 Parts auto-unlock!"
            infoLabel.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
        else
            stealModeBtn.Text = "🐀 STEAL MODE: OFF"
            stealModeBtn.BackgroundColor3 = Color3.fromRGB(255, 150, 50)
            infoLabel.Text = "⚔️ DELETE: Click to remove!\n🔓 UNANCHOR: Click to unanchor!"
            infoLabel.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
        end
    end)
    
    -- Steal From Self Toggle Button (NEW!)
    local stealSelfBtn = Instance.new("TextButton")
    stealSelfBtn.Name = "StealSelfButton"
    stealSelfBtn.Size = UDim2.new(1, -20, 0, 35)
    stealSelfBtn.Position = UDim2.new(0, 10, 0, 345)
    stealSelfBtn.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
    stealSelfBtn.BorderSizePixel = 0
    stealSelfBtn.Text = "🔄 Steal From Self: OFF"
    stealSelfBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    stealSelfBtn.TextSize = 12
    stealSelfBtn.Font = Enum.Font.GothamBold
    stealSelfBtn.Parent = lightsaberGui
    
    local stealSelfBtnCorner = Instance.new("UICorner")
    stealSelfBtnCorner.CornerRadius = UDim.new(0, 6)
    stealSelfBtnCorner.Parent = stealSelfBtn
    
    -- Steal From Self Button Click
    stealSelfBtn.MouseButton1Click:Connect(function()
        stealFromSelf = not stealFromSelf
        if stealFromSelf then
            stealSelfBtn.Text = "🔄 Steal From Self: ON"
            stealSelfBtn.BackgroundColor3 = Color3.fromRGB(50, 200, 200)
        else
            stealSelfBtn.Text = "🔄 Steal From Self: OFF"
            stealSelfBtn.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
        end
    end)
    
    -- Select Self Button (Quick test button)
    local selectSelfBtn = Instance.new("TextButton")
    selectSelfBtn.Name = "SelectSelfButton"
    selectSelfBtn.Size = UDim2.new(1, -20, 0, 35)
    selectSelfBtn.Position = UDim2.new(0, 10, 0, 390)
    selectSelfBtn.BackgroundColor3 = Color3.fromRGB(255, 100, 100)
    selectSelfBtn.BorderSizePixel = 0
    selectSelfBtn.Text = "👤 SELECT SELF (Test)"
    selectSelfBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    selectSelfBtn.TextSize = 12
    selectSelfBtn.Font = Enum.Font.GothamBold
    selectSelfBtn.Parent = lightsaberGui
    
    local selectSelfBtnCorner = Instance.new("UICorner")
    selectSelfBtnCorner.CornerRadius = UDim.new(0, 6)
    selectSelfBtnCorner.Parent = selectSelfBtn
    
    -- Select Self Button Click
    selectSelfBtn.MouseButton1Click:Connect(function()
        print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
        print("👤 SELECT SELF - Testing selection...")
        print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
        
        if not chr then
            warn("❌ Character not found!")
            return
        end
        
        -- Get all character parts
        local charParts = {}
        for _, part in ipairs(chr:GetDescendants()) do
            if part:IsA("BasePart") then
                table.insert(charParts, part)
            end
        end
        
        print("📊 Found " .. #charParts .. " parts in your character")
        
        if #charParts == 0 then
            warn("❌ No parts found in character!")
            return
        end
        
        -- Set them as selected parts
        dragSelectedParts = charParts
        
        print("✅ Selected " .. #dragSelectedParts .. " parts!")
        print("🔧 Mode - Steal:", stealMode, "Unanchor:", unanchorMode)
        
        -- Process based on mode
        if stealMode then
            print("🐀 Starting steal mode on self...")
            
            -- First, select all parts in the tool
            local buildingTools = getBuildingTools()
            if buildingTools then
                local Core = buildingTools:FindFirstChild("Core")
                if Core then
                    print("🔧 Selecting parts in Building Tools...")
                    local success = pcall(function()
                        local Selection = require(Core).Selection
                        
                        -- Clear current selection
                        for i = #Selection.Parts, 1, -1 do
                            table.remove(Selection.Parts, i)
                        end
                        
                        -- Add all parts to selection
                        for _, part in ipairs(dragSelectedParts) do
                            table.insert(Selection.Parts, part)
                        end
                        
                        print("✅ Added " .. #dragSelectedParts .. " parts to tool selection!")
                        print("✅ Tool now has " .. #Selection.Parts .. " parts selected!")
                    end)
                    
                    if not success then
                        warn("⚠️ Failed to select parts in tool (might not be needed)")
                    end
                else
                    warn("⚠️ Building Tools Core not found")
                end
            end
            
            task.spawn(function()
                local count = 0
                for _, part in ipairs(dragSelectedParts) do
                    print("🐀 Attempting to steal:", part.Name)
                    if stealPart(part) then
                        count = count + 1
                        print("✅ Stole:", part.Name)
                    else
                        print("❌ Failed to steal:", part.Name)
                    end
                    task.wait(0.05)
                end
                print("🐀 FINAL: Stolen " .. count .. " parts!")
            end)
        elseif unanchorMode then
            print("🔓 Starting unanchor mode on self...")
            task.spawn(function()
                local serverEndpoint = getServerEndpoint()
                if not serverEndpoint then
                    warn("❌ Building Tools ServerEndpoint not found!")
                    return
                end
                print("✅ ServerEndpoint found!")
                
                local count = 0
                for _, part in ipairs(dragSelectedParts) do
                    if part:IsA("BasePart") or part:IsA("MeshPart") then
                        local success = pcall(function()
                            serverEndpoint:InvokeServer("SetProperty", part, "Anchored", false)
                        end)
                        if success then
                            count = count + 1
                            print("✅ Unanchored:", part.Name)
                        else
                            print("❌ Failed to unanchor:", part.Name)
                        end
                    end
                end
                print("🔓 FINAL: Unanchored " .. count .. " parts!")
            end)
        else
            print("⚔️ Starting delete mode on self...")
            task.spawn(function()
                local serverEndpoint = getServerEndpoint()
                if not serverEndpoint then
                    warn("❌ Building Tools not found!")
                    return
                end
                print("✅ ServerEndpoint found!")
                print("🔄 Claiming ownership of " .. #dragSelectedParts .. " parts...")
                
                -- Claim ownership first
                local claimSuccess = pcall(function()
                    local EscalateEvent = RS.raidRoleplay.Events.EscalateEvent
                    local PartOwnership = RS.raidRoleplay.Modules.PartOwnership
                    EscalateEvent:FireServer(PartOwnership, dragSelectedParts)
                end)
                
                if claimSuccess then
                    print("✅ Ownership claim sent!")
                else
                    print("⚠️ Ownership claim failed (might not be needed)")
                end
                
                task.wait(0.3)
                
                print("⚔️ Deleting parts...")
                
                -- Delete parts one by one
                local deletedCount = 0
                for _, part in ipairs(dragSelectedParts) do
                    if part and part.Parent then
                        local success = pcall(function()
                            -- Method 1: Group then ungroup
                            local groupArgs = {
                                "CreateGroup",
                                "Model",
                                workspace,
                                {part}
                            }
                            serverEndpoint:InvokeServer(unpack(groupArgs))
                            task.wait(0.03)
                            
                            local ungroupArgs = {
                                "Ungroup",
                                {part}
                            }
                            serverEndpoint:InvokeServer(unpack(ungroupArgs))
                            deletedCount = deletedCount + 1
                            print("✅ Deleted:", part.Name)
                        end)
                        
                        if not success then
                            -- Fallback: Try direct remove
                            local fallbackSuccess = pcall(function()
                                serverEndpoint:InvokeServer("Remove", {part})
                                deletedCount = deletedCount + 1
                                print("✅ Deleted (fallback):", part.Name)
                            end)
                            
                            if not fallbackSuccess then
                                print("❌ Failed to delete:", part.Name)
                            end
                        end
                        
                        task.wait(0.05)
                    end
                end
                
                print("⚔️ FINAL: Deleted " .. deletedCount .. "/" .. #dragSelectedParts .. " parts!")
            end)
        end
    end)
    
    -- 3D Drag Selection Toggle Button
    local dragSelectionBtn = Instance.new("TextButton")
    dragSelectionBtn.Name = "DragSelectionButton"
    dragSelectionBtn.Size = UDim2.new(1, -20, 0, 35)
    dragSelectionBtn.Position = UDim2.new(0, 10, 0, 430)
    dragSelectionBtn.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
    dragSelectionBtn.BorderSizePixel = 0
    dragSelectionBtn.Text = "📦 3D Drag Select: OFF"
    dragSelectionBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    dragSelectionBtn.TextSize = 12
    dragSelectionBtn.Font = Enum.Font.GothamBold
    dragSelectionBtn.Parent = lightsaberGui
    
    local dragSelectionBtnCorner = Instance.new("UICorner")
    dragSelectionBtnCorner.CornerRadius = UDim.new(0, 6)
    dragSelectionBtnCorner.Parent = dragSelectionBtn
    
    -- Drag Selection Button Click
    dragSelectionBtn.MouseButton1Click:Connect(function()
        dragSelectionMode = not dragSelectionMode
        if dragSelectionMode then
            dragSelectionBtn.Text = "📦 3D Drag Select: ON"
            dragSelectionBtn.BackgroundColor3 = Color3.fromRGB(255, 200, 50)
            infoLabel.Text = "📦 Click to start drag selection!\nX→Z→Y (UP/DOWN). Press F to finish, ] to cancel"
            infoLabel.BackgroundColor3 = Color3.fromRGB(255, 200, 50)
        else
            dragSelectionBtn.Text = "📦 3D Drag Select: OFF"
            dragSelectionBtn.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
            -- Restore original info label
            if stealMode then
                infoLabel.Text = "🐀 STEAL: Click to steal!\n🔓 Parts auto-unlock!"
                infoLabel.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
            else
                infoLabel.Text = "⚔️ DELETE: Click to remove!\n🔓 UNANCHOR: Click to unanchor!"
                infoLabel.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
            end
            -- Cancel any active drag selection
            cancelDragSelection()
        end
    end)
    
    -- Live Counter Toggle Button (for drag selection)
    local liveCounterBtn = Instance.new("TextButton")
    liveCounterBtn.Name = "LiveCounterButton"
    liveCounterBtn.Size = UDim2.new(1, -20, 0, 30)
    liveCounterBtn.Position = UDim2.new(0, 10, 0, 470)
    liveCounterBtn.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
    liveCounterBtn.BorderSizePixel = 0
    liveCounterBtn.Text = "📊 Live Counter: OFF (reduces lag)"
    liveCounterBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    liveCounterBtn.TextSize = 11
    liveCounterBtn.Font = Enum.Font.Gotham
    liveCounterBtn.Parent = lightsaberGui
    
    local liveCounterBtnCorner = Instance.new("UICorner")
    liveCounterBtnCorner.CornerRadius = UDim.new(0, 6)
    liveCounterBtnCorner.Parent = liveCounterBtn
    
    -- Live Counter Button Click
    liveCounterBtn.MouseButton1Click:Connect(function()
        dragShowLiveCount = not dragShowLiveCount
        if dragShowLiveCount then
            liveCounterBtn.Text = "📊 Live Counter: ON (may lag)"
            liveCounterBtn.BackgroundColor3 = Color3.fromRGB(255, 150, 50)
        else
            liveCounterBtn.Text = "📊 Live Counter: OFF (reduces lag)"
            liveCounterBtn.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
        end
    end)
    
    -- Unanchor Saber Mode Button
    local unanchorModeBtn = Instance.new("TextButton")
    unanchorModeBtn.Name = "UnanchorModeButton"
    unanchorModeBtn.Size = UDim2.new(1, -20, 0, 40)
    unanchorModeBtn.Position = UDim2.new(0, 10, 0, 505)
    unanchorModeBtn.BackgroundColor3 = Color3.fromRGB(150, 100, 255)
    unanchorModeBtn.BorderSizePixel = 0
    unanchorModeBtn.Text = "🔓 UNANCHOR MODE: OFF"
    unanchorModeBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    unanchorModeBtn.TextSize = 13
    unanchorModeBtn.Font = Enum.Font.GothamBold
    unanchorModeBtn.Parent = lightsaberGui
    
    local unanchorModeBtnCorner = Instance.new("UICorner")
    unanchorModeBtnCorner.CornerRadius = UDim.new(0, 6)
    unanchorModeBtnCorner.Parent = unanchorModeBtn
    
    -- Unanchor Mode Button Click
    unanchorModeBtn.MouseButton1Click:Connect(function()
        unanchorMode = not unanchorMode
        if unanchorMode then
            unanchorModeBtn.Text = "🔓 UNANCHOR MODE: ON"
            unanchorModeBtn.BackgroundColor3 = Color3.fromRGB(100, 255, 100)
        else
            unanchorModeBtn.Text = "🔓 UNANCHOR MODE: OFF"
            unanchorModeBtn.BackgroundColor3 = Color3.fromRGB(150, 100, 255)
        end
    end)
    
    -- Whitelist Section Label
    local whitelistLabel = Instance.new("TextLabel")
    whitelistLabel.Name = "WhitelistLabel"
    whitelistLabel.Size = UDim2.new(1, -20, 0, 25)
    whitelistLabel.Position = UDim2.new(0, 10, 0, 555)
    whitelistLabel.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    whitelistLabel.BorderSizePixel = 0
    whitelistLabel.Text = "🛡️ WHITELIST"
    whitelistLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    whitelistLabel.TextSize = 13
    whitelistLabel.Font = Enum.Font.GothamBold
    whitelistLabel.Parent = lightsaberGui
    
    local whitelistLabelCorner = Instance.new("UICorner")
    whitelistLabelCorner.CornerRadius = UDim.new(0, 6)
    whitelistLabelCorner.Parent = whitelistLabel
    
    -- Whitelist ScrollFrame
    local whitelistScroll = Instance.new("ScrollingFrame")
    whitelistScroll.Name = "WhitelistScroll"
    whitelistScroll.Size = UDim2.new(1, -20, 0, 70)
    whitelistScroll.Position = UDim2.new(0, 10, 0, 590)
    whitelistScroll.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    whitelistScroll.BorderSizePixel = 0
    whitelistScroll.ScrollBarThickness = 4
    whitelistScroll.Parent = lightsaberGui
    
    local whitelistScrollCorner = Instance.new("UICorner")
    whitelistScrollCorner.CornerRadius = UDim.new(0, 6)
    whitelistScrollCorner.Parent = whitelistScroll
    
    local whitelistLayout = Instance.new("UIListLayout")
    whitelistLayout.SortOrder = Enum.SortOrder.LayoutOrder
    whitelistLayout.Padding = UDim.new(0, 3)
    whitelistLayout.Parent = whitelistScroll
    
    local whitelistPadding = Instance.new("UIPadding")
    whitelistPadding.PaddingTop = UDim.new(0, 5)
    whitelistPadding.PaddingBottom = UDim.new(0, 5)
    whitelistPadding.PaddingLeft = UDim.new(0, 5)
    whitelistPadding.PaddingRight = UDim.new(0, 5)
    whitelistPadding.Parent = whitelistScroll
    
    -- Add Player to Whitelist Button
    local addWhitelistBtn = Instance.new("TextButton")
    addWhitelistBtn.Name = "AddWhitelistButton"
    addWhitelistBtn.Size = UDim2.new(1, -20, 0, 35)
    addWhitelistBtn.Position = UDim2.new(0, 10, 0, 670)
    addWhitelistBtn.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
    addWhitelistBtn.BorderSizePixel = 0
    addWhitelistBtn.Text = "➕ Add Selected Player"
    addWhitelistBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    addWhitelistBtn.TextSize = 13
    addWhitelistBtn.Font = Enum.Font.GothamBold
    addWhitelistBtn.Parent = lightsaberGui
    
    local addWhitelistBtnCorner = Instance.new("UICorner")
    addWhitelistBtnCorner.CornerRadius = UDim.new(0, 6)
    addWhitelistBtnCorner.Parent = addWhitelistBtn
    
    -- Function to update whitelist display
    local function updateWhitelistDisplay()
        -- Clear existing
        for _, child in ipairs(whitelistScroll:GetChildren()) do
            if child:IsA("Frame") then
                child:Destroy()
            end
        end
        
        -- Add each whitelisted player
        for _, playerName in ipairs(whitelistedPlayers) do
            local whitelistEntry = Instance.new("Frame")
            whitelistEntry.Name = playerName
            whitelistEntry.Size = UDim2.new(1, -10, 0, 25)
            whitelistEntry.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
            whitelistEntry.BorderSizePixel = 0
            whitelistEntry.Parent = whitelistScroll
            
            local whitelistEntryCorner = Instance.new("UICorner")
            whitelistEntryCorner.CornerRadius = UDim.new(0, 5)
            whitelistEntryCorner.Parent = whitelistEntry
            
            local nameLabel = Instance.new("TextLabel")
            nameLabel.Size = UDim2.new(1, -30, 1, 0)
            nameLabel.Position = UDim2.new(0, 5, 0, 0)
            nameLabel.BackgroundTransparency = 1
            nameLabel.Text = playerName
            nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
            nameLabel.TextSize = 12
            nameLabel.Font = Enum.Font.Gotham
            nameLabel.TextXAlignment = Enum.TextXAlignment.Left
            nameLabel.Parent = whitelistEntry
            
            local removeBtn = Instance.new("TextButton")
            removeBtn.Size = UDim2.new(0, 20, 0, 20)
            removeBtn.Position = UDim2.new(1, -23, 0, 2.5)
            removeBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
            removeBtn.BorderSizePixel = 0
            removeBtn.Text = "X"
            removeBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
            removeBtn.TextSize = 11
            removeBtn.Font = Enum.Font.GothamBold
            removeBtn.Parent = whitelistEntry
            
            local removeBtnCorner = Instance.new("UICorner")
            removeBtnCorner.CornerRadius = UDim.new(0, 4)
            removeBtnCorner.Parent = removeBtn
            
            removeBtn.MouseButton1Click:Connect(function()
                -- Remove from whitelist
                for i, name in ipairs(whitelistedPlayers) do
                    if name == playerName then
                        table.remove(whitelistedPlayers, i)
                        break
                    end
                end
                updateWhitelistDisplay()
            end)
        end
        
        whitelistScroll.CanvasSize = UDim2.new(0, 0, 0, whitelistLayout.AbsoluteContentSize.Y + 10)
    end
    
    -- Add player to whitelist
    addWhitelistBtn.MouseButton1Click:Connect(function()
        if selectedPlayer and not isWhitelisted(selectedPlayer.Name) then
            table.insert(whitelistedPlayers, selectedPlayer.Name)
            updateWhitelistDisplay()
        end
    end)
    
    -- Toggle selection mode (ACTIVATE/DEACTIVATE)
    toggleSelectionBtn.MouseButton1Click:Connect(function()
        lightsaberMode = not lightsaberMode
        
        if lightsaberMode then
            toggleSelectionBtn.Text = "🔴 DEACTIVATE"
            toggleSelectionBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
            statusLabel.Text = "🟢 ACTIVE - Click to select!"
            statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
        else
            toggleSelectionBtn.Text = "🟢 ACTIVATE"
            toggleSelectionBtn.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
            statusLabel.Text = "🔴 INACTIVE - Click Activate!"
            statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
            
            -- Clear selection when deactivating
            if selectionBox then
                selectionBox:Destroy()
                selectionBox = nil
            end
            selectedPart = nil
        end
    end)
    
    -- Unselect button (clears selection but keeps mode active)
    unselectBtn.MouseButton1Click:Connect(function()
        if selectionBox then
            selectionBox:Destroy()
            selectionBox = nil
        end
        selectedPart = nil
        print("Selection cleared - mode still active!")
    end)
    
    -- Toggle SelectionBox visibility
    toggleBoxBtn.MouseButton1Click:Connect(function()
        selectionBoxEnabled = not selectionBoxEnabled
        
        if selectionBoxEnabled then
            toggleBoxBtn.Text = "👁️ Hide SelectionBox"
            if selectionBox then
                selectionBox.Visible = true
            end
        else
            toggleBoxBtn.Text = "👁️ Show SelectionBox"
            if selectionBox then
                selectionBox.Visible = false
            end
        end
    end)
    
    -- Close button
    lightsaberCloseBtn.MouseButton1Click:Connect(function()
        lightsaberGui.Visible = false
        lightsaberMode = false
        if selectionBox then
            selectionBox:Destroy()
            selectionBox = nil
        end
        selectedPart = nil
    end)
    
    -- Initial whitelist display
    updateWhitelistDisplay()
end

-- Create the Lightsaber GUI
createLightsaberGUI()

-- Lightsaber Mode Button Click
lightsaberBtn.MouseButton1Click:Connect(function()
    if lightsaberGui then
        lightsaberGui.Visible = not lightsaberGui.Visible
    end
end)

-- Mouse click detection for Lightsaber Mode
mouse.Button1Down:Connect(function()
    if not lightsaberMode then return end
    
    -- DRAG SELECTION MODE
    if dragSelectionMode then
        if dragPhase == 0 then
            -- Start drag selection
            dragStartPos = mouse.Hit.Position
            dragCurrentPos = dragStartPos
            dragPhase = 1
            dragSelectionActive = true
            dragLockedX = nil
            dragLockedZ = nil
            dragStartMouseY = nil
            dragCurrentY = nil
            print("📦 Drag selection started! Move mouse along X axis (RED), then click")
            updateDragSelectionBox()
        elseif dragPhase == 1 then
            -- Lock X dimension, move to Z phase
            dragLockedX = dragCurrentPos.X
            dragPhase = 2
            print("📦 X axis locked at " .. math.floor(dragLockedX) .. "! Move mouse along Z axis (BLUE), then click")
            updateDragSelectionBox()
        elseif dragPhase == 2 then
            -- Lock Z dimension, move to Y phase
            dragLockedZ = dragCurrentPos.Z
            dragPhase = 3
            dragStartMouseY = mouse.Y
            dragCurrentY = dragStartPos.Y
            print("📦 Z axis locked at " .. math.floor(dragLockedZ) .. "! Move mouse UP/DOWN for Y axis (GREEN)")
            print("📦 Press F to FINALIZE or ] to CANCEL")
            updateDragSelectionBox()
        end
        return
    end
    
    -- NORMAL LIGHTSABER MODE
    local target = mouse.Target
    if not target then return end
    
    -- DON'T DELETE GUI PARTS!
    if target:IsDescendantOf(plr.PlayerGui) then
        return
    end
    
    -- DON'T DELETE THE SELECTIONBOX ITSELF!
    if target:IsA("SelectionBox") or target == selectionBox then
        return
    end
    
    -- DON'T DELETE GRASS!
    if target.Name == "Grass" then
        warn("🌱 Can't delete grass!")
        return
    end
    
    -- Check if it's your own character (only block if stealFromSelf is OFF AND in steal mode)
    if stealMode and not stealFromSelf and target:IsDescendantOf(chr) then
        warn("⚠️ Can't steal from yourself! Enable 'Steal From Self' toggle.")
        return
    end
    
    -- Check if it's a whitelisted player's character
    local character = target:FindFirstAncestorOfClass("Model")
    if character then
        local player = game.Players:GetPlayerFromCharacter(character)
        if player and isWhitelisted(player.Name) then
            warn("🛡️ Cannot remove whitelisted player:", player.Name)
            return
        end
    end
    
    print("⚔️ Lightsaber hit:", target:GetFullName())
    
    -- Update selected part
    selectedPart = target
    
    -- Create or update SelectionBox (visual feedback) - PARENT TO WORKSPACE!
    if selectionBox then
        selectionBox:Destroy()
    end
    
    if selectionBoxEnabled then
        selectionBox = Instance.new("SelectionBox")
        selectionBox.Adornee = target
        -- Color based on mode: Steal = Green, Unanchor = Blue, Delete = Pink
        if stealMode then
            selectionBox.Color3 = Color3.fromRGB(50, 255, 50)
        elseif unanchorMode then
            selectionBox.Color3 = Color3.fromRGB(100, 200, 255)
        else
            selectionBox.Color3 = Color3.fromRGB(255, 50, 150)
        end
        selectionBox.LineThickness = 0.05
        selectionBox.Transparency = 0.5
        selectionBox.Visible = true
        selectionBox.Parent = workspace -- PARENT TO WORKSPACE NOT TARGET!
    end
    
    -- STEAL MODE, UNANCHOR MODE, or DELETE MODE
    task.spawn(function()
        -- Small delay so SelectionBox shows first
        wait(0.05)
        
        if stealMode then
            -- STEAL MODE - Steal the part using group/ungroup exploit
            if target:IsA("BasePart") or target:IsA("MeshPart") then
                local success = stealPart(target)
                if success then
                    print("🐀 Stolen:", target:GetFullName())
                else
                    warn("❌ Failed to steal:", target:GetFullName())
                end
            elseif target:IsA("Model") then
                -- Steal all parts in the model
                local count = 0
                for _, part in ipairs(target:GetDescendants()) do
                    if part:IsA("BasePart") or part:IsA("MeshPart") then
                        if stealPart(part) then
                            count = count + 1
                        end
                        wait(0.05) -- Small delay between parts
                    end
                end
                print("🐀 Stolen " .. count .. " parts from model:", target:GetFullName())
            end
        elseif unanchorMode then
            -- UNANCHOR MODE - Just unanchor the part
            if target:IsA("BasePart") or target:IsA("MeshPart") then
                target.Anchored = false
                print("🔓 Unanchored:", target:GetFullName())
            elseif target:IsA("Model") then
                -- Unanchor all parts in the model
                for _, part in ipairs(target:GetDescendants()) do
                    if part:IsA("BasePart") or part:IsA("MeshPart") then
                        part.Anchored = false
                    end
                end
                print("🔓 Unanchored model:", target:GetFullName())
            end
        else
            -- DELETE MODE - Remove the part
            if character and (target:IsA("BasePart") or target:IsA("MeshPart")) then
                -- It's a body part - remove it
                removeBodyPart(target)
            elseif target:IsA("Model") then
                -- It's a model - remove the whole thing
                removeModel(target)
            else
                -- Just a regular part - remove it
                removeBodyPart(target)
            end
        end
        
        -- Clear selection after action
        wait(0.3)
        if selectionBox then
            selectionBox:Destroy()
            selectionBox = nil
        end
        selectedPart = nil
    end)
end)

-- Initialize
populateBodyParts(selectedCharacter)

-- Keyboard handler for drag selection (] to cancel, F to finalize)
game:GetService("UserInputService").InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    -- Press ] to cancel drag selection
    if input.KeyCode == Enum.KeyCode.RightBracket then
        if dragSelectionActive then
            print("🚫 Cancelling drag selection...")
            cancelDragSelection()
        end
    end
    
    -- Press F to finalize drag selection (only in phase 3)
    if input.KeyCode == Enum.KeyCode.F then
        if dragSelectionActive and dragPhase == 3 then
            print("✅ F key pressed - Finalizing selection!")
            finalizeDragSelection()
        elseif dragSelectionActive and dragPhase < 3 then
            print("⚠️ Complete all 3 axes first! (Currently on phase " .. dragPhase .. "/3)")
        end
    end
end)

-- Mouse move handler for drag selection
game:GetService("RunService").RenderStepped:Connect(function()
    if dragSelectionActive and dragPhase > 0 then
        if dragPhase == 3 then
            -- For Y-axis, use mouse screen position instead of raycast
            if dragStartMouseY then
                local mouseDelta = mouse.Y - dragStartMouseY
                -- Scale factor: 1 pixel = 0.1 studs (adjust as needed)
                local yOffset = -mouseDelta * 0.1
                dragCurrentY = dragStartPos.Y + yOffset
            end
        else
            -- For X and Z axes, use normal raycast
            dragCurrentPos = mouse.Hit.Position
        end
        updateDragSelectionBox()
    end
end)

-- Update player list when players join/leave
game.Players.PlayerAdded:Connect(function()
    if dropdownOpen then
        updatePlayerDropdown()
    end
end)

game.Players.PlayerRemoving:Connect(function()
    if dropdownOpen then
        updatePlayerDropdown()
    end
end)

print("Body Part Remover with Lightsaber Mode loaded!")
print("Click the ⚔️ LIGHTSABER MODE button to open the second GUI!")
print("📦 3D Drag Selection: Click X axis → Click Z axis → Click Y axis (move UP/DOWN) → Press F to finalize")
print("Press ] to cancel drag selection at any time")
