-- Eye positions relative to platform center
local function getEyePositions()
    if not clientPart or not clientPart.Parent then return nil, nil end
    
    local cf = clientPart.CFrame
    
    -- Left eye offset: -0.8 studs X, +2.45 studs Y, 0 studs Z
    -- Right eye offset: +1.3 studs X, +2.45 studs Y, 0 studs Z
    local leftEyeOffset = Vector3.new(-0.8, 2.45, 0)
    local rightEyeOffset = Vector3.new(1.3, 2.45, 0)
    
    local leftEyePos = cf * CFrame.new(leftEyeOffset)
    local rightEyePos = cf * CFrame.new(rightEyeOffset)
    
    return leftEyePos.Position, rightEyePos.Position
end

-- Destroy parts along laser path (OPTIMIZED - limit checks)
local function destroyPartsAlongLaser(startPos, endPos, radius)
    local direction = (endPos - startPos).Unit
    local distance = (endPos - startPos).Magnitude
    
    local mainMap = workspace:FindFirstChild("Terrain")
    if mainMap then
        mainMap = mainMap:FindFirstChild("Everything")
        if mainMap then
            mainMap = mainMap:FindFirstChild("MainMap")
        end
    end
    
    local partsToDestroy = {}
    local maxParts = 10 -- Limit parts destroyed per update to reduce lag
    
    -- Use Region3 for faster spatial queries instead of GetDescendants
    local region = Region3.new(startPos, endPos):ExpandToGrid(4)
    local partsInRegion = workspace:FindPartsInRegion3(region, nil, 100) -- Limit to 100 parts checked
    
    for _, obj in ipairs(partsInRegion) do
        if #partsToDestroy >= maxParts then break end -- Stop if we hit the limit
        
        if obj:IsA("BasePart") and obj.Name ~= "LaserBeam_Left" and obj.Name ~= "LaserBeam_Right" and obj.Name ~= "Platform_Client" and obj.Name ~= "Platform_Server" then
            -- Allow destroying "Grass" parts
            local shouldDestroy = obj.Name == "Grass"
            
            if not shouldDestroy then
                local isCharacterPart = false
                local isMainMapPart = false
                local isPlatformPart = obj == clientPart or obj == serverPart
                local isFakeCharacterPart = false
                local isPlayerTouching = false
                
                -- Check if part is from fake character (rigModel)
                if rigModel and obj:IsDescendantOf(rigModel) then
                    isFakeCharacterPart = true
                end
                
                -- Check if part is from player character
                if player.Character and obj:IsDescendantOf(player.Character) then
                    isCharacterPart = true
                end
                
                -- Check if part is from MainMap
                if mainMap and obj:IsDescendantOf(mainMap) then
                    isMainMapPart = true
                end
                
                -- Check if player is touching this part (don't destroy what we're standing on)
                if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                    local touchingParts = player.Character.HumanoidRootPart:GetTouchingParts()
                    for _, touchingPart in ipairs(touchingParts) do
                        if touchingPart == obj then
                            isPlayerTouching = true
                            break
                        end
                    end
                end
                
                shouldDestroy = not isCharacterPart and not isMainMapPart and not isPlatformPart and not isFakeCharacterPart and not isPlayerTouching
            end
            
            if shouldDestroy then
                local partPos = obj.Position
                local closestPoint = startPos + direction * math.clamp((partPos - startPos):Dot(direction), 0, distance)
                local distanceToLine = (partPos - closestPoint).Magnitude
                
                if distanceToLine <= radius then
                    table.insert(partsToDestroy, obj)
                end
            end
        end
    end
    
    if #partsToDestroy > 0 then
        task.spawn(function()
            local EscalateEvent = RS.raidRoleplay.Events.EscalateEvent
            local PartOwnership = RS.raidRoleplay.Modules.PartOwnership
            
            pcall(function()
                EscalateEvent:FireServer(PartOwnership, partsToDestroy)
            end)
            
            task.wait(0.15)
            
            for _, part in ipairs(partsToDestroy) do
                if part and part.Parent then
                    task.spawn(function()
                        pcall(function()
                            ep:InvokeServer("CreateGroup", "Model", workspace, {part})
                            task.wait(0.01)
                            ep:InvokeServer("Ungroup", {part})
                            task.wait(0.01)
                            
                            if part and part.Parent then
                                ep:InvokeServer("Remove", {part})
                            end
                        end)
                    end)
                    
                    task.wait(0.0001)
                end
            end
        end)
    end
end

-- Create single laser part (STEALTH: 0.001x size with 1000x mesh)
local function createLaserPart(name)
    local laserPart = ep:InvokeServer("CreatePart", "Normal", CFrame.new(0, -1000, 0), workspace)
    if not laserPart then return nil end
    
    laserPart.Name = name
    
    local EscalateEvent = RS.raidRoleplay.Events.EscalateEvent
    local PartOwnership = RS.raidRoleplay.Modules.PartOwnership
    EscalateEvent:FireServer(PartOwnership, {laserPart})
    
    repeat task.wait(0.01) until laserPart:FindFirstChild("RRPartOwner")
    
    -- Set initial size to 0.001x (stealth)
    local stealthSize = Vector3.new(0.3, 0.3, 0.3) * 0.001
    ep:InvokeServer("SyncResize", {{Part = laserPart, Size = stealthSize, CFrame = CFrame.new(0, -1000, 0)}})
    
    -- Set material properties
    SyncAPI:Invoke("SyncMaterial", {{Part = laserPart, Transparency = 0.2, Material = Enum.Material.Neon}})
    SyncAPI:Invoke("SyncColor", {{Part = laserPart, UnionColoring = true, Color = Color3.fromRGB(255, 0, 0)}})
    SyncAPI:Invoke("SyncAnchor", {{Part = laserPart, Anchored = true}})
    
    -- Add mesh with 1000x scale
    local mesh = Instance.new("BlockMesh")
    mesh.Scale = Vector3.new(1000, 1000, 1000)
    mesh.Parent = laserPart
    
    return laserPart
end

