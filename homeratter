-- Continuous laser update loop (batch move + resize)
local lastLaserUpdate = 0
local lastDestructionUpdate = 0
local LASER_UPDATE_RATE = 1/30 -- 30Hz updates (reduced from 60Hz for performance)
local DESTRUCTION_UPDATE_RATE = 1/10 -- 10Hz destruction checks (much slower)

RunService.Heartbeat:Connect(function()
    if not laserActive or not controlEnabled then return end
    if not leftLaser or not rightLaser or not leftLaser.Parent or not rightLaser.Parent then return end
    
    local currentTime = tick()
    if currentTime - lastLaserUpdate < LASER_UPDATE_RATE then return end
    lastLaserUpdate = currentTime
    
    local mouse = player:GetMouse()
    if not mouse.Target then return end
    
    local leftEye, rightEye = getEyePositions()
    if not leftEye or not rightEye then return end
    
    local targetPos = mouse.Hit.Position
    
    -- Raycast from each eye
    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {clientPart, serverPart, rigModel, player.Character, leftLaser, rightLaser}
    
    -- Add all fake character parts to filter
    if rigModel then
        for _, part in ipairs(rigModel:GetDescendants()) do
            if part:IsA("BasePart") then
                table.insert(raycastParams.FilterDescendantsInstances, part)
            end
        end
    end
    
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    
    -- Left eye raycast
    local leftDirection = (targetPos - leftEye).Unit
    local leftResult = workspace:Raycast(leftEye, leftDirection * 500, raycastParams)
    local leftHitPos = leftResult and leftResult.Position or (leftEye + leftDirection * 500)
    
    -- Right eye raycast
    local rightDirection = (targetPos - rightEye).Unit
    local rightResult = workspace:Raycast(rightEye, rightDirection * 500, raycastParams)
    local rightHitPos = rightResult and rightResult.Position or (rightEye + rightDirection * 500)
    
    -- Calculate laser CFrames and sizes
    local leftLength = (leftHitPos - leftEye).Magnitude
    local leftCF = CFrame.new(leftEye, leftHitPos) * CFrame.new(0, 0, -leftLength / 2)
    
    local rightLength = (rightHitPos - rightEye).Magnitude
    local rightCF = CFrame.new(rightEye, rightHitPos) * CFrame.new(0, 0, -rightLength / 2)
    
    -- Calculate stealth sizes (0.001x base with length)
    local leftStealthSize = Vector3.new(0.3, 0.3, leftLength) * 0.001
    local rightStealthSize = Vector3.new(0.3, 0.3, rightLength) * 0.001
    
    -- BATCH update both lasers (move + resize at same time)
    pcall(function()
        ep:InvokeServer("SyncResize", {
            {Part = leftLaser, Size = leftStealthSize, CFrame = leftCF},
            {Part = rightLaser, Size = rightStealthSize, CFrame = rightCF}
        })
    end)
    
    -- Destroy parts along laser paths (MUCH SLOWER UPDATE RATE)
    if currentTime - lastDestructionUpdate >= DESTRUCTION_UPDATE_RATE then
        lastDestructionUpdate = currentTime
        destroyPartsAlongLaser(leftEye, leftHitPos, 3)
        destroyPartsAlongLaser(rightEye, rightHitPos, 3)
    end
end)

