-- Toggle fly function (controls FAKE character, not real player)
local function toggleFly()
    flyEnabled = not flyEnabled
    
    if flyEnabled then
        -- Enable fly on FAKE character (rigModel)
        if not rigModel or not clientPart or not rigHumanoid then
            flyEnabled = false
            print("⚠️ Enable platform control first!")
            return
        end
        
        -- Create BodyPosition and BodyGyro on FAKE character
        bodyPos = Instance.new("BodyPosition")
        bodyGyro = Instance.new("BodyGyro")
        
        bodyPos.Position = clientPart.Position
        bodyPos.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        bodyPos.P = 100000
        bodyPos.D = 1750
        bodyPos.Parent = clientPart
        
        bodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
        bodyGyro.P = 100000
        bodyGyro.D = 2200
        bodyGyro.Parent = clientPart
        
        rigHumanoid.PlatformStand = true
        
        -- Fly update loop
        flyConnection = RunService.Heartbeat:Connect(function()
            if not flyEnabled or not bodyPos or not bodyGyro then return end
            
            local cam = workspace.CurrentCamera
            local cf = cam.CFrame.Rotation
            local dir = cf:VectorToObjectSpace(rigHumanoid.MoveDirection * 1) -- speed = 1
            local direction
            
            if dir.Magnitude == 0 then
                direction = Vector3.new(0, 0, 0)
            else
                direction = cf:VectorToWorldSpace(Vector3.new(dir.X, 0, dir.Z).Unit * dir.Magnitude)
            end
            
            bodyPos.Position = bodyPos.Position + direction
            bodyGyro.CFrame = cam.CFrame
            
            -- Disable collisions on fake character
            for _, part in ipairs(rigModel:GetChildren()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
            
            rigHumanoid.PlatformStand = true
        end)
        
        print("✈️ Fly enabled on platform!")
    else
        -- Disable fly
        if flyConnection then
            flyConnection:Disconnect()
            flyConnection = nil
        end
        
        if bodyPos then
            bodyPos:Destroy()
            bodyPos = nil
        end
        
        if bodyGyro then
            bodyGyro:Destroy()
            bodyGyro = nil
        end
        
        if rigHumanoid then
            rigHumanoid.PlatformStand = false
        end
        
        print("✈️ Fly disabled!")
    end
end

