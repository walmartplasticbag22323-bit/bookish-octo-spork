-- Mobile: Use player's MoveVector if available
local useMoveVector = isMobile and playerHumanoid:FindFirstChild("MoveVector") ~= nil

-- Humanoid-based movement loop
RunService.Heartbeat:Connect(function(dt)
    if not controlEnabled or not clientPart or not clientPart.Parent then return end
    if not rigHumanoid then return end
    
    local moveDirection = Vector3.new(0, 0, 0)
    
    if isMobile and useMoveVector then
        -- MOBILE: Read from player's MoveVector (joystick)
        local moveVector = playerHumanoid.MoveVector
        
        if moveVector.Magnitude > 0 then
            -- Get camera direction
            local cameraCF = currentCamera.CFrame
            local cameraLook = Vector3.new(cameraCF.LookVector.X, 0, cameraCF.LookVector.Z).Unit
            local cameraRight = Vector3.new(cameraCF.RightVector.X, 0, cameraCF.RightVector.Z).Unit
            
            -- Convert move vector to world space relative to camera
            moveDirection = (cameraLook * moveVector.Z + cameraRight * moveVector.X)
        end
        
        -- Copy jump state from player
        if playerHumanoid.Jump then
            rigHumanoid.Jump = true
        end
        
    else
        -- PC: Read from WASD keys
        local cameraCF = currentCamera.CFrame
        local cameraLook = Vector3.new(cameraCF.LookVector.X, 0, cameraCF.LookVector.Z).Unit
        local cameraRight = Vector3.new(cameraCF.RightVector.X, 0, cameraCF.RightVector.Z).Unit
        
        if moveInput.W then
            moveDirection = moveDirection + cameraLook
        end
        if moveInput.S then
            moveDirection = moveDirection - cameraLook
        end
        if moveInput.A then
            moveDirection = moveDirection - cameraRight
        end
        if moveInput.D then
            moveDirection = moveDirection + cameraRight
        end
    end
    
    -- Apply movement
    if moveDirection.Magnitude > 0 then
        moveDirection = moveDirection.Unit
        rigHumanoid:Move(moveDirection, false)
    else
        rigHumanoid:Move(Vector3.new(0, 0, 0), false)
    end
    
    -- Update humanoid WalkSpeed
    rigHumanoid.WalkSpeed = MOVE_SPEED
end)

