-- Explorer Node Creation
local function createExplorerNode(object, depth, layoutOrder)
	local nodeFrame = Instance.new("Frame")
	nodeFrame.Name = "Node_" .. object.Name
	nodeFrame.Size = UDim2.new(1, -10, 0, 22)
	nodeFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
	nodeFrame.BorderSizePixel = 0
	nodeFrame.LayoutOrder = layoutOrder
	
	local nodeCorner = Instance.new("UICorner")
	nodeCorner.CornerRadius = UDim.new(0, 3)
	nodeCorner.Parent = nodeFrame
	
	-- Expand/Collapse Button
	local expandButton = Instance.new("TextButton")
	expandButton.Name = "ExpandButton"
	expandButton.Size = UDim2.new(0, 18, 0, 18)
	expandButton.Position = UDim2.new(0, 5 + (depth * 15), 0, 2)
	expandButton.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
	expandButton.Text = "+"
	expandButton.TextColor3 = Color3.fromRGB(200, 200, 200)
	expandButton.TextSize = 12
	expandButton.Font = Enum.Font.GothamBold
	expandButton.BorderSizePixel = 0
	expandButton.Parent = nodeFrame
	
	local expandCorner = Instance.new("UICorner")
	expandCorner.CornerRadius = UDim.new(0, 3)
	expandCorner.Parent = expandButton
	
	-- Check if object has children
	local hasChildren = #object:GetChildren() > 0
	if not hasChildren then
		expandButton.Visible = false
	end
	
	-- Object Name Label
	local nameLabel = Instance.new("TextButton")
	nameLabel.Name = "NameLabel"
	nameLabel.Size = UDim2.new(1, -35 - (depth * 15), 0, 18)
	nameLabel.Position = UDim2.new(0, 28 + (depth * 15), 0, 2)
	nameLabel.BackgroundTransparency = 1
	nameLabel.Text = object.Name .. " (" .. object.ClassName .. ")"
	nameLabel.TextColor3 = Color3.fromRGB(220, 220, 220)
	nameLabel.TextSize = 11
	nameLabel.Font = Enum.Font.Gotham
	nameLabel.TextXAlignment = Enum.TextXAlignment.Left
	nameLabel.TextTruncate = Enum.TextTruncate.AtEnd
	nameLabel.Parent = nodeFrame
	
	-- Store object reference
	nodeObjects[nodeFrame] = object
	
	return nodeFrame, expandButton, nameLabel, hasChildren
end

-- Build Explorer Tree
local currentLayoutOrder = 0
local childrenContainers = {}

local function reorderAllNodes()
	-- Recursively reorder all visible nodes in proper hierarchy
	local order = 0
	local function reorderNode(node)
		if node.Visible then
			node.LayoutOrder = order
			order = order + 1
			
			local data = childrenContainers[node]
			if data and data.expanded then
				for _, childNode in ipairs(data.children) do
					reorderNode(childNode)
				end
			end
		end
	end
	
	-- Reorder all root nodes and their children
	for _, child in pairs(explorerScroll:GetChildren()) do
		if child:IsA("Frame") and child.Name:match("^Node_") then
			local data = childrenContainers[child]
			if data and data.depth == 0 then
				reorderNode(child)
			end
		end
	end
end

local function addNode(object, depth, parentNode)
	currentLayoutOrder = currentLayoutOrder + 1
	local nodeFrame, expandButton, nameLabel, hasChildren = createExplorerNode(object, depth, currentLayoutOrder)
	nodeFrame.Parent = explorerScroll
	nodeFrame.Visible = (depth == 0) -- Only show root nodes initially
	
	-- Track children for this node
	local childrenList = {}
	childrenContainers[nodeFrame] = {
		expanded = false, 
		children = childrenList, 
		childrenBuilt = false,
		object = object, 
		depth = depth,
		parent = parentNode
	}
	
	-- Expand/Collapse functionality
	if hasChildren then
		expandButton.MouseButton1Click:Connect(function()
			-- Don't allow expansion during search
			if searchBar.Text ~= "" then
				print("⚠️ Clear search to expand nodes")
				return
			end
			
			local nodeData = childrenContainers[nodeFrame]
			nodeData.expanded = not nodeData.expanded
			expandButton.Text = nodeData.expanded and "-" or "+"
			
			if nodeData.expanded then
				-- Build children if not already built
				if not nodeData.childrenBuilt then
					nodeData.childrenBuilt = true
					local children = object:GetChildren()
					
					-- Sort children: Terrain first, Camera last, then alphabetically
					table.sort(children, function(a, b)
						local aIsTerrain = a.Name == "Terrain"
						local bIsTerrain = b.Name == "Terrain"
						local aIsCamera = a.Name == "Camera"
						local bIsCamera = b.Name == "Camera"
						
						if aIsTerrain then return true end
						if bIsTerrain then return false end
						if aIsCamera then return false end
						if bIsCamera then return true end
						
						return a.Name:lower() < b.Name:lower()
					end)
					
					for i, child in ipairs(children) do
						-- Skip parts named "Part" if filter is enabled
						if not (filterPartsEnabled and child.Name == "Part" and child:IsA("BasePart")) then
							local childNode = addNode(child, depth + 1, nodeFrame)
							table.insert(nodeData.children, childNode)
						end
					end
				end
				
				-- Show immediate children only
				for _, childNode in ipairs(nodeData.children) do
					childNode.Visible = true
				end
			else
				-- Hide all children recursively
				local function hideChildren(node)
					local data = childrenContainers[node]
					if data then
						for _, childNode in ipairs(data.children) do
							childNode.Visible = false
							-- Collapse and hide their children too
							if data.expanded then
								data.expanded = false
								local childExpandBtn = childNode:FindFirstChild("ExpandButton")
								if childExpandBtn then
									childExpandBtn.Text = "+"
								end
							end
							hideChildren(childNode)
						end
					end
				end
				hideChildren(nodeFrame)
			end
			
			-- Reorder all nodes to maintain hierarchy
			reorderAllNodes()
			
			-- Update canvas size
			task.wait()
			local contentSize = explorerLayout.AbsoluteContentSize.Y
			explorerScroll.CanvasSize = UDim2.new(0, 0, 0, contentSize)
		end)
	end
	
	-- Selection functionality
	nameLabel.MouseButton1Click:Connect(function()
		local obj = nodeObjects[nodeFrame]
		if explorerSelectionMode == "target" then
			targetObject = obj
			targetExplorerButton.Text = "Select from Explorer"
			targetExplorerButton.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
			explorerSelectionMode = nil
			print("✓ Target selected:", obj.Name)
			updateDisplay()
		end
	end)
	
	-- Hover effect
	nameLabel.MouseEnter:Connect(function()
		nodeFrame.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
	end)
	nameLabel.MouseLeave:Connect(function()
		nodeFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
	end)
	
	return nodeFrame
end

local function buildExplorerTree()
	print("Building explorer tree...")
	
	-- Save expanded state before clearing
	local expandedPaths = {}
	for nodeFrame, data in pairs(childrenContainers) do
		if data.expanded then
			local obj = data.object
			if obj and obj.Parent then
				expandedPaths[obj:GetFullName()] = true
			end
		end
	end
	
	-- Clear existing
	for _, child in pairs(explorerScroll:GetChildren()) do
		if child:IsA("Frame") then
			child:Destroy()
		end
	end
	
	nodeObjects = {}
	childrenContainers = {}
	currentLayoutOrder = 0
	
	-- Add main services
	local services = {
		game:GetService("Workspace"),
		game:GetService("ReplicatedStorage"),
		game:GetService("ReplicatedFirst"),
		game:GetService("Lighting"),
		game:GetService("Players"),
		game:GetService("StarterGui"),
		game:GetService("StarterPack"),
		game:GetService("StarterPlayer")
	}
	
	for _, service in ipairs(services) do
		addNode(service, 0, nil)
	end
	
	-- Update canvas size
	task.wait()
	local contentSize = explorerLayout.AbsoluteContentSize.Y
	explorerScroll.CanvasSize = UDim2.new(0, 0, 0, contentSize)
	
	print("✓ Explorer tree built!")
	
	-- Restore expanded state
	if next(expandedPaths) then
		print("🔄 Restoring expanded nodes...")
		for nodeFrame, data in pairs(childrenContainers) do
			local obj = data.object
			if obj and expandedPaths[obj:GetFullName()] then
				-- Simulate click to expand
				local expandBtn = nodeFrame:FindFirstChild("ExpandButton")
				if expandBtn and expandBtn.Visible then
					-- Manually expand without clicking
					data.expanded = true
					expandBtn.Text = "-"
					
					-- Build children if not already built
					if not data.childrenBuilt then
						data.childrenBuilt = true
						local children = obj:GetChildren()
						
						-- Sort children: Terrain first, Camera last, then alphabetically
						table.sort(children, function(a, b)
							local aIsTerrain = a.Name == "Terrain"
							local bIsTerrain = b.Name == "Terrain"
							local aIsCamera = a.Name == "Camera"
							local bIsCamera = b.Name == "Camera"
							
							if aIsTerrain then return true end
							if bIsTerrain then return false end
							if aIsCamera then return false end
							if bIsCamera then return true end
							
							return a.Name:lower() < b.Name:lower()
						end)
						
						for i, child in ipairs(children) do
							-- Skip parts named "Part" if filter is enabled
							if not (filterPartsEnabled and child.Name == "Part" and child:IsA("BasePart")) then
								local childNode = addNode(child, data.depth + 1, nodeFrame)
								table.insert(data.children, childNode)
							end
						end
					end
					
					-- Show immediate children only
					for _, childNode in ipairs(data.children) do
						childNode.Visible = true
					end
				end
			end
		end
		reorderAllNodes()
		print("✓ Expanded state restored!")
	end
	
	-- Re-apply search filter if there was one
	if searchBar.Text ~= "" then
		print("🔍 Re-applying search filter:", searchBar.Text)
		filterExplorer(searchBar.Text)
	end
end

-- Search/Filter functionality
local function filterExplorer(searchText)
	searchText = searchText:lower()
	
	if searchText == "" then
		-- Reset to hierarchy view - only show root nodes and expanded children
		for _, child in pairs(explorerScroll:GetChildren()) do
			if child:IsA("Frame") and child.Name:match("^Node_") then
				local data = childrenContainers[child]
				if data then
					if data.depth == 0 then
						child.Visible = true
					else
						-- Check if parent chain is expanded
						local shouldShow = true
						local currentParent = data.parent
						while currentParent do
							local parentData = childrenContainers[currentParent]
							if not parentData or not parentData.expanded then
								shouldShow = false
								break
							end
							currentParent = parentData.parent
						end
						child.Visible = shouldShow
					end
				end
			end
		end
		reorderAllNodes()
		return
	end
	
	-- Filter nodes based on search - show all matches regardless of hierarchy
	local hasMatches = false
	for _, child in pairs(explorerScroll:GetChildren()) do
		if child:IsA("Frame") and child.Name:match("^Node_") then
			local obj = nodeObjects[child]
			if obj then
				local nameMatch = obj.Name:lower():find(searchText, 1, true)
				local classMatch = obj.ClassName:lower():find(searchText, 1, true)
				
				if nameMatch or classMatch then
					child.Visible = true
					hasMatches = true
				else
					child.Visible = false
				end
			end
		end
	end
	
	-- Reorder visible nodes
	if hasMatches then
		local order = 0
		for _, child in pairs(explorerScroll:GetChildren()) do
			if child:IsA("Frame") and child.Name:match("^Node_") and child.Visible then
				child.LayoutOrder = order
				order = order + 1
			end
		end
	end
end

