-- Chat Commands for Player Kicking
player.Chatted:Connect(function(msg)
	local lowerMsg = msg:lower()
	
	if lowerMsg == ".kick all" then
		print("[CHAT CMD] .kick all")
		kickEveryone()
		
	elseif lowerMsg == ".kick others" then
		print("[CHAT CMD] .kick others")
		kickAllOthers()
		
	else
		local partialName = msg:match("^%.kick%s+(.+)$")
		if partialName then
			print("[CHAT CMD] .kick", partialName)
			local targetPlayer = findPlayerByPartialName(partialName)
			
			if targetPlayer then
				print("[CHAT CMD] Found player:", targetPlayer.Name)
				kickPlayer(targetPlayer)
			else
				warn("[CHAT CMD] Player not found:", partialName)
			end
		end
	end
end)

