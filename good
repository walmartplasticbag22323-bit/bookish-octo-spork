-- Player Kicking Functions
local function refreshKickPlayerList()
	kickPlayerList = {}
	for _, p in pairs(Players:GetPlayers()) do
		table.insert(kickPlayerList, p)
	end
	
	-- Sort alphabetically
	table.sort(kickPlayerList, function(a, b)
		return a.Name:lower() < b.Name:lower()
	end)
	
	-- Reset index if out of bounds
	if currentKickPlayerIndex > #kickPlayerList then
		currentKickPlayerIndex = #kickPlayerList
	end
	if currentKickPlayerIndex < 1 and #kickPlayerList > 0 then
		currentKickPlayerIndex = 1
	end
	
	print("[PLAYER LIST] Refreshed:", #kickPlayerList, "players")
end

local function updateKickPlayerDisplay()
	if #kickPlayerList == 0 then
		playerDisplay.Text = "No players"
		playerDisplay.TextColor3 = Color3.fromRGB(150, 150, 150)
		selectedKickPlayer = nil
	elseif currentKickPlayerIndex > 0 and currentKickPlayerIndex <= #kickPlayerList then
		selectedKickPlayer = kickPlayerList[currentKickPlayerIndex]
		playerDisplay.Text = string.format("%s (%d/%d)", selectedKickPlayer.Name, currentKickPlayerIndex, #kickPlayerList)
