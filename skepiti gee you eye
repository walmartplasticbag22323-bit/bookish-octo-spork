-- Variables
local selectedPlayer = nil
local currentPlayerIndex = 0
local playerList = {}
local selectedMode = 7

-- Functions
local function updatePlayerDisplay()
    if #playerList == 0 then
        PlayerDisplay.Text = "No players available"
        selectedPlayer = nil
        currentPlayerIndex = 0
        return
    end
    
    if currentPlayerIndex < 1 then
        currentPlayerIndex = #playerList
    elseif currentPlayerIndex > #playerList then
        currentPlayerIndex = 1
    end
    
    selectedPlayer = playerList[currentPlayerIndex]
    if selectedPlayer then
        PlayerDisplay.Text = selectedPlayer.Name
    end
end

local function refreshPlayerList()
    playerList = {}
    
    -- Add all players except local player
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            table.insert(playerList, player)
        end
    end
    
    -- Sort alphabetically
    table.sort(playerList, function(a, b)
        return a.Name < b.Name
    end)
    
    -- Update display
    if currentPlayerIndex == 0 and #playerList > 0 then
        currentPlayerIndex = 1
    elseif currentPlayerIndex > #playerList then
        currentPlayerIndex = #playerList
    end
    
    updatePlayerDisplay()
end

local function updateModeDisplay()
    ModeDisplay.Text = "Mode: " .. selectedMode
end

local function executeVote(targetPlayer)
    local success, err = pcall(function()
        ReplicatedStorage.RemoteEvents.VoteEnd:FireServer(table.unpack({
            [1] = targetPlayer.Name,
            [2] = "eEQ8T6kChodgkk8kVMJKeLg6QHEkSMBpxmckdk4pfb2Q7uKxnU4JCQ8",
            [3] = selectedMode,
            [4] = 0,
        }))
    end)
    
    if success then
        print("✓ Vote executed for: " .. targetPlayer.Name .. " (Mode " .. selectedMode .. ")")
    else
        warn("✗ Failed to execute vote for " .. targetPlayer.Name .. ": " .. tostring(err))
    end
end

local function executeAllVotes()
    local count = 0
    for _, player in pairs(playerList) do
        executeVote(player)
        count = count + 1
        task.wait(0.1) -- Small delay between votes
    end
    print("✓ Executed votes for " .. count .. " players (Mode " .. selectedMode .. ")")
end

