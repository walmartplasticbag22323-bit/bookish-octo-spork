end)

Players.PlayerRemoving:Connect(function(player)
    if selectedPlayer == player then
        -- Move to next player if current one leaves
        currentPlayerIndex = currentPlayerIndex + 1
    end
    task.wait(0.5)
    refreshPlayerList()
end)

