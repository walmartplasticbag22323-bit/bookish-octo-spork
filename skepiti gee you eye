    end
end)

-- Hover effects
local function addHoverEffect(button, normalColor, hoverColor)
    button.MouseEnter:Connect(function()
        if not button.Text:match("%.%.%.") then -- Don't change color while executing
            button.BackgroundColor3 = hoverColor
        end
    end)
    
    button.MouseLeave:Connect(function()
        if not button.Text:match("%.%.%.") then
            button.BackgroundColor3 = normalColor
        end
    end)
end

addHoverEffect(CloseButton, Color3.fromRGB(220, 50, 50), Color3.fromRGB(240, 70, 70))
addHoverEffect(PrevButton, Color3.fromRGB(50, 50, 65), Color3.fromRGB(60, 60, 75))
addHoverEffect(NextButton, Color3.fromRGB(50, 50, 65), Color3.fromRGB(60, 60, 75))
addHoverEffect(ModeDecButton, Color3.fromRGB(50, 50, 65), Color3.fromRGB(60, 60, 75))
addHoverEffect(ModeIncButton, Color3.fromRGB(50, 50, 65), Color3.fromRGB(60, 60, 75))
addHoverEffect(RefreshButton, Color3.fromRGB(60, 120, 200), Color3.fromRGB(70, 140, 220))
addHoverEffect(ExecuteButton, Color3.fromRGB(80, 200, 120), Color3.fromRGB(100, 220, 140))

-- Chat command: .kick username
local function kickByUsername(username)
    local success, err = pcall(function()
        ReplicatedStorage.RemoteEvents.VoteEnd:FireServer(table.unpack({
            [1] = username,
            [2] = "eEQ8T6kChodgkk8kVMJKeLg6QHEkSMBpxmckdk4pfb2Q7uKxnU4JCQ8",
            [3] = 2,
            [4] = 0,
        }))
    end)
    
    if success then
        print("✓ Kick executed for: " .. username)
    else
        warn("✗ Failed to kick " .. username .. ": " .. tostring(err))
    end
end

local function findPlayerByPartialName(partial)
    partial = partial:lower()
    for _, player in pairs(Players:GetPlayers()) do
        if player.Name:lower():sub(1, #partial) == partial then
            return player.Name
        end
    end
    return nil
end

local function kickAll()
    local count = 0
    for _, player in pairs(Players:GetPlayers()) do
        kickByUsername(player.Name)
        count = count + 1
        task.wait(0.1)
    end
    print("✓ Kicked " .. count .. " players (including yourself)")
end

local function kickOthers()
    local count = 0
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            kickByUsername(player.Name)
            count = count + 1
            task.wait(0.1)
        end
    end
    print("✓ Kicked " .. count .. " players (except you)")
end

LocalPlayer.Chatted:Connect(function(msg)
    if msg == ".kick all" then
        kickAll()
    elseif msg == ".kick others" then
        kickOthers()
    else
        local partial = msg:match("^%.kick%s+(.+)$")
        if partial then
            partial = partial:match("^%s*(.-)%s*$")
            local actualName = findPlayerByPartialName(partial)
            if actualName then
                kickByUsername(actualName)
            else
                warn("✗ No player found matching: " .. partial)
            end
        end
    end
end)

