Plugin.Commands["bring"] = {
	["ListName"] = "bring / tp",
	["Description"] = "Teleport player to you",
	["Aliases"] = {"tp"},
	["Function"] = function(args, speaker)
		if #args < 1 then
			notify("Usage: ;bring [player]")
			return
		end
		
		local serverEndpoint = getF3XTool()
		if not serverEndpoint then return end
		
		if not speaker.Character or not speaker.Character:FindFirstChild("HumanoidRootPart") then
			notify("You need a character!")
			return
		end
		
		local myPos = speaker.Character.HumanoidRootPart.CFrame
		local players = getPlayer(args[1], speaker)
		
		for _, plr in ipairs(players) do
			if not plr.Character or not plr.Character:FindFirstChild("HumanoidRootPart") then continue end
			
			local parts = getPlayerParts(plr)
			if #parts == 0 then continue end
			
			local hrp = plr.Character.HumanoidRootPart
			
			-- Claim ownership using group/ungroup (REQUIRED for move!)
			for _, part in ipairs(parts) do
				task.spawn(function()
					pcall(function()
						serverEndpoint:InvokeServer("CreateGroup", "Model", workspace, {part})
					end)
				end)
			end
			
			task.wait(0.05)
			
			for _, part in ipairs(parts) do
				task.spawn(function()
					pcall(function()
						serverEndpoint:InvokeServer("Ungroup", {part})
					end)
				end)
			end
			
			task.wait(0.1)
			
			-- Bring ALL parts in PARALLEL with task.spawn
			for _, part in ipairs(parts) do
				task.spawn(function()
					pcall(function()
						local relativePos = hrp.CFrame:ToObjectSpace(part.CFrame)
						local newCFrame = (myPos * CFrame.new(0, 0, -5)) * relativePos
						serverEndpoint:InvokeServer("SyncMove", {{Part = part, CFrame = newCFrame}})
					end)
				end)
			end
			
			notify("Brought " .. plr.Name)
		end
	end,
}

Plugin.Commands["bringbuild"] = {
	["ListName"] = "bringbuild / bringb",
	["Description"] = "Bring player's build to you",
	["Aliases"] = {"bringb"},
	["Function"] = function(args, speaker)
		if #args < 1 then
			notify("Usage: ;bringbuild [playername]")
			return
		end
		
		local serverEndpoint = getF3XTool()
		if not serverEndpoint then return end
		
		if not speaker.Character or not speaker.Character:FindFirstChild("HumanoidRootPart") then
			notify("You need a character!")
			return
		end
		
		local targetName = table.concat(args, " ")
		notify("Scanning for parts...")
		
		local parts = getBuildParts(targetName)
		
		if #parts == 0 then
			notify("No parts found")
			return
		end
		
		notify("Bringing " .. #parts .. " parts...")
		
		-- Claim ownership using group/ungroup (REQUIRED for move!)
		for _, part in ipairs(parts) do
			task.spawn(function()
				pcall(function()
					serverEndpoint:InvokeServer("CreateGroup", "Model", workspace, {part})
				end)
			end)
		end
		
		task.wait(0.05)
		
		for _, part in ipairs(parts) do
			task.spawn(function()
				pcall(function()
					serverEndpoint:InvokeServer("Ungroup", {part})
				end)
			end)
		end
		
		task.wait(0.1)
		
		local myPos = speaker.Character.HumanoidRootPart.Position
		local stackHeight = 0
		
		-- Bring ALL parts in PARALLEL with task.spawn
		for _, part in ipairs(parts) do
			task.spawn(function()
				pcall(function()
					local newCFrame = CFrame.new(myPos + Vector3.new(0, 10 + stackHeight, 0))
					serverEndpoint:InvokeServer("SyncMove", {{Part = part, CFrame = newCFrame}})
				end)
			end)
			
			stackHeight = stackHeight + 0.5
		end
		
		notify("Done!")
	end,
}

Plugin.Commands["fling"] = {
	["ListName"] = "fling / fl",
	["Description"] = "Fling a player",
	["Aliases"] = {"fl"},
	["Function"] = function(args, speaker)
		if #args < 1 then
			notify("Usage: ;fling [player]")
			return
		end
		
		local serverEndpoint = getF3XTool()
		if not serverEndpoint then return end
		
		local players = getPlayer(args[1], speaker)
		
		for _, plr in ipairs(players) do
			local parts = getPlayerParts(plr)
			if #parts == 0 then continue end
			
			-- Claim ownership using group/ungroup
			for _, part in ipairs(parts) do
				task.spawn(function()
					pcall(function()
						serverEndpoint:InvokeServer("CreateGroup", "Model", workspace, {part})
					end)
				end)
			end
			
			task.wait(0.05)
			
			for _, part in ipairs(parts) do
				task.spawn(function()
					pcall(function()
						serverEndpoint:InvokeServer("Ungroup", {part})
					end)
				end)
			end
			
			task.wait(0.1)
			
			-- Unanchor first
			for _, part in ipairs(parts) do
				task.spawn(function()
					pcall(function()
						serverEndpoint:InvokeServer("SyncAnchor", {{Part = part, Anchored = false}})
					end)
				end)
			end
			
			task.wait(0.1)
			
			-- Then fling
			for _, part in ipairs(parts) do
				task.spawn(function()
					pcall(function()
						local randomVec = Vector3.new(
							math.random(-100, 100),
							math.random(50, 150),
							math.random(-100, 100)
						)
						serverEndpoint:InvokeServer("SyncMove", {{Part = part, CFrame = part.CFrame + randomVec}})
					end)
				end)
			end
			
			notify("Flung " .. plr.Name)
		end
	end,
}

Plugin.Commands["spin"] = {
	["ListName"] = "spin",
	["Description"] = "Spin a player",
	["Aliases"] = {},
	["Function"] = function(args, speaker)
		if #args < 1 then
			notify("Usage: ;spin [player]")
			return
		end
		
		local serverEndpoint = getF3XTool()
		if not serverEndpoint then return end
		
		local players = getPlayer(args[1], speaker)
		
		for _, plr in ipairs(players) do
			if not plr.Character or not plr.Character:FindFirstChild("HumanoidRootPart") then continue end
			
			local parts = getPlayerParts(plr)
			if #parts == 0 then continue end
			
			-- Claim ownership using group/ungroup
			for _, part in ipairs(parts) do
				task.spawn(function()
					pcall(function()
						serverEndpoint:InvokeServer("CreateGroup", "Model", workspace, {part})
					end)
				end)
			end
			
			task.wait(0.05)
			
			for _, part in ipairs(parts) do
				task.spawn(function()
					pcall(function()
						serverEndpoint:InvokeServer("Ungroup", {part})
					end)
				end)
			end
			
			task.wait(0.1)
			
			notify("Spinning " .. plr.Name)
			
			task.spawn(function()
				for i = 1, 50 do
					local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
					if not hrp then break end
					
					for _, part in ipairs(parts) do
						pcall(function()
							local relativePos = hrp.CFrame:ToObjectSpace(part.CFrame)
							local newCFrame = (hrp.CFrame * CFrame.Angles(0, math.rad(36), 0)) * relativePos
							serverEndpoint:InvokeServer("SyncMove", {{Part = part, CFrame = newCFrame}})
						end)
					end
					
					task.wait(0.05)
				end
			end)
		end
	end,
}

Plugin.Commands["explode"] = {
	["ListName"] = "explode / boom",
	["Description"] = "Explode a player",
	["Aliases"] = {"boom"},
	["Function"] = function(args, speaker)
		if #args < 1 then
			notify("Usage: ;explode [player]")
			return
		end
		
		local serverEndpoint = getF3XTool()
		if not serverEndpoint then return end
		
		local players = getPlayer(args[1], speaker)
		
		for _, plr in ipairs(players) do
			if not plr.Character or not plr.Character:FindFirstChild("HumanoidRootPart") then continue end
			
			local parts = getPlayerParts(plr)
			if #parts == 0 then continue end
			
			local center = plr.Character.HumanoidRootPart.Position
			
			-- Step 1: Group all parts in parallel (claim ownership)
			for _, part in ipairs(parts) do
				task.spawn(function()
					pcall(function()
						serverEndpoint:InvokeServer("CreateGroup", "Model", workspace, {part})
					end)
				end)
				task.wait(0.0001)
			end
			task.wait(0.1)
			
			-- Step 2: Ungroup all parts in parallel
			for _, part in ipairs(parts) do
				task.spawn(function()
					pcall(function()
						serverEndpoint:InvokeServer("Ungroup", {part})
					end)
				end)
				task.wait(0.0001)
			end
			task.wait(0.15)
			
			-- Step 3: Unanchor all parts in parallel
			for _, part in ipairs(parts) do
				task.spawn(function()
					pcall(function()
						serverEndpoint:InvokeServer("SyncAnchor", {{Part = part, Anchored = false}})
					end)
				end)
				task.wait(0.0001)
			end
			task.wait(0.1)
			
			-- Step 4: Scatter parts in random directions
			for _, part in ipairs(parts) do
				task.spawn(function()
					pcall(function()
						local direction = (part.Position - center).Unit
						local distance = math.random(20, 50)
						serverEndpoint:InvokeServer("SyncMove", {{Part = part, CFrame = CFrame.new(center + direction * distance)}})
					end)
				end)
				task.wait(0.0001)
			end
			
			notify("Exploded " .. plr.Name)
		end
	end,
}

Plugin.Commands["shrink"] = {
	["ListName"] = "shrink / tiny",
	["Description"] = "Shrink a player",
	["Aliases"] = {"tiny"},
	["Function"] = function(args, speaker)
		if #args < 1 then
			notify("Usage: ;shrink [player]")
			return
		end
		
		local serverEndpoint = getF3XTool()
		if not serverEndpoint then return end
		
		local players = getPlayer(args[1], speaker)
		
		for _, plr in ipairs(players) do
			if not plr.Character then continue end
			
			local parts = getPlayerParts(plr)
			if #parts == 0 then continue end
			
			-- Claim ownership using group/ungroup (REQUIRED for resize!)
			for _, part in ipairs(parts) do
				task.spawn(function()
					pcall(function()
						serverEndpoint:InvokeServer("CreateGroup", "Model", workspace, {part})
					end)
				end)
			end
			
			task.wait(0.05)
			
			for _, part in ipairs(parts) do
				task.spawn(function()
					pcall(function()
						serverEndpoint:InvokeServer("Ungroup", {part})
					end)
				end)
			end
			
			task.wait(0.1)
			
			-- Now resize in parallel
			for _, part in ipairs(parts) do
				task.spawn(function()
					pcall(function()
						serverEndpoint:InvokeServer("SyncResize", {{Part = part, Size = part.Size * 0.1, CFrame = part.CFrame}})
					end)
				end)
			end
			
			notify("Shrunk " .. plr.Name)
		end
	end,
}

Plugin.Commands["giant"] = {
	["ListName"] = "giant / grow",
	["Description"] = "Make player giant",
	["Aliases"] = {"grow"},
	["Function"] = function(args, speaker)
		if #args < 1 then
			notify("Usage: ;giant [player]")
			return
		end
		
		local serverEndpoint = getF3XTool()
		if not serverEndpoint then return end
		
		local players = getPlayer(args[1], speaker)
		
		for _, plr in ipairs(players) do
			if not plr.Character then continue end
			
			local parts = getPlayerParts(plr)
			if #parts == 0 then continue end
			
			-- Claim ownership using group/ungroup (REQUIRED for resize!)
			for _, part in ipairs(parts) do
				task.spawn(function()
					pcall(function()
						serverEndpoint:InvokeServer("CreateGroup", "Model", workspace, {part})
					end)
				end)
			end
			
			task.wait(0.05)
			
			for _, part in ipairs(parts) do
				task.spawn(function()
					pcall(function()
						serverEndpoint:InvokeServer("Ungroup", {part})
					end)
				end)
			end
			
			task.wait(0.1)
			
			-- Now resize in parallel
			for _, part in ipairs(parts) do
				task.spawn(function()
					pcall(function()
						serverEndpoint:InvokeServer("SyncResize", {{Part = part, Size = part.Size * 3, CFrame = part.CFrame}})
					end)
				end)
			end
			
			notify("Made " .. plr.Name .. " giant")
		end
	end,
}

return Plugin
