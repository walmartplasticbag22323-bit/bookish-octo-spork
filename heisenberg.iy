Plugin.Commands["colorplayer"] = {
	["ListName"] = "colorplayer / colorply / rgb",
	["Description"] = "Change player color (RGB 0-255)",
	["Aliases"] = {"colorply", "rgb"},
	["Function"] = function(args, speaker)
		if #args < 4 then
			notify("Usage: ;colorplayer [player] [r] [g] [b]")
			return
		end
		
		local serverEndpoint = getF3XTool()
		if not serverEndpoint then return end
		
		local players = getPlayer(args[1], speaker)
		local r = math.clamp(tonumber(args[2]) or 255, 0, 255) / 255
		local g = math.clamp(tonumber(args[3]) or 255, 0, 255) / 255
		local b = math.clamp(tonumber(args[4]) or 255, 0, 255) / 255
		
		local color = Color3.new(r, g, b)
		
		for _, plr in ipairs(players) do
			local parts = getPlayerParts(plr)
			if #parts == 0 then continue end
			
			claimOwnershipFast(parts)
			
			for _, part in ipairs(parts) do
				task.spawn(function()
					pcall(function()
						serverEndpoint:InvokeServer("SyncColor", {{Part = part, Color = color}})
					end)
				end)
			end
			
			notify("Colored " .. plr.Name)
		end
	end,
}

Plugin.Commands["removelimb"] = {
	["ListName"] = "removelimb / remlimb",
	["Description"] = "Remove limb (head/torso/arms/legs)",
	["Aliases"] = {"remlimb"},
	["Function"] = function(args, speaker)
		if #args < 2 then
			notify("Usage: ;removelimb [player] [head/torso/arms/legs]")
			return
		end
		
		local serverEndpoint = getF3XTool()
		if not serverEndpoint then return end
		
		local players = getPlayer(args[1], speaker)
		local limb = args[2]:lower()
		
		local limbMap = {
			["head"] = {"Head"},
			["torso"] = {"UpperTorso", "LowerTorso"},
			["arms"] = {"LeftUpperArm", "RightUpperArm", "LeftLowerArm", "RightLowerArm", "LeftHand", "RightHand"},
			["legs"] = {"LeftUpperLeg", "RightUpperLeg", "LeftLowerLeg", "RightLowerLeg", "LeftFoot", "RightFoot"},
		}
		
		local limbNames = limbMap[limb]
		if not limbNames then
			notify("Invalid limb!")
			return
		end
		
		for _, plr in ipairs(players) do
			if not plr.Character then continue end
			
			local partsToRemove = {}
			for _, limbName in ipairs(limbNames) do
				local part = plr.Character:FindFirstChild(limbName)
				if part and part:IsA("BasePart") then
					table.insert(partsToRemove, part)
				end
			end
			
			if #partsToRemove == 0 then continue end
			
			claimOwnershipFast(partsToRemove)
			
			for _, part in ipairs(partsToRemove) do
				task.spawn(function()
					pcall(function()
						serverEndpoint:InvokeServer("Remove", {part})
					end)
				end)
			end
			
			notify("Removed " .. limb .. " from " .. plr.Name)
		end
	end,
}

