-- OPTIMIZED Raid Roleplay F3X Plugin for Infinite Yield
-- Ultra-fast scanning with GetChildren() instead of GetDescendants()
-- Created by motorolav99

local Plugin = {
	["PluginName"] = "RR F3X Tools (Optimized)",
	["PluginDescription"] = "Fast F3X Building Tools exploitation",
	["Commands"] = {},
}

-- Utility Functions
local function notify(message)
	game:GetService("StarterGui"):SetCore("SendNotification", {
		Title = "F3X Tools",
		Text = message,
		Duration = 3,
	})
end

local function getF3XTool()
	local player = game:GetService("Players").LocalPlayer
	
	local tool = player.Backpack:FindFirstChild("Building Tools") 
		or player.Backpack:FindFirstChild("Building Tools Plus")
		or (player.Character and player.Character:FindFirstChild("Building Tools"))
		or (player.Character and player.Character:FindFirstChild("Building Tools Plus"))
	
	if not tool then
		notify("F3X Building Tools not found!")
		return nil
	end
	
	local syncAPI = tool:FindFirstChild("SyncAPI")
	if not syncAPI then
		notify("SyncAPI not found!")
		return nil
	end
	
	local serverEndpoint = syncAPI:FindFirstChild("ServerEndpoint")
	if not serverEndpoint then
		notify("ServerEndpoint not found!")
		return nil
	end
	
	return serverEndpoint
end

local function claimOwnershipFast(parts)
	-- Use EscalateEvent for INSTANT ownership claim (like TornadoWand!)
	local RS = game:GetService("ReplicatedStorage")
	pcall(function()
		local EscalateEvent = RS.raidRoleplay.Events.EscalateEvent
		local PartOwnership = RS.raidRoleplay.Modules.PartOwnership
		EscalateEvent:FireServer(PartOwnership, parts)
	end)
	task.wait(0.15)
end

local function getPlayerParts(player)
	if not player.Character then return {} end
	
	local parts = {}
	for _, descendant in ipairs(player.Character:GetDescendants()) do
		if descendant:IsA("BasePart") then
			table.insert(parts, descendant)
		end
	end
	return parts
end

-- OPTIMIZED: Use GetChildren() recursively instead of GetDescendants()
local function getBuildParts(ownerName)
	local parts = {}
	local lowerName = ownerName:lower()
	
	local function scanFolder(folder)
		for _, obj in ipairs(folder:GetChildren()) do
			if obj:IsA("BasePart") then
				local owner = obj:FindFirstChild("RRPartOwner")
				if owner and owner:IsA("StringValue") and owner.Value:lower():find(lowerName) then
					table.insert(parts, obj)
				end
			elseif obj:IsA("Model") or obj:IsA("Folder") then
				scanFolder(obj)
			end
		end
	end
	
	scanFolder(workspace)
	return parts
end

-- ========================================
-- COMMANDS
-- ========================================

-- List all commands
Plugin.Commands["cmds"] = {
	["ListName"] = "cmds / f3xcmds",
	["Description"] = "List all F3X plugin commands",
	["Aliases"] = {"f3xcmds"},
	["Function"] = function(args, speaker)
		print("========================================")
		print("F3X PLUGIN COMMANDS:")
		print("========================================")
		
		local commandList = {
			";deletebuild [name] - Delete all parts owned by player",
			";freeze [player] - Anchor all body parts",
			";unfreeze [player] - Unanchor all body parts",
			";invisible [player] - Make player invisible",
			";visible [player] - Make player visible",
			";neon [player] - Change material to Neon",
			";colorplayer [player] [r] [g] [b] - RGB color (0-255)",
			";removelimb [player] [limb] - Remove limb (head/torso/leftarm/rightarm/leftleg/rightleg)",
			";lockplayer [player] - Lock parts",
			";unlockplayer [player] - Unlock parts",
			";bring [player] - Teleport player to you",
			";bringbuild [name] - Bring all owned parts to you",
			";fling [player] - Launch player",
			";spin [player] - Rotate player 50 times",
			";explode [player] - Scatter body parts",
			";shrink [player] - Scale down to 10%",
			";giant [player] - Scale up 3x",
		}
		
		for _, cmd in ipairs(commandList) do
			print(cmd)
		end
		
		print("========================================")
		notify("Commands printed to console (F9)")
	end,
}

Plugin.Commands["deletebuild"] = {
	["ListName"] = "deletebuild / delbuild",
	["Description"] = "Delete all parts owned by a player",
	["Aliases"] = {"delbuild"},
	["Function"] = function(args, speaker)
		if #args < 1 then
			notify("Usage: ;deletebuild [playername]")
			return
		end
		
		local serverEndpoint = getF3XTool()
		if not serverEndpoint then return end
		
		local targetName = table.concat(args, " ")
		notify("Scanning for parts...")
		
		local parts = getBuildParts(targetName)
		
		if #parts == 0 then
			notify("No parts found owned by " .. targetName)
			return
		end
		
		notify("Deleting " .. #parts .. " parts...")
		
		-- Claim ownership using EscalateEvent (INSTANT like TornadoWand!)
		local RS = game:GetService("ReplicatedStorage")
		pcall(function()
			local EscalateEvent = RS.raidRoleplay.Events.EscalateEvent
			local PartOwnership = RS.raidRoleplay.Modules.PartOwnership
			EscalateEvent:FireServer(PartOwnership, parts)
		end)
		
		task.wait(0.15)
		
		-- Delete ALL parts in PARALLEL (like TornadoWand.lua!)
		local deletedCount = 0
		for _, part in ipairs(parts) do
			if part and part.Parent then
				task.spawn(function()
					local success = pcall(function()
						-- Step 1: Group the part
						serverEndpoint:InvokeServer("CreateGroup", "Model", workspace, {part})
						task.wait(0.01)
						
						-- Step 2: Ungroup it (claims ownership)
						serverEndpoint:InvokeServer("Ungroup", {part})
						task.wait(0.01)
						
						-- Step 3: Remove the part
						if part and part.Parent then
							serverEndpoint:InvokeServer("Remove", {part})
							deletedCount = deletedCount + 1
						end
					end)
					
					if not success then
						-- Fallback: Try direct remove
						pcall(function()
							serverEndpoint:InvokeServer("Remove", {part})
							deletedCount = deletedCount + 1
						end)
					end
				end)
				
				task.wait(0.0001) -- Don't delay the sending process
			end
		end
		
		-- Wait for all spawned tasks to complete
		task.wait(0.3)
		notify("Deleted " .. deletedCount .. " / " .. #parts .. " parts!")
	end,
}

Plugin.Commands["freeze"] = {
	["ListName"] = "freeze / anchor",
	["Description"] = "Freeze a player",
	["Aliases"] = {"anchor"},
	["Function"] = function(args, speaker)
		if #args < 1 then
			notify("Usage: ;freeze [player]")
			return
		end
		
		local serverEndpoint = getF3XTool()
		if not serverEndpoint then return end
		
		local players = getPlayer(args[1], speaker)
		
		for _, plr in ipairs(players) do
			local parts = getPlayerParts(plr)
			if #parts == 0 then continue end
			
			claimOwnershipFast(parts)
			
			-- Anchor ALL parts in PARALLEL
			for _, part in ipairs(parts) do
				task.spawn(function()
					pcall(function()
						serverEndpoint:InvokeServer("SyncAnchor", {{Part = part, Anchored = true}})
					end)
				end)
			end
			
			notify("Froze " .. plr.Name)
		end
	end,
}

