-- Get F3X endpoints
local function getEndpoints()
    local bt = workspace:FindFirstChild(player.Name) and workspace[player.Name]:FindFirstChild("Building Tools")
    if not bt then
        local tool = backpack:FindFirstChild("Building Tools")
        if tool and character then
            character:WaitForChild("Humanoid"):EquipTool(tool)
            task.wait(0.1)
            bt = workspace:FindFirstChild(player.Name) and workspace[player.Name]:FindFirstChild("Building Tools")
        end
    end
    
    if not bt then
        warn("Building Tools not found!")
        return nil, nil
    end
    
    return bt.SyncAPI.ServerEndpoint, bt.SyncAPI
end

