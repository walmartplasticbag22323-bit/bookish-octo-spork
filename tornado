	end)
	
	buildButton.MouseButton1Click:Connect(function()
		local fontPath = fontPathBox.Text
		local text = textBox.Text
		local scale = tonumber(scaleSlider.Text) or 1.5
		local thickness = tonumber(thicknessBox.Text) or 0.2
		local spacing = tonumber(spacingBox.Text) or 0.8
		local distance = tonumber(distanceBox.Text) or 15
		
		-- Check if file exists first
		if not isfile(fontPath) then
			warn("Font file not found: " .. fontPath)
			warn("Please place your TTF file in the FontProcessor folder in your executor workspace")
			return
		end
		
		local success, fontData = pcall(function()
			return readfile(fontPath)
		end)
		
		if not success then
			warn("Failed to read font file: " .. fontPath)
			warn("Error: " .. tostring(fontData))
			return
		end
		
		local parser = TTFParser.new(fontData)
		
		local camera = workspace.CurrentCamera
		local startPos = camera.CFrame.Position + camera.CFrame.LookVector * distance
		
		-- Get font metrics for proper scaling
		local head = parser:parseHead()
		local unitsPerEm = head and head.unitsPerEm or 2048
		
		-- Collect ALL glyphs and positions first
		local allPartData = {}
		local xOffset = 0
		
		for i = 1, #text do
			local char = text:sub(i, i)
			local glyph = parser:getGlyphContours(char)
			
			if glyph then
				local normalized = normalizeGlyph(glyph, 16)
				
				if normalized then
					local charPos = Vector3.new(
						startPos.X + xOffset,
						startPos.Y,
						startPos.Z
					)
					
					-- Calculate scale factor that preserves aspect ratio
					-- Scale is based on font units, maintaining proper proportions
					local fontScale = scale / unitsPerEm
					
					for _, contour in ipairs(normalized.contours) do
						for j = 1, #contour - 1 do
							local p1 = contour[j]
							local p2 = contour[j + 1]
							
							-- Use actual font coordinates (no normalization to 0-1)
							-- This preserves the aspect ratio and size relationships
							local x1 = p1.x * fontScale
							local y1 = p1.y * fontScale
							local x2 = p2.x * fontScale
							local y2 = p2.y * fontScale
							
							local midX = (x1 + x2) / 2
							local midY = (y1 + y2) / 2
							
							local length = math.sqrt((x2 - x1)^2 + (y2 - y1)^2)
							local angle = math.atan2(y2 - y1, x2 - x1)
							
							local cf = CFrame.new(
								charPos.X + midX,
								charPos.Y + midY,
								charPos.Z
							) * CFrame.Angles(0, 0, angle)
							
							table.insert(allPartData, {
								cf = cf,
								length = length,
								size = Vector3.new(length, thickness, thickness)
							})
						end
					end
					
					-- Letter spacing based on actual glyph width
					xOffset = xOffset + (normalized.width * fontScale) + spacing
				end
			end
		end
		
		-- Now create ALL parts in parallel
		local endpoint = getF3XEndpoint()
		if not endpoint then
			warn("F3X not found!")
			return
		end
		
		local parts = {}
		local threads = {}
		
		for i, data in ipairs(allPartData) do
			threads[i] = task.spawn(function()
				local success, part = pcall(function()
					return endpoint:InvokeServer("CreatePart", "Normal", data.cf, workspace)
				end)
				if success and part then
					parts[i] = part
				end
			end)
		end
		
		-- Wait for all parts to be created
		for _, thread in ipairs(threads) do
			while coroutine.status(thread) ~= "dead" do
				task.wait()
			end
		end
		
		-- Remove nil entries
		local cleanParts = {}
		for _, part in ipairs(parts) do
			if part then
				table.insert(cleanParts, part)
			end
		end
		parts = cleanParts
		
		if #parts > 0 then
			-- Claim ownership
			claimOwnership(parts)
			
			-- Batch resize
			local resizeBatch = {}
			for i, part in ipairs(parts) do
				if allPartData[i] then
					table.insert(resizeBatch, {
						Part = part,
						Size = allPartData[i].size,
						CFrame = allPartData[i].cf
					})
				end
			end
			endpoint:InvokeServer("SyncResize", resizeBatch)
			
			-- Batch color
			local colorBatch = {}
			for _, part in ipairs(parts) do
				table.insert(colorBatch, {
					Part = part,
					Color = Color3.new(0, 0, 0)
				})
			end
			endpoint:InvokeServer("SyncColor", colorBatch)
			
			-- Batch material
			local materialBatch = {}
			for _, part in ipairs(parts) do
				table.insert(materialBatch, {
					Part = part,
					Material = Enum.Material.SmoothPlastic
				})
			end
			endpoint:InvokeServer("SyncMaterial", materialBatch)
		end
	end)
	
	local dragging = false
	local dragInput, mousePos, framePos
	
	frame.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			mousePos = input.Position
			framePos = frame.Position
			
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)
	
	UIS.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement then
			dragInput = input
		end
	end)
	
	UIS.InputChanged:Connect(function(input)
		if input == dragInput and dragging then
			local delta = input.Position - mousePos
			frame.Position = UDim2.new(
				framePos.X.Scale,
				framePos.X.Offset + delta.X,
				framePos.Y.Scale,
				framePos.Y.Offset + delta.Y
			)
		end
	end)
end

