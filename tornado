-- ============================================================================
-- BINARY READER
-- ============================================================================

local BinaryReader = {}
BinaryReader.__index = BinaryReader

function BinaryReader.new(data)
	local self = setmetatable({}, BinaryReader)
	self.data = data
	self.pos = 1
	self.length = #data
	return self
end

function BinaryReader:seek(pos)
	self.pos = pos
end

function BinaryReader:tell()
	return self.pos
end

function BinaryReader:readBytes(n)
	if self.pos + n - 1 > self.length then
		error("Read beyond end of data")
	end
	local bytes = {}
	for i = 1, n do
		bytes[i] = string.byte(self.data, self.pos)
		self.pos = self.pos + 1
	end
	return bytes
end

function BinaryReader:readUInt8()
	return self:readBytes(1)[1]
end

function BinaryReader:readInt8()
	local val = self:readUInt8()
	return val >= 128 and (val - 256) or val
end

function BinaryReader:readUInt16()
	local b = self:readBytes(2)
	return b[1] * 256 + b[2]
end

function BinaryReader:readInt16()
	local val = self:readUInt16()
	return val >= 32768 and (val - 65536) or val
end

function BinaryReader:readUInt32()
	local b = self:readBytes(4)
	return b[1] * 16777216 + b[2] * 65536 + b[3] * 256 + b[4]
end

function BinaryReader:readInt32()
	local val = self:readUInt32()
	return val >= 2147483648 and (val - 4294967296) or val
end

function BinaryReader:readFixed()
	return self:readInt32() / 65536
end

function BinaryReader:readString(n)
	local bytes = self:readBytes(n)
	local str = ""
	for i = 1, n do
		str = str .. string.char(bytes[i])
	end
	return str
end

-- ============================================================================
-- TTF PARSER
-- ============================================================================

local TTFParser = {}
TTFParser.__index = TTFParser

function TTFParser.new(data)
	local self = setmetatable({}, TTFParser)
	self.reader = BinaryReader.new(data)
	self.tables = {}
	self:parseHeader()
	self:parseTableDirectory()
	return self
end

function TTFParser:parseHeader()
	local reader = self.reader
	reader:seek(1)
	
	self.version = reader:readUInt32()
	self.numTables = reader:readUInt16()
	self.searchRange = reader:readUInt16()
	self.entrySelector = reader:readUInt16()
	self.rangeShift = reader:readUInt16()
end

function TTFParser:parseTableDirectory()
	local reader = self.reader
	
	for i = 1, self.numTables do
		local tag = reader:readString(4)
		local checksum = reader:readUInt32()
		local offset = reader:readUInt32()
		local length = reader:readUInt32()
		
		self.tables[tag] = {
			offset = offset + 1,
			length = length,
			checksum = checksum
		}
	end
end

function TTFParser:getTable(tag)
	return self.tables[tag]
end

function TTFParser:parseHead()
	local headTable = self:getTable("head")
	if not headTable then return nil end
	
	local reader = self.reader
	reader:seek(headTable.offset)
	
	local head = {}
	head.version = reader:readFixed()
	head.fontRevision = reader:readFixed()
	head.checksumAdjustment = reader:readUInt32()
	head.magicNumber = reader:readUInt32()
	head.flags = reader:readUInt16()
	head.unitsPerEm = reader:readUInt16()
	
	reader:readBytes(16) -- skip dates
	
	head.xMin = reader:readInt16()
	head.yMin = reader:readInt16()
	head.xMax = reader:readInt16()
	head.yMax = reader:readInt16()
	head.macStyle = reader:readUInt16()
	head.lowestRecPPEM = reader:readUInt16()
	head.fontDirectionHint = reader:readInt16()
	head.indexToLocFormat = reader:readInt16()
	head.glyphDataFormat = reader:readInt16()
	
	return head
end

function TTFParser:parseMaxp()
	local maxpTable = self:getTable("maxp")
	if not maxpTable then return nil end
	
	local reader = self.reader
	reader:seek(maxpTable.offset)
	
	local maxp = {}
	maxp.version = reader:readFixed()
	maxp.numGlyphs = reader:readUInt16()
	
	return maxp
end

function TTFParser:parseLoca()
	local locaTable = self:getTable("loca")
	if not locaTable then return nil end
	
	local head = self:parseHead()
	local maxp = self:parseMaxp()
	if not head or not maxp then return nil end
	
	local reader = self.reader
	reader:seek(locaTable.offset)
	
	local loca = {}
	local format = head.indexToLocFormat
	
	for i = 0, maxp.numGlyphs do
		if format == 0 then
			loca[i] = reader:readUInt16() * 2
		else
			loca[i] = reader:readUInt32()
		end
	end
	
	return loca
end

function TTFParser:parseCmap()
	local cmapTable = self:getTable("cmap")
	if not cmapTable then return nil end
	
	local reader = self.reader
	reader:seek(cmapTable.offset)
	
	local version = reader:readUInt16()
	local numTables = reader:readUInt16()
	
	local bestTable = nil
	local bestScore = -1
	
	for i = 1, numTables do
		local platformID = reader:readUInt16()
		local encodingID = reader:readUInt16()
		local offset = reader:readUInt32()
		
		local score = 0
		if platformID == 3 and encodingID == 1 then
			score = 100
		elseif platformID == 0 and encodingID == 3 then
			score = 90
		elseif platformID == 3 and encodingID == 10 then
			score = 80
		end
		
		if score > bestScore then
			bestScore = score
			bestTable = {offset = cmapTable.offset + offset}
		end
	end
	
	if not bestTable then return nil end
	
	reader:seek(bestTable.offset)
	local format = reader:readUInt16()
	
	local cmap = {}
	
	if format == 4 then
		local length = reader:readUInt16()
		local language = reader:readUInt16()
		local segCountX2 = reader:readUInt16()
		local segCount = segCountX2 / 2
		local searchRange = reader:readUInt16()
		local entrySelector = reader:readUInt16()
		local rangeShift = reader:readUInt16()
		
		local endCode = {}
		for i = 1, segCount do
			endCode[i] = reader:readUInt16()
		end
		
		reader:readUInt16() -- reserved
		
		local startCode = {}
		for i = 1, segCount do
			startCode[i] = reader:readUInt16()
		end
		
		local idDelta = {}
		for i = 1, segCount do
			idDelta[i] = reader:readInt16()
		end
		
		local idRangeOffsetStart = reader:tell()
		local idRangeOffset = {}
		for i = 1, segCount do
			idRangeOffset[i] = reader:readUInt16()
		end
		
		for i = 1, segCount do
			local endChar = endCode[i]
			local startChar = startCode[i]
			
			if startChar ~= 65535 then
				for c = startChar, endChar do
					local glyphIndex
					
					if idRangeOffset[i] == 0 then
						glyphIndex = (c + idDelta[i]) % 65536
					else
						local offset = idRangeOffsetStart + (i - 1) * 2 + idRangeOffset[i] + (c - startChar) * 2
						reader:seek(offset)
						glyphIndex = reader:readUInt16()
						if glyphIndex ~= 0 then
							glyphIndex = (glyphIndex + idDelta[i]) % 65536
						end
					end
					
					if glyphIndex ~= 0 then
						cmap[c] = glyphIndex
					end
				end
			end
		end
	end
	
	return cmap
end

function TTFParser:parseGlyph(glyphIndex)
	local glyfTable = self:getTable("glyf")
	if not glyfTable then return nil end
	
	local loca = self:parseLoca()
	if not loca then return nil end
	
	local offset = loca[glyphIndex]
	local nextOffset = loca[glyphIndex + 1]
	
	if offset == nextOffset then
		return {contours = {}}
	end
	
	local reader = self.reader
	reader:seek(glyfTable.offset + offset)
	
	local glyph = {}
	glyph.numberOfContours = reader:readInt16()
	glyph.xMin = reader:readInt16()
	glyph.yMin = reader:readInt16()
	glyph.xMax = reader:readInt16()
	glyph.yMax = reader:readInt16()
	
	if glyph.numberOfContours < 0 then
		return {contours = {}}
	end
	
	local endPtsOfContours = {}
	for i = 1, glyph.numberOfContours do
		endPtsOfContours[i] = reader:readUInt16()
	end
	
	local instructionLength = reader:readUInt16()
	reader:readBytes(instructionLength)
	
	local numPoints = endPtsOfContours[glyph.numberOfContours] + 1
	
	local flags = {}
	local i = 0
	while i < numPoints do
		local flag = reader:readUInt8()
		flags[i] = flag
		i = i + 1
		
		if bit32.band(flag, 0x08) ~= 0 then
			local repeatCount = reader:readUInt8()
			for j = 1, repeatCount do
				flags[i] = flag
				i = i + 1
			end
		end
	end
	
	local xCoordinates = {}
	local x = 0
	for i = 0, numPoints - 1 do
		local flag = flags[i]
		local xShort = bit32.band(flag, 0x02) ~= 0
		local xSame = bit32.band(flag, 0x10) ~= 0
		
		if xShort then
			local val = reader:readUInt8()
			if xSame then
				x = x + val
			else
				x = x - val
			end
		elseif not xSame then
			x = x + reader:readInt16()
		end
		
		xCoordinates[i] = x
	end
	
	local yCoordinates = {}
	local y = 0
	for i = 0, numPoints - 1 do
		local flag = flags[i]
		local yShort = bit32.band(flag, 0x04) ~= 0
		local ySame = bit32.band(flag, 0x20) ~= 0
		
		if yShort then
			local val = reader:readUInt8()
			if ySame then
				y = y + val
			else
				y = y - val
			end
		elseif not ySame then
			y = y + reader:readInt16()
		end
		
		yCoordinates[i] = y
	end
	
	local contours = {}
	local startIdx = 0
	
	for i = 1, glyph.numberOfContours do
		local endIdx = endPtsOfContours[i]
		local contour = {}
		
		for j = startIdx, endIdx do
			local onCurve = bit32.band(flags[j], 0x01) ~= 0
			table.insert(contour, {
				x = xCoordinates[j],
				y = yCoordinates[j],
				onCurve = onCurve
			})
		end
		
		table.insert(contours, contour)
		startIdx = endIdx + 1
	end
	
	glyph.contours = contours
	return glyph
end

function TTFParser:getGlyphContours(char)
	local cmap = self:parseCmap()
	if not cmap then return nil end
	
	local charCode = string.byte(char)
	local glyphIndex = cmap[charCode]
	
	if not glyphIndex then return nil end
	
	return self:parseGlyph(glyphIndex)
end

-- ============================================================================
-- CONTOUR TO SEGMENTS CONVERTER
-- ============================================================================

local function quadraticBezier(p0, p1, p2, segments)
	local points = {}
	for i = 0, segments do
		local t = i / segments
		local mt = 1 - t
		local x = mt * mt * p0.x + 2 * mt * t * p1.x + t * t * p2.x
		local y = mt * mt * p0.y + 2 * mt * t * p1.y + t * t * p2.y
		table.insert(points, {x = x, y = y})
	end
	return points
end

local function convertContoursToSegments(contours, segments)
	if not contours then return {} end
	
	local result = {}
	
	for _, contour in ipairs(contours) do
		local points = {}
		local n = #contour
		
		if n == 0 then continue end
		
		for i = 1, n do
			local curr = contour[i]
			local next = contour[i % n + 1]
			
			if curr.onCurve then
				table.insert(points, {x = curr.x, y = curr.y})
				
				if not next.onCurve then
					local nextNext = contour[(i + 1) % n + 1]
					
					local endPoint
					if nextNext.onCurve then
						endPoint = nextNext
					else
						endPoint = {
							x = (next.x + nextNext.x) / 2,
							y = (next.y + nextNext.y) / 2,
							onCurve = true
						}
					end
					
					local bezierPoints = quadraticBezier(curr, next, endPoint, segments)
					for j = 2, #bezierPoints do
						table.insert(points, bezierPoints[j])
					end
				end
			end
		end
		
		if #points > 0 then
			table.insert(result, points)
		end
	end
	
	return result
end

local function normalizeGlyph(glyph, segments)
	if not glyph or not glyph.contours then return nil end
	
	local contours = convertContoursToSegments(glyph.contours, segments or 16)
	
	if #contours == 0 then return nil end
	
	local minX, maxX = math.huge, -math.huge
	local minY, maxY = math.huge, -math.huge
	
	for _, contour in ipairs(contours) do
		for _, point in ipairs(contour) do
			minX = math.min(minX, point.x)
			maxX = math.max(maxX, point.x)
			minY = math.min(minY, point.y)
			maxY = math.max(maxY, point.y)
		end
	end
	
	local width = maxX - minX
	local height = maxY - minY
	
	if width == 0 or height == 0 then return nil end
	
	-- DON'T normalize - keep original coordinates for proper sizing
	return {
		contours = contours,
		width = width,
		height = height,
		minX = minX,
		minY = minY,
		maxX = maxX,
		maxY = maxY
	}
end

-- ============================================================================
-- F3X BUILDER
-- ============================================================================

local function getF3XEndpoint()
	local bt = workspace[player.Name]:FindFirstChild("Building Tools")
	if not bt then
		warn("F3X Building Tools not equipped!")
		return nil
	end
	
	local syncAPI = bt:FindFirstChild("SyncAPI")
	if not syncAPI then
		warn("F3X SyncAPI not found!")
		return nil
	end
	
	local endpoint = syncAPI:FindFirstChild("ServerEndpoint")
	if not endpoint then
		warn("F3X ServerEndpoint not found!")
		return nil
	end
	
	return endpoint
end

local function claimOwnership(parts)
	local EscalateEvent = RS.raidRoleplay.Events.EscalateEvent
	local PartOwnership = RS.raidRoleplay.Modules.PartOwnership
	
	EscalateEvent:FireServer(PartOwnership, parts)
	
	for _, part in ipairs(parts) do
		local timeout = 0
		while not part:FindFirstChild("RRPartOwner") and timeout < 100 do
			task.wait(0.01)
			timeout = timeout + 1
		end
	end
end

local function buildGlyph(glyphData, position, scale, thickness, color, material)
	local endpoint = getF3XEndpoint()
	if not endpoint then return end
	
	if not glyphData or not glyphData.contours then return end
	
	local parts = {}
	local partData = {}
	
	-- Collect all part data first
	for _, contour in ipairs(glyphData.contours) do
		for i = 1, #contour - 1 do
			local p1 = contour[i]
			local p2 = contour[i + 1]
			
			local x1 = p1.x * scale
			local y1 = p1.y * scale
			local x2 = p2.x * scale
			local y2 = p2.y * scale
			
			local midX = (x1 + x2) / 2
			local midY = (y1 + y2) / 2
			
			local length = math.sqrt((x2 - x1)^2 + (y2 - y1)^2)
			local angle = math.atan2(y2 - y1, x2 - x1)
			
			local cf = CFrame.new(
				position.X + midX,
				position.Y + midY,
				position.Z
			) * CFrame.Angles(0, 0, angle)
			
			table.insert(partData, {
				cf = cf,
				length = length
			})
		end
	end
	
	-- Create all parts in parallel (don't wait for each one)
	local threads = {}
	for i, data in ipairs(partData) do
		threads[i] = task.spawn(function()
			local success, part = pcall(function()
				return endpoint:InvokeServer("CreatePart", "Normal", data.cf, workspace)
			end)
			if success and part then
				parts[i] = part
			end
		end)
	end
	
	-- Wait for all threads to complete
	for _, thread in ipairs(threads) do
		while coroutine.status(thread) ~= "dead" do
			task.wait()
		end
	end
	
	-- Remove nil entries
	local cleanParts = {}
	for _, part in ipairs(parts) do
		if part then
			table.insert(cleanParts, part)
		end
	end
	parts = cleanParts
	
	if #parts > 0 then
		claimOwnership(parts)
		
		-- Batch resize
		local resizeBatch = {}
		for i, part in ipairs(parts) do
			table.insert(resizeBatch, {
				Part = part,
				Size = Vector3.new(partData[i].length, thickness, thickness),
				CFrame = partData[i].cf
			})
		end
		endpoint:InvokeServer("SyncResize", resizeBatch)
		
		-- Batch color
		local colorBatch = {}
		for _, part in ipairs(parts) do
			table.insert(colorBatch, {
				Part = part,
				Color = color
			})
		end
		endpoint:InvokeServer("SyncColor", colorBatch)
		
		-- Batch material
		local materialBatch = {}
		for _, part in ipairs(parts) do
			table.insert(materialBatch, {
				Part = part,
				Material = material
			})
		end
		endpoint:InvokeServer("SyncMaterial", materialBatch)
	end
end

