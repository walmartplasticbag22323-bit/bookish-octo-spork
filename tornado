-- Calculate build center from all parts
local function calculateBuildCenter()
    local sumX, sumY, sumZ = 0, 0, 0
    for _, part in ipairs(TORNADO_DATA) do
        sumX = sumX + part.Position.X
        sumY = sumY + part.Position.Y
        sumZ = sumZ + part.Position.Z
    end
    local count = #TORNADO_DATA
    return Vector3.new(sumX/count, sumY/count, sumZ/count)
end

local BUILD_CENTER = calculateBuildCenter()

-- Create server part (invisible, for replication) with STEALTH technique
local function createServerPart(ep, syncAPI, partData, spawnCF, sizeMultiplier)
    local relativePos = partData.Position - BUILD_CENTER
    local cf = spawnCF * CFrame.new(relativePos * sizeMultiplier) * partData.Rotation
    
    -- STEALTH: Use 0.001x size (microscopic, hides RRPartOwner)
    local adjustedSize = partData.Size * sizeMultiplier
    local stealthSize = CONFIG.USE_STEALTH_PARTS and (adjustedSize * 0.001) or adjustedSize
    
    local part = ep:InvokeServer("CreatePart", "Normal", cf, workspace)
    if not part then return nil end
    
    -- Claim ownership
    local EscalateEvent = RS.raidRoleplay.Events.EscalateEvent
    local PartOwnership = RS.raidRoleplay.Modules.PartOwnership
    EscalateEvent:FireServer(PartOwnership, {part})
    
    -- Wait for ownership
    local timeout = 0
    repeat 
        task.wait(0.01)
        timeout = timeout + 0.01
    until part:FindFirstChild("RRPartOwner") or timeout > 1
    
    if not part:FindFirstChild("RRPartOwner") then
        part:Destroy()
        return nil
    end
    
    -- Set properties with stealth size
    ep:InvokeServer("SyncResize", {{Part = part, Size = stealthSize, CFrame = cf}})
    
    if CONFIG.USE_STEALTH_PARTS then
        -- Add mesh to compensate for tiny size (1000x scale)
        syncAPI:Invoke("CreateMeshes", {{Part = part}})
        task.wait(0.05)
        
        -- Set mesh to block shape with 1000x scale
        syncAPI:Invoke("SyncMesh", {{
            Part = part,
            MeshType = Enum.MeshType.Brick,
            Scale = Vector3.new(1000, 1000, 1000)
        }})
        
        -- Update mesh scale dynamically during replication
        part:SetAttribute("StealthMode", true)
    end
    
    syncAPI:Invoke("SyncMaterial", {{Part = part, Transparency = 0, Material = Enum.Material.Sand}})
    syncAPI:Invoke("SyncAnchor", {{Part = part, Anchored = true}})
    syncAPI:Invoke("SyncColor", {{Part = part, UnionColoring = true, Color = Color3.fromRGB(163, 162, 165)}})
    
    -- Disable CastShadow using RemoteEvents
    task.spawn(function()
        task.wait(0.1)
        pcall(function()
            local RemoteEvents = RS:FindFirstChild("RemoteEvents")
            if RemoteEvents and RemoteEvents:FindFirstChild("PropertyChanged") then
                RemoteEvents.PropertyChanged:FireServer(part, "CastShadow", false)
            end
        end)
    end)
    
    -- Make server part invisible on client side
    part.Transparency = 1
    part.CanCollide = false
    
    return part
end

-- Batch update server parts with size and transparency
local function batchUpdateServerParts(ep, syncAPI, partsData)
    if not ep or not syncAPI or #partsData == 0 then return end
    
    local moveData = {}
    local resizeData = {}
    local meshUpdateData = {}
    
    for _, info in ipairs(partsData) do
        if info.serverPart and info.serverPart.Parent and info.clientPart and info.clientPart.Parent then
            -- Sync position
            table.insert(moveData, {
                Part = info.serverPart,
                CFrame = info.clientPart.CFrame,
            })
            
            -- Sync size (if using stealth mode, scale appropriately)
            if CONFIG.USE_STEALTH_PARTS then
                local stealthSize = info.clientPart.Size * 0.001
                table.insert(resizeData, {
                    Part = info.serverPart,
                    Size = stealthSize,
                    CFrame = info.clientPart.CFrame,
                })
                
                -- Update mesh scale to match visual size
                if info.serverPart:FindFirstChildOfClass("SpecialMesh") then
                    table.insert(meshUpdateData, {
                        Part = info.serverPart,
                        MeshType = Enum.MeshType.Brick,
                        Scale = Vector3.new(1000, 1000, 1000)
                    })
                end
            else
                table.insert(resizeData, {
                    Part = info.serverPart,
                    Size = info.clientPart.Size,
                    CFrame = info.clientPart.CFrame,
                })
            end
        end
    end
    
    if #moveData > 0 then
        pcall(function()
            ep:InvokeServer("SyncMove", moveData)
        end)
    end
    
    if #resizeData > 0 then
        pcall(function()
            ep:InvokeServer("SyncResize", resizeData)
        end)
    end
    
    if #meshUpdateData > 0 then
        pcall(function()
            syncAPI:Invoke("SyncMesh", meshUpdateData)
        end)
    end
end

-- Destroy parts in tornado's path
local function destroyPartsInRadius(ep, syncAPI, centerPos, radius)
    if not ep then return end
    
    local partsToDestroy = {}
    
    -- Find all parts in radius
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Name ~= "TornadoPart" and obj.Name ~= "TornadoRoot" then
            -- Skip player characters
            local isCharacterPart = false
            local ancestor = obj.Parent
            while ancestor do
                if ancestor:IsA("Model") and Players:GetPlayerFromCharacter(ancestor) then
                    isCharacterPart = true
                    break
                end
                ancestor = ancestor.Parent
            end
            
            if not isCharacterPart then
                -- Check distance
                local distance = (obj.Position - centerPos).Magnitude
                if distance <= radius then
                    table.insert(partsToDestroy, obj)
                end
            end
        end
    end
    
    -- Destroy parts using lightsaber method (most reliable)
    if #partsToDestroy > 0 then
        task.spawn(function()
            -- Claim ownership first
            local EscalateEvent = RS.raidRoleplay.Events.EscalateEvent
            local PartOwnership = RS.raidRoleplay.Modules.PartOwnership
            pcall(function()
                EscalateEvent:FireServer(PartOwnership, partsToDestroy)
            end)
            
            task.wait(0.15)
            
            local deletedCount = 0
            
            -- Delete parts one by one using lightsaber method
            for _, part in ipairs(partsToDestroy) do
                if part and part.Parent then
                    local success = pcall(function()
                        -- Method 1: Group then ungroup (lightsaber method)
                        local groupArgs = {
                            "CreateGroup",
                            "Model",
                            workspace,
                            {part}
                        }
                        ep:InvokeServer(unpack(groupArgs))
                        task.wait(0.03)
                        
                        local ungroupArgs = {
                            "Ungroup",
                            {part}
                        }
                        ep:InvokeServer(unpack(ungroupArgs))
                        deletedCount = deletedCount + 1
                    end)
                    
                    if not success then
                        -- Fallback: Try direct remove
                        pcall(function()
                            ep:InvokeServer("Remove", {part})
                            deletedCount = deletedCount + 1
                        end)
                    end
                    
                    task.wait(0.05)
                end
            end
            
            print("🌪️ Destroyed", deletedCount, "/", #partsToDestroy, "parts in tornado path!")
        end)
    end
end

-- Main tornado spawn function
local function spawnTornado(spawnCF, forwardDirection, sizeMultiplier)
    sizeMultiplier = sizeMultiplier or 1  -- Default to normal size
    
    local ep, syncAPI = getEndpoints()
    if not ep or not syncAPI then return end
    
    print("Spawning tornado at:", spawnCF.Position, "with size multiplier:", sizeMultiplier)
    print("Build center:", BUILD_CENTER)
    
    -- Raycast down to find ground
    local rayOrigin = spawnCF.Position
    local rayDirection = Vector3.new(0, -1000, 0)
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    raycastParams.FilterDescendantsInstances = {character}
    
    local rayResult = workspace:Raycast(rayOrigin, rayDirection, raycastParams)
    local groundY = rayResult and rayResult.Position.Y or spawnCF.Position.Y
    
    -- Auto-calculate spawn height based on size multiplier
    local autoSpawnHeight = CONFIG.SPAWN_HEIGHT * sizeMultiplier
    
    -- Spawn tornado at ground level + auto height offset
    local finalSpawnPos = Vector3.new(spawnCF.Position.X, groundY + autoSpawnHeight, spawnCF.Position.Z)
    local finalSpawnCF = CFrame.new(finalSpawnPos) * (spawnCF - spawnCF.Position)
    
    print("Ground detected at Y:", groundY, "Spawning at Y:", finalSpawnPos.Y, "Height offset:", autoSpawnHeight)
    
    -- Create invisible main root at spawn position (ANCHORED to prevent sinking)
    local mainRoot = Instance.new("Part")
    mainRoot.Name = "TornadoRoot"
    mainRoot.Size = Vector3.new(1, 1, 1)
    mainRoot.CFrame = finalSpawnCF
    mainRoot.Transparency = 1
    mainRoot.Anchored = true  -- ANCHORED so it stays at exact position
    mainRoot.CanCollide = false
    mainRoot.Parent = workspace
    
    -- Create all client parts with group tracking
    local clientParts = {}
    local serverParts = {}
    local partsByGroup = {BottomRing = {}, TopRing = {}, Core = {}}
    
    for i, partData in ipairs(TORNADO_DATA) do
        -- Calculate relative position from build center with size multiplier
        local relativePos = partData.Position - BUILD_CENTER
        local partCF = spawnCF * CFrame.new(relativePos * sizeMultiplier) * partData.Rotation
        
        -- Create client part (FULLY VISIBLE - transparency 0)
        local clientPart = Instance.new("Part")
        clientPart.Name = "TornadoPart_" .. i
        clientPart.Size = partData.Size * sizeMultiplier  -- Apply size multiplier
        clientPart.CFrame = partCF
        clientPart.Transparency = 0  -- FULLY VISIBLE
        clientPart.Material = Enum.Material.Sand
        clientPart.Color = Color3.fromRGB(163, 162, 165)
        clientPart.TopSurface = Enum.SurfaceType.Smooth
        clientPart.BottomSurface = Enum.SurfaceType.Smooth
        clientPart.Anchored = true
        clientPart.CanCollide = false
        clientPart.CastShadow = false  -- No shadows
        clientPart.Parent = workspace
        
        -- Store part info with group, relative position, and original properties
        local partInfo = {
            part = clientPart,
            relativePos = relativePos * sizeMultiplier,  -- Store scaled relative position
            rotation = partData.Rotation,
            group = partData.Group,
            baseSize = partData.Size * sizeMultiplier,  -- Store scaled base size
            baseTransparency = 0,  -- Client parts stay at 0 transparency
        }
        
        table.insert(clientParts, partInfo)
        table.insert(partsByGroup[partData.Group], partInfo)
        
        -- Store placeholder for server part
        local serverPartInfo = {
            clientPart = clientPart,
            serverPart = nil,
            partData = partData,
        }
        table.insert(serverParts, serverPartInfo)
        
        -- Create server part in background
        task.spawn(function()
            local serverPart = createServerPart(ep, syncAPI, partData, spawnCF, sizeMultiplier)
            if serverPart then
                serverPartInfo.serverPart = serverPart
                print("Server part created:", i, "/", #TORNADO_DATA)
            else
                warn("Failed to create server part:", i)
            end
        end)
    end
    
    print("Client tornado spawned with", #clientParts, "parts")
    
    -- Wait a bit for server parts to be created
    task.wait(0.5)
    
    -- Count successful server parts
    local serverPartCount = 0
    for _, info in ipairs(serverParts) do
        if info.serverPart and info.serverPart.Parent then
            serverPartCount = serverPartCount + 1
        end
    end
    print("Server parts created:", serverPartCount, "/", #TORNADO_DATA)
    
    -- Store initial Y for comparison
    local initialY = finalSpawnPos.Y
    
    -- Animation loop
    local startTime = tick()
    local lastReplicationTime = 0
    local replicationInterval = 1 / CONFIG.REPLICATION_RATE
    local destructionFrameCounter = 0
    
    local mainRotation = 0
    local bottomRotation = 0
    local topRotation = 0
    local coreRotation = 0
    local distanceTraveled = 0
    
    local connection
    connection = RunService.Heartbeat:Connect(function(dt)
        local elapsedTime = tick() - startTime
        
        -- Check lifetime (skip if debug mode)
        if elapsedTime > CONFIG.TORNADO_LIFETIME then
            connection:Disconnect()
            
            -- Cleanup
            mainRoot:Destroy()
            for _, partInfo in ipairs(clientParts) do
                if partInfo.part and partInfo.part.Parent then
                    partInfo.part:Destroy()
                end
            end
            
            if ep and #serverParts > 0 then
                local toRemove = {}
                for _, info in ipairs(serverParts) do
                    if info.serverPart and info.serverPart.Parent then
                        table.insert(toRemove, info.serverPart)
                    end
                end
                if #toRemove > 0 then
                    pcall(function()
                        ep:InvokeServer("Remove", toRemove)
                    end)
                end
            end
            
            print("Tornado despawned")
            return
        end
        
        -- Update rotations (accelerated speeds)
        bottomRotation = bottomRotation + (CONFIG.BOTTOM_RING_SPIN * dt)
        topRotation = topRotation + (CONFIG.TOP_RING_SPIN * dt)
        coreRotation = coreRotation + (CONFIG.CORE_SPIN * dt)
        
        -- Calculate dynamic wobble offset
        local wobbleX = math.sin(elapsedTime * CONFIG.WOBBLE_SPEED) * CONFIG.WOBBLE_INTENSITY
        local wobbleZ = math.cos(elapsedTime * CONFIG.WOBBLE_SPEED * 1.3) * CONFIG.WOBBLE_INTENSITY
        
        -- Calculate vertical pulse
        local verticalPulse = math.sin(elapsedTime * CONFIG.VERTICAL_PULSE_SPEED) * CONFIG.VERTICAL_PULSE
        
        -- Move forward in spawn direction
        distanceTraveled = distanceTraveled + (CONFIG.FORWARD_SPEED * dt)
        local forwardOffset = forwardDirection * distanceTraveled
        
        -- Update main root position with all dynamic movements
        local newPos = Vector3.new(
            finalSpawnPos.X + wobbleX + forwardOffset.X,
            finalSpawnPos.Y + verticalPulse,
            finalSpawnPos.Z + wobbleZ + forwardOffset.Z
        )
        mainRoot.CFrame = CFrame.new(newPos)
        
        -- Destroy parts in path (every N frames to reduce lag)
        destructionFrameCounter = destructionFrameCounter + 1
        if destructionFrameCounter >= CONFIG.DESTRUCTION_CHECK_RATE then
            destructionFrameCounter = 0
            destroyPartsInRadius(ep, syncAPI, newPos, CONFIG.DESTRUCTION_RADIUS * sizeMultiplier)
        end
        
        -- Get current main CFrame
        local mainCF = mainRoot.CFrame
        
        -- Calculate size and transparency pulse multipliers
        local sizePulse = 1 + (math.sin(elapsedTime * CONFIG.SIZE_PULSE_SPEED) * CONFIG.SIZE_PULSE_AMOUNT)
        local transparencyPulse = math.sin(elapsedTime * CONFIG.TRANSPARENCY_SPEED) * CONFIG.TRANSPARENCY_PULSE
        
        -- Apply multi-layer rotations with dynamic effects
        for _, partInfo in ipairs(clientParts) do
            if partInfo.part and partInfo.part.Parent then
                local groupRotation = 0
                local additionalScale = 1
                
                -- Different rotation speeds per group
                if partInfo.group == "BottomRing" then
                    groupRotation = bottomRotation
                    additionalScale = 1 + (math.sin(elapsedTime * 2) * 0.1) -- Extra pulsing for bottom
                elseif partInfo.group == "TopRing" then
                    groupRotation = topRotation
                    additionalScale = 1 + (math.cos(elapsedTime * 2.5) * 0.08) -- Different pulse for top
                elseif partInfo.group == "Core" then
                    groupRotation = coreRotation
                end
                
                -- Calculate new position with group-specific rotation
                local rotatedOffset = CFrame.Angles(0, groupRotation, 0) * partInfo.relativePos
                
                -- Apply rotation to both position AND orientation of the part
                partInfo.part.CFrame = mainCF * CFrame.new(rotatedOffset) * CFrame.Angles(0, groupRotation, 0) * partInfo.rotation
                
                -- Apply dynamic size pulsing
                local finalSize = partInfo.baseSize * sizePulse * additionalScale
                partInfo.part.Size = finalSize
                
                -- Apply dynamic transparency pulsing
                local finalTransparency = math.clamp(partInfo.baseTransparency + transparencyPulse, 0, 1)
                partInfo.part.Transparency = finalTransparency
            end
        end
        
        -- Replicate to server at 75Hz
        local currentTime = tick()
        if currentTime - lastReplicationTime >= replicationInterval then
            batchUpdateServerParts(ep, syncAPI, serverParts)
            lastReplicationTime = currentTime
        end
    end)
end

-- Create spawner tool
local function createSpawnerTool(toolName, sizeMultiplier, toolColor)
    local tool = Instance.new("Tool")
    tool.Name = toolName
    tool.RequiresHandle = false
    tool.CanBeDropped = false
    
    local handle = Instance.new("Part")
    handle.Name = "Handle"
    handle.Size = Vector3.new(0.5, 3, 0.5) * math.clamp(sizeMultiplier, 0.5, 3)  -- Scale handle (capped at 3x for visibility)
    handle.Material = Enum.Material.Neon
    handle.BrickColor = BrickColor.new(toolColor)
    handle.CanCollide = false
    handle.Parent = tool
    
    tool.Activated:Connect(function()
        local char = player.Character
        if not char then return end
        
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        
        -- Get forward direction from player's facing direction
        local lookVector = hrp.CFrame.LookVector
        local forwardDirection = Vector3.new(lookVector.X, 0, lookVector.Z).Unit
        
        -- Spawn in front of player at configured height (scaled)
        local spawnDistance = CONFIG.SPAWN_DISTANCE * sizeMultiplier
        local spawnHeight = CONFIG.SPAWN_HEIGHT * sizeMultiplier
        local spawnCF = hrp.CFrame * CFrame.new(0, spawnHeight, -spawnDistance)
        spawnTornado(spawnCF, forwardDirection, sizeMultiplier)
    end)
    
    tool.Parent = backpack
end

