                selectedLimbIndex = i
                selectedLimbData = limb
                limbSelector.Text = i .. ". " .. limb.part.Name .. " ▼"
                limbTypeButton.Text = limb.limbType .. " ▼"
                limbDropdown.Visible = false
                
                -- Highlight selected limb in game
                if limb.part then
                    local highlight = limb.part:FindFirstChild("LimbHighlight")
                    if not highlight then
                        highlight = Instance.new("SelectionBox")
                        highlight.Name = "LimbHighlight"
                        highlight.Adornee = limb.part
                        highlight.LineThickness = 0.05
                        highlight.Color3 = Color3.fromRGB(100, 200, 255)
                        highlight.Parent = limb.part
                    end
                    
                    -- Remove other highlights
                    for _, otherLimb in ipairs(ai.bodyMap.limbs) do
                        if otherLimb ~= limb and otherLimb.part then
                            local otherHighlight = otherLimb.part:FindFirstChild("LimbHighlight")
                            if otherHighlight then
                                otherHighlight:Destroy()
                            end
                        end
                    end
                end
            end)
