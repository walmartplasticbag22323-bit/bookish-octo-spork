                            servoParts[part].inputConnection:Disconnect()
                        end
                        if servoParts[part].inputEndConnection then
                            servoParts[part].inputEndConnection:Disconnect()
                        end
                    end
                    
                    -- Store original CFrame
                    local originalCFrame = part.CFrame
                    local isKeyPressed = false
                    local currentProgress = 0 -- 0 to 1
                    
                    -- Input connection
                    local inputConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
                        if gameProcessed then return end
                        if input.KeyCode == Enum.KeyCode[keybind] then
                            isKeyPressed = true
                        end
                    end)
                    
                    local inputEndConnection = UserInputService.InputEnded:Connect(function(input)
                        if input.KeyCode == Enum.KeyCode[keybind] then
                            isKeyPressed = false
                        end
                    end)
                    
                    -- Rotation axis vector
                    local axisVector = Vector3.new(0, 0, 0)
                    if selectedAxis == "X" then
                        axisVector = Vector3.new(1, 0, 0)
                    elseif selectedAxis == "Y" then
                        axisVector = Vector3.new(0, 1, 0)
                    elseif selectedAxis == "Z" then
                        axisVector = Vector3.new(0, 0, 1)
                    end
                    
                    -- Heartbeat connection for smooth tweening
                    local connection = RunService.Heartbeat:Connect(function(dt)
                        if not part.Parent then
                            connection:Disconnect()
                            inputConnection:Disconnect()
                            inputEndConnection:Disconnect()
                            servoParts[part] = nil
                            return
                        end
                        
                        setNetworkOwnership(part)
                        
                        -- Update progress based on key state
                        if isKeyPressed then
                            currentProgress = math.min(currentProgress + (speed * dt), 1)
                        else
                            currentProgress = math.max(currentProgress - (speed * dt), 0)
                        end
                        
                        -- Calculate target rotation
                        local currentAngle = math.rad(targetAngle * currentProgress)
                        local rotationCFrame = CFrame.fromAxisAngle(axisVector, currentAngle)
                        local targetCFrame = originalCFrame * rotationCFrame
                        
                        -- Apply rotation using AssemblyAngularVelocity for smooth tweening
                        local angleDiff = targetCFrame.Rotation - part.CFrame.Rotation
                        local _, angleX, angleY, angleZ = angleDiff:ToAxisAngle()
                        local angularVelocity = Vector3.new(angleX, angleY, angleZ) * 10 * speed
                        
                        part.AssemblyAngularVelocity = angularVelocity
                        
                        -- If very close to target, snap to it
                        if math.abs(currentProgress - (isKeyPressed and 1 or 0)) < 0.01 then
                            part.CFrame = targetCFrame
                            part.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                        end
                    end)
                    
                    servoParts[part] = {
                        connection = connection,
                        inputConnection = inputConnection,
                        inputEndConnection = inputEndConnection,
                        originalCFrame = originalCFrame,
                        targetAngle = targetAngle,
                        axis = selectedAxis,
                        keybind = keybind,
                        speed = speed
                    }
                    
