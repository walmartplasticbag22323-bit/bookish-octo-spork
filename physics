                part.CFrame = CFrame.new(position + offset, position + offset + part.CFrame.LookVector)
                task.wait()
                part.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                print("Teleported " .. part.Name .. " to " .. tostring(position))
