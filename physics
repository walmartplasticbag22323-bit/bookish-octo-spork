    -- NEW: Keybind Manager Storage
    local activeKeybinds = {} -- {id: {parts, velocity, mode, keys, triggerType, connection}}
    local nextKeybindId = 1
    
    -- Storage for keybind physics objects (per part)
    local keybindPhysicsObjects = {} -- {part: {bodyVel, vectorForce, attachment, method}}
    local keybindAngularObjects = {} -- {part: {bodyAngVel, bodyGyro, torqueForce, attachment, method}}
    
    -- NEW: Global keybind update loop (runs once per frame, combines ALL keybinds)
    local keybindUpdateConnection = RunService.Heartbeat:Connect(function()
        -- Track which parts need velocity updates
        local partVelocities = {} -- {part: {velocity, forceful, method}}
        local partAngularVelocities = {} -- {part: {angularVel, method, torque, spinAxis}}
        
        -- Collect velocities from ALL active keybinds
        for id, keybindData in pairs(activeKeybinds) do
            -- LINEAR VELOCITY KEYBINDS
            if keybindData.enabled and keybindData.isActive and keybindData.type == "LinVel" then
                local part = keybindData.partRef
                if part and part.Parent then
                    -- Calculate effective velocity
                    local effectiveVel = keybindData.velocity
                    
                    if keybindData.velocityToAxis == "Velocity to Axis" or keybindData.velocityToAxis == "Updating Velocity to Axis" then
                        effectiveVel = part.CFrame:VectorToWorldSpace(keybindData.velocity)
                    end
                    
                    -- Add to combined velocity for this part
                    if not partVelocities[part] then
                        partVelocities[part] = {velocity = Vector3.new(0, 0, 0), forceful = false, method = keybindData.method}
                    end
                    
                    partVelocities[part].velocity = partVelocities[part].velocity + effectiveVel
                    partVelocities[part].forceful = partVelocities[part].forceful or keybindData.forceful
                end
            end
            
            -- ANGULAR VELOCITY KEYBINDS
            if keybindData.enabled and keybindData.isActive and keybindData.type == "AngVel" then
                local part = keybindData.partRef
                if part and part.Parent then
                    -- Calculate effective angular velocity
                    local effectiveAngVel = keybindData.angularVel
                    
                    if keybindData.spinAxis == "Spin to Axis" or keybindData.spinAxis == "Updating Spin to Axis" then
                        effectiveAngVel = part.CFrame:VectorToWorldSpace(keybindData.angularVel)
                    end
                    
                    -- Add to combined angular velocity for this part
                    if not partAngularVelocities[part] then
                        partAngularVelocities[part] = {angularVel = Vector3.new(0, 0, 0), method = keybindData.method, torque = keybindData.torque, spinAxis = keybindData.spinAxis}
                    end
                    
                    partAngularVelocities[part].angularVel = partAngularVelocities[part].angularVel + effectiveAngVel
                end
            end
            
            -- Handle OnPress/OnRelease trigger types (reset after one frame)
            if keybindData.triggerType == "OnPress" or keybindData.triggerType == "OnRelease" then
                keybindData.isActive = false
            end
        end
        
        -- Apply combined velocities to parts (only ONCE per part per frame)
        for part, data in pairs(partVelocities) do
            if part and part.Parent then
                -- Ensure physics objects exist for this part
                if not keybindPhysicsObjects[part] then
                    keybindPhysicsObjects[part] = {method = data.method}
                    
                    -- Create physics objects based on method
                    if data.method == "BodyVelocity" then
                        local bodyVel = Instance.new("BodyVelocity")
                        bodyVel.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
                        bodyVel.Velocity = Vector3.new(0, 0, 0)
                        bodyVel.Parent = part
                        keybindPhysicsObjects[part].bodyVel = bodyVel
                        print("🔧 Created BodyVelocity for " .. part.Name)
                        
                    elseif data.method == "VectorForce" then
                        local attachment = Instance.new("Attachment")
                        attachment.Parent = part
                        
                        local vectorForce = Instance.new("VectorForce")
                        vectorForce.Attachment0 = attachment
                        vectorForce.ApplyAtCenterOfMass = true
                        vectorForce.RelativeTo = Enum.ActuatorRelativeTo.World
                        vectorForce.Parent = part
                        
                        keybindPhysicsObjects[part].attachment = attachment
                        keybindPhysicsObjects[part].vectorForce = vectorForce
                        print("🔧 Created VectorForce for " .. part.Name)
                    end
                    -- AssemblyLinearVelocity doesn't need objects
                end
                
                -- Apply velocity using the appropriate method
                local physicsObj = keybindPhysicsObjects[part]
                
                if physicsObj.method == "BodyVelocity" and physicsObj.bodyVel then
                    physicsObj.bodyVel.Velocity = data.velocity
                    if data.forceful then
                        part.AssemblyLinearVelocity = data.velocity
                    end
                    
                elseif physicsObj.method == "VectorForce" and physicsObj.vectorForce then
                    local currentVel = part.AssemblyLinearVelocity
                    local velocityDiff = data.velocity - currentVel
                    physicsObj.vectorForce.Force = velocityDiff * part.AssemblyMass * (data.forceful and 20 or 10)
                    
                elseif physicsObj.method == "AssemblyLinearVelocity" then
                    part.AssemblyLinearVelocity = data.velocity
                    if data.forceful then
                        local velocityDiff = data.velocity - part.AssemblyLinearVelocity
                        if velocityDiff.Magnitude > 0.1 then
                            part:ApplyImpulse(velocityDiff * part.Mass * 0.5)
                        end
                    end
                end
            end
        end
        
        -- Apply combined angular velocities to parts
        for part, data in pairs(partAngularVelocities) do
            if part and part.Parent then
                -- Ensure physics objects exist for this part
                if not keybindAngularObjects[part] then
                    keybindAngularObjects[part] = {method = data.method}
                    
                    -- Create physics objects based on method
                    if data.method == "BodyAngularVelocity" then
                        local bodyAngVel = Instance.new("BodyAngularVelocity")
                        bodyAngVel.MaxTorque = Vector3.new(data.torque, data.torque, data.torque)
                        bodyAngVel.AngularVelocity = Vector3.new(0, 0, 0)
                        bodyAngVel.P = data.torque
                        bodyAngVel.Parent = part
                        keybindAngularObjects[part].bodyAngVel = bodyAngVel
                        print("🔧 Created BodyAngularVelocity for " .. part.Name)
                        
                    elseif data.method == "BodyGyro" then
                        local bodyGyro = Instance.new("BodyGyro")
                        bodyGyro.MaxTorque = Vector3.new(data.torque, data.torque, data.torque)
                        bodyGyro.D = 100
                        bodyGyro.P = data.torque
                        bodyGyro.Parent = part
                        keybindAngularObjects[part].bodyGyro = bodyGyro
                        print("🔧 Created BodyGyro for " .. part.Name)
                        
                    elseif data.method == "Torque" then
                        local attachment = Instance.new("Attachment")
                        attachment.Parent = part
                        
                        local torqueForce = Instance.new("Torque")
                        torqueForce.Attachment0 = attachment
                        torqueForce.Torque = Vector3.new(0, 0, 0)
                        torqueForce.Parent = part
                        
                        keybindAngularObjects[part].attachment = attachment
                        keybindAngularObjects[part].torqueForce = torqueForce
                        print("🔧 Created Torque for " .. part.Name)
                    end
                    -- AssemblyAngularVelocity doesn't need objects
                end
                
                -- Apply angular velocity using the appropriate method
                local angularObj = keybindAngularObjects[part]
                
                if angularObj.method == "BodyAngularVelocity" and angularObj.bodyAngVel then
                    angularObj.bodyAngVel.AngularVelocity = data.angularVel
                    angularObj.bodyAngVel.MaxTorque = Vector3.new(data.torque, data.torque, data.torque)
                    angularObj.bodyAngVel.P = data.torque
                    
                elseif angularObj.method == "BodyGyro" and angularObj.bodyGyro then
                    angularObj.bodyGyro.CFrame = part.CFrame * CFrame.fromEulerAnglesXYZ(data.angularVel.X, data.angularVel.Y, data.angularVel.Z)
                    angularObj.bodyGyro.MaxTorque = Vector3.new(data.torque, data.torque, data.torque)
                    angularObj.bodyGyro.P = data.torque
                    
                elseif angularObj.method == "Torque" and angularObj.torqueForce then
                    angularObj.torqueForce.Torque = data.angularVel * data.torque
                    
                elseif angularObj.method == "AssemblyAngularVelocity" then
                    part.AssemblyAngularVelocity = data.angularVel
                end
            end
        end
        
        -- Reset velocity for parts with NO active keybinds
        for part, physicsObj in pairs(keybindPhysicsObjects) do
            if part and part.Parent and not partVelocities[part] then
                -- No active keybinds for this part - set velocity to zero
                if physicsObj.method == "BodyVelocity" and physicsObj.bodyVel then
                    physicsObj.bodyVel.Velocity = Vector3.new(0, 0, 0)
                elseif physicsObj.method == "VectorForce" and physicsObj.vectorForce then
                    physicsObj.vectorForce.Force = Vector3.new(0, 0, 0)
                elseif physicsObj.method == "AssemblyLinearVelocity" then
                    part.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                end
            end
        end
        
        -- Reset angular velocity for parts with NO active angular keybinds
        for part, angularObj in pairs(keybindAngularObjects) do
            if part and part.Parent and not partAngularVelocities[part] then
                -- No active angular keybinds for this part - set angular velocity to zero
                if angularObj.method == "BodyAngularVelocity" and angularObj.bodyAngVel then
                    angularObj.bodyAngVel.AngularVelocity = Vector3.new(0, 0, 0)
                elseif angularObj.method == "BodyGyro" and angularObj.bodyGyro then
                    angularObj.bodyGyro.CFrame = part.CFrame
                elseif angularObj.method == "Torque" and angularObj.torqueForce then
                    angularObj.torqueForce.Torque = Vector3.new(0, 0, 0)
                elseif angularObj.method == "AssemblyAngularVelocity" then
                    part.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                end
            end
        end
    end)
    
