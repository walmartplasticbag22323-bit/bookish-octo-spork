            end
            activeKeybinds = {}
            nextKeybindId = 1
            
            -- Clean up all physics objects
            for part, physicsObj in pairs(keybindPhysicsObjects) do
                if physicsObj.bodyVel then physicsObj.bodyVel:Destroy() end
                if physicsObj.vectorForce then physicsObj.vectorForce:Destroy() end
                if physicsObj.attachment then physicsObj.attachment:Destroy() end
            end
            keybindPhysicsObjects = {}
            
            print("✅ Removed ALL keybinds and physics objects")
        end)
        
        -- NEW: Remove Binds from Selected Parts button
        local removeSelectedBindsBtn = createButton(panel, "Remove Binds from Selected", UDim2.new(1, -20, 0, 30), UDim2.new(0, 10, 1, -80))
        removeSelectedBindsBtn.BackgroundColor3 = Color3.fromRGB(180, 80, 30)
        removeSelectedBindsBtn.MouseButton1Click:Connect(function()
            local removedCount = 0
            
            -- Remove all keybinds associated with selected parts
            for id, data in pairs(activeKeybinds) do
                if data.partRef then
                    for _, selectedPart in ipairs(selectedParts) do
                        if data.partRef == selectedPart then
                            if data.connection then data.connection:Disconnect() end
                            if data.releaseConnection then data.releaseConnection:Disconnect() end
                            activeKeybinds[id] = nil
                            removedCount = removedCount + 1
                            break
                        end
                    end
                end
            end
            
            -- Clean up physics objects for selected parts
            for _, part in ipairs(selectedParts) do
                if keybindPhysicsObjects[part] then
                    local physicsObj = keybindPhysicsObjects[part]
                    if physicsObj.bodyVel then physicsObj.bodyVel:Destroy() end
                    if physicsObj.vectorForce then physicsObj.vectorForce:Destroy() end
                    if physicsObj.attachment then physicsObj.attachment:Destroy() end
                    keybindPhysicsObjects[part] = nil
                end
            end
            
            -- Remove velocity and angular controls from selected parts
            for _, part in ipairs(selectedParts) do
                if velocityControls[part] then
                    if type(velocityControls[part]) == "table" then
                        for _, control in pairs(velocityControls[part]) do
                            if type(control) == "table" then
                                if control.bodyVel then control.bodyVel:Destroy() end
                                if control.vectorForce then control.vectorForce:Destroy() end
                                if control.attachment then control.attachment:Destroy() end
                                if control.connection then control.connection:Disconnect() end
                                if control.keybindConnection then control.keybindConnection:Disconnect() end
                            end
                        end
                    end
                    velocityControls[part] = nil
                    removedCount = removedCount + 1
                end
                
                if angularControls[part] then
                    if angularControls[part].controls then
                        for _, control in pairs(angularControls[part].controls) do
                            if type(control) == "table" then
                                if control.bodyAngVel then control.bodyAngVel:Destroy() end
                                if control.bodyPosition then control.bodyPosition:Destroy() end
                                if control.bodyGyro then control.bodyGyro:Destroy() end
                                if control.attachment then control.attachment:Destroy() end
                                if control.torqueForce then control.torqueForce:Destroy() end
                                if control.weldConstraint then control.weldConstraint:Destroy() end
                                if control.anchorPart then control.anchorPart:Destroy() end
                                if control.connection then control.connection:Disconnect() end
                                if control.keybindConnection then control.keybindConnection:Disconnect() end
                                if control.hingeConstraint then
                                    pcall(function()
                                        control.hingeConstraint.ActuatorType = Enum.ActuatorType.None
                                        control.hingeConstraint.AngularVelocity = 0
                                    end)
                                end
                                if control.safetyConnection then control.safetyConnection:Disconnect() end
                            end
                        end
                    end
                    if angularControls[part].keybinds then
                        for _, keybind in pairs(angularControls[part].keybinds) do
                            if type(keybind) == "table" then
                                if keybind.connection then keybind.connection:Disconnect() end
                                if keybind.releaseConnection then keybind.releaseConnection:Disconnect() end
                                if keybind.updateConnection then keybind.updateConnection:Disconnect() end
                            end
                        end
                    end
                    angularControls[part] = nil
                    removedCount = removedCount + 1
                end
            end
            
            print("✅ Removed " .. removedCount .. " binds/controls from " .. #selectedParts .. " selected part(s)")
        end)
        
        local clearBtn = createButton(panel, "Clear Selection", UDim2.new(0.5, -5, 0, 30), UDim2.new(0, 10, 1, -40))
        clearBtn.MouseButton1Click:Connect(function() clearSelection() end)
