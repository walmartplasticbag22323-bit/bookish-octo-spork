    -- NEW: Realistic Settings System (APPLIES TO SELECTED PARTS ONLY!)
    local realisticSettings = {
        enabled = false,
        gyroscopicEffect = true,
        airResistance = true,
        spinLift = true,
        precession = true,
        centrifugalForce = true,
        magnusEffect = true
    }
    
    local realisticParts = {} -- Store parts with realistic physics applied
    
    local function applyRealisticToSelected()
        -- Apply to currently selected parts
        for _, part in ipairs(selectedParts) do
            if realisticParts[part] then
                -- Already has realistic physics, remove it
                if realisticParts[part].connection then
                    realisticParts[part].connection:Disconnect()
                end
                realisticParts[part] = nil
                print("❌ Removed realistic physics from " .. part.Name)
            else
                -- Add realistic physics to this part
                replicateToServer(function()
                    setNetworkOwnership(part)
                    
                    local connection = RunService.Heartbeat:Connect(function(dt)
                        if not part.Parent then
                            connection:Disconnect()
                            realisticParts[part] = nil
                            return
                        end
                        
                        local angVel = part.AssemblyAngularVelocity
                        local linVel = part.AssemblyLinearVelocity
                        
                        if angVel.Magnitude > 0.5 then
                            -- SPIN LIFT: Fast spinning = lift (like a frisbee)
                            if realisticSettings.gyroscopicEffect or realisticSettings.spinLift then
                                local spinSpeed = angVel.Magnitude
                                local liftForce = Vector3.new(0, spinSpeed * 0.5, 0)
                                part:ApplyImpulse(liftForce * part.Mass * dt)
                            end
                            
                            -- MAGNUS EFFECT: Spinning + moving = curve
                            if realisticSettings.magnusEffect and linVel.Magnitude > 2 then
                                local spinAxis = angVel.Unit
                                local velocityDir = linVel.Unit
                                local magnusForce = spinAxis:Cross(velocityDir) * angVel.Magnitude * 0.3
                                part:ApplyImpulse(magnusForce * part.Mass * dt)
                            end
                            
                            -- PRECESSION: Spinning = wobble
                            if realisticSettings.precession then
                                local wobble = Vector3.new(
                                    math.sin(tick() * angVel.Magnitude) * 0.1,
                                    0,
                                    math.cos(tick() * angVel.Magnitude) * 0.1
                                )
                                part.AssemblyAngularVelocity = angVel + wobble
                            end
                            
                            -- CENTRIFUGAL FORCE: Spin = outward push
                            if realisticSettings.centrifugalForce then
                                local centrifugal = angVel * 0.15
                                part:ApplyImpulse(Vector3.new(centrifugal.X, 0, centrifugal.Z) * part.Mass * dt)
                            end
                        end
                        
                        -- AIR RESISTANCE: Speed = drag
                        if realisticSettings.airResistance then
                            if linVel.Magnitude > 1 then
                                local dragForce = -linVel * 0.05 * linVel.Magnitude
                                part:ApplyImpulse(dragForce * part.Mass * dt)
                            end
                            
                            if angVel.Magnitude > 0.5 then
                                local angDrag = -angVel * 0.03 * angVel.Magnitude
                                part.AssemblyAngularVelocity = angVel + angDrag * dt
                            end
                        end
                    end)
                    
                    realisticParts[part] = {connection = connection}
                    print("✅ Applied realistic physics to " .. part.Name)
                end)
            end
        end
    end
    
