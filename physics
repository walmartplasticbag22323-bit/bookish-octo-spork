                bodyGyro.D = 100
                bodyGyro.P = 5000
                bodyGyro.Parent = part
                
                local time = 0
                
                local connection = RunService.RenderStepped:Connect(function(dt)
                    if not part.Parent then
                        connection:Disconnect()
                        return
                    end
                    
                    time = time + dt
                    
                    -- NO POSITION LOCKING - Let it move freely!
                    
                    -- Apply unstable rotation based on mode
                    local targetCFrame
                    
                    if mode == "Chaotic" then
                        -- Random rotation every frame
                        targetCFrame = CFrame.Angles(
                            math.random() * math.pi * 2,
                            math.random() * math.pi * 2,
                            math.random() * math.pi * 2
                        )
                        
                    elseif mode == "Glitchy" then
                        -- Snaps between random angles rapidly
                        if math.random() > 0.7 then
                            targetCFrame = CFrame.Angles(
                                math.random(0, 3) * (math.pi/2),
                                math.random(0, 3) * (math.pi/2),
                                math.random(0, 3) * (math.pi/2)
                            )
                        else
                            targetCFrame = bodyGyro.CFrame
                        end
                        
                    elseif mode == "Seizure" then
                        -- Extremely fast random rotation
                        targetCFrame = CFrame.Angles(
                            math.sin(time * 100 * intensity) * math.pi,
                            math.cos(time * 100 * intensity) * math.pi,
                            math.sin(time * 50 * intensity) * math.pi
                        )
                        
                    elseif mode == "Vibrate" then
                        -- Small jittery movements
                        local jitter = 0.1 * intensity
                        targetCFrame = bodyGyro.CFrame * CFrame.Angles(
                            (math.random() - 0.5) * jitter,
                            (math.random() - 0.5) * jitter,
                            (math.random() - 0.5) * jitter
                        )
                        
                    elseif mode == "Spinning Chaos" then
                        -- Spins wildly in all directions
                        targetCFrame = CFrame.Angles(
                            time * intensity * 5,
                            time * intensity * 3,
                            time * intensity * 7
                        ) * CFrame.Angles(
                            math.sin(time * 10) * 0.5,
                            math.cos(time * 15) * 0.5,
                            math.sin(time * 8) * 0.5
                        )
                    end
                    
                    bodyGyro.CFrame = CFrame.new(part.Position) * targetCFrame
                    
                    -- Force angular velocity to match the chaos
                    if mode == "Chaotic" or mode == "Seizure" then
                        part.AssemblyAngularVelocity = Vector3.new(
                            (math.random() - 0.5) * intensity * 10,
                            (math.random() - 0.5) * intensity * 10,
                            (math.random() - 0.5) * intensity * 10
                        )
                    end
                end)
                
                unstabilizedParts[part] = {
