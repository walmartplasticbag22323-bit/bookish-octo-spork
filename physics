_G.SentinelBodyControl = {}

-- Auto-detect limb type based on part name
local function detectLimbType(partName)
    local name = partName:lower()
    
    -- Arms
    if name:match("left") and (name:match("arm") or name:match("hand")) then
        return "LeftArm"
    elseif name:match("right") and (name:match("arm") or name:match("hand")) then
        return "RightArm"
    
    -- Legs
    elseif name:match("left") and (name:match("leg") or name:match("foot")) then
        return "LeftLeg"
    elseif name:match("right") and (name:match("leg") or name:match("foot")) then
        return "RightLeg"
    
    -- Head
    elseif name:match("head") then
        return "Head"
    
    -- Torso
    elseif name:match("torso") or name:match("chest") or name:match("body") then
        return "Torso"
    
    -- Default: Random
    else
        return "Random"
    end
end

-- Scan and map all constraints connected to a Sentinel part
function _G.SentinelBodyControl.scanBody(sentinelPart)
    local bodyMap = {
        core = sentinelPart,
        limbs = {},
        constraints = {},
        motors = {}
    }
    
    print("🔍 Scanning for motors/constraints in: " .. sentinelPart.Name)
    
    -- Find all Motor6D, HingeConstraint, BallSocketConstraint, etc.
    for _, child in ipairs(sentinelPart:GetChildren()) do
        local connectedPart = nil
        local constraintType = child.ClassName
        
        -- Check Motor6D (most common for character rigs)
        if child:IsA("Motor6D") or child:IsA("Motor") then
            print("  Found Motor6D: " .. child.Name)
            if child.Part0 == sentinelPart and child.Part1 then
                connectedPart = child.Part1
            elseif child.Part1 == sentinelPart and child.Part0 then
                connectedPart = child.Part0
            end
            
            if connectedPart and connectedPart:IsA("BasePart") then
                table.insert(bodyMap.limbs, {
                    part = connectedPart,
                    constraint = child,
                    type = "Motor6D",
                    motor = child,
                    limbType = detectLimbType(connectedPart.Name)
                })
                table.insert(bodyMap.motors, child)
                print("    ✅ Connected to: " .. connectedPart.Name .. " (Type: " .. detectLimbType(connectedPart.Name) .. ")")
            end
            
        -- Check HingeConstraint (uses attachments)
        elseif child:IsA("HingeConstraint") then
            print("  Found HingeConstraint: " .. child.Name)
            local attachment0 = child.Attachment0
            local attachment1 = child.Attachment1
            
            if attachment0 and attachment0.Parent == sentinelPart and attachment1 then
                connectedPart = attachment1.Parent
            elseif attachment1 and attachment1.Parent == sentinelPart and attachment0 then
                connectedPart = attachment0.Parent
            end
            
            if connectedPart and connectedPart:IsA("BasePart") then
                table.insert(bodyMap.limbs, {
                    part = connectedPart,
                    constraint = child,
                    attachment0 = attachment0,
                    attachment1 = attachment1,
                    type = "HingeConstraint",
                    limbType = detectLimbType(connectedPart.Name)
                })
                table.insert(bodyMap.constraints, child)
                print("    ✅ Connected to: " .. connectedPart.Name .. " (Type: " .. detectLimbType(connectedPart.Name) .. ")")
            end
            
        -- Check BallSocketConstraint (uses attachments)
        elseif child:IsA("BallSocketConstraint") then
            print("  Found BallSocketConstraint: " .. child.Name)
            local attachment0 = child.Attachment0
            local attachment1 = child.Attachment1
            
            if attachment0 and attachment0.Parent == sentinelPart and attachment1 then
                connectedPart = attachment1.Parent
            elseif attachment1 and attachment1.Parent == sentinelPart and attachment0 then
                connectedPart = attachment0.Parent
            end
            
            if connectedPart and connectedPart:IsA("BasePart") then
                table.insert(bodyMap.limbs, {
                    part = connectedPart,
                    constraint = child,
                    attachment0 = attachment0,
                    attachment1 = attachment1,
                    type = "BallSocketConstraint",
                    limbType = detectLimbType(connectedPart.Name)
                })
                table.insert(bodyMap.constraints, child)
                print("    ✅ Connected to: " .. connectedPart.Name .. " (Type: " .. detectLimbType(connectedPart.Name) .. ")")
            end
        end
    end
    
    print("🦾 Scan complete: " .. #bodyMap.limbs .. " limbs found")
    return bodyMap
end

-- Set limb type manually
function _G.SentinelBodyControl.setLimbType(sentinelName, limbIndex, limbType)
    local ai = _G.SentinelAI.instances[sentinelName]
    if not ai or not ai.bodyMap then
        warn("⚠️ Sentinel not found or not scanned: " .. sentinelName)
        return false
    end
    
    local limb = ai.bodyMap.limbs[limbIndex]
    if not limb then
        warn("⚠️ Limb " .. limbIndex .. " not found")
        return false
    end
    
    limb.limbType = limbType
    print("🦾 Limb " .. limbIndex .. " (" .. limb.part.Name .. ") set to: " .. limbType)
    return true
end

-- Initialize motor control for a Sentinel
function _G.SentinelBodyControl.initializeMotors(sentinelName, sentinelPart)
    local ai = _G.SentinelAI.initialize(sentinelName)
    
    -- Scan body structure
    local bodyMap = _G.SentinelBodyControl.scanBody(sentinelPart)
    
    -- Create motor control network (inputs: sensor data, outputs: motor commands)
    local inputCount = #bodyMap.limbs * 3 + 6 -- limb positions + core position/rotation
    local outputCount = #bodyMap.limbs * 2 -- motor power + direction for each limb
    
    ai.motorNetwork = NeuralNetwork.new(inputCount, math.max(10, inputCount), outputCount)
    ai.bodyMap = bodyMap
    ai.motorMemory = {}
    
    print("🧠 Motor control initialized: " .. inputCount .. " inputs → " .. outputCount .. " outputs")
    return ai
end

-- Get current body state as input vector
function _G.SentinelBodyControl.getBodyState(bodyMap)
    local state = {}
    
    -- Core position and rotation
    local core = bodyMap.core
    table.insert(state, core.Position.X / 100)
    table.insert(state, core.Position.Y / 100)
    table.insert(state, core.Position.Z / 100)
    table.insert(state, core.Orientation.X / 180)
    table.insert(state, core.Orientation.Y / 180)
    table.insert(state, core.Orientation.Z / 180)
    
    -- Limb positions relative to core
    for _, limb in ipairs(bodyMap.limbs) do
        local relativePos = limb.part.Position - core.Position
        table.insert(state, relativePos.X / 10)
        table.insert(state, relativePos.Y / 10)
        table.insert(state, relativePos.Z / 10)
    end
    
    return state
end

-- Apply motor commands to limbs
function _G.SentinelBodyControl.applyMotorCommands(bodyMap, commands)
    for i, limb in ipairs(bodyMap.limbs) do
        local powerIndex = (i - 1) * 2 + 1
        local directionIndex = (i - 1) * 2 + 2
        
        if commands[powerIndex] and commands[directionIndex] then
            local power = commands[powerIndex] * 100 -- Scale to reasonable force
            local direction = commands[directionIndex] * 2 - 1 -- Convert to -1 to 1
            
            -- Apply force based on constraint type
            if limb.constraint:IsA("Motor6D") then
                -- Motor6D uses C0/C1 CFrame offsets for rotation
                local currentC0 = limb.constraint.C0
                local rotationAngle = direction * power * 0.01 -- Scale rotation
                -- Rotate around Y axis (can be customized per limb)
                local rotation = CFrame.Angles(0, rotationAngle, 0)
                limb.constraint.C0 = currentC0 * rotation
                
            elseif limb.constraint:IsA("HingeConstraint") then
                limb.constraint.MotorMaxTorque = math.abs(power)
                limb.constraint.AngularVelocity = direction * 5
                
            elseif limb.constraint:IsA("BallSocketConstraint") then
                -- For ball socket, apply torque in multiple axes
                if limb.part:FindFirstChild("BodyAngularVelocity") then
                    limb.part.BodyAngularVelocity.AngularVelocity = Vector3.new(
                        direction * power * 0.1,
                        direction * power * 0.1,
                        direction * power * 0.1
                    )
                end
            end
        end
    end
end

-- Run one motor control cycle
function _G.SentinelBodyControl.controlCycle(sentinelName, goal)
    local ai = _G.SentinelAI[sentinelName]
    if not ai or not ai.motorNetwork or not ai.bodyMap then
        warn("⚠️ Motor control not initialized for " .. sentinelName)
        return
    end
    
    -- Get current body state
    local bodyState = _G.SentinelBodyControl.getBodyState(ai.bodyMap)
    
    -- Add goal to input (what the sentinel is trying to do)
    if goal then
        table.insert(bodyState, goal.x or 0)
        table.insert(bodyState, goal.y or 0)
        table.insert(bodyState, goal.z or 0)
    end
    
    -- Run through neural network to get motor commands
    local motorCommands = ai.motorNetwork:forward(bodyState)
    
    -- Apply commands to limbs
    _G.SentinelBodyControl.applyMotorCommands(ai.bodyMap, motorCommands)
    
    -- Store experience for learning
    table.insert(ai.motorMemory, {
        state = bodyState,
        commands = motorCommands,
        goal = goal,
        timestamp = tick()
    })
    
    -- Keep memory manageable
    if #ai.motorMemory > 1000 then
        table.remove(ai.motorMemory, 1)
    end
end

-- Train motor control based on success/failure
function _G.SentinelBodyControl.trainMotors(sentinelName, success, reward)
    local ai = _G.SentinelAI[sentinelName]
    if not ai or not ai.motorNetwork then return end
    
    reward = reward or (success and 1.0 or -0.5)
    
    -- Get recent motor memory
    local recentMemory = {}
    for i = math.max(1, #ai.motorMemory - 10), #ai.motorMemory do
        table.insert(recentMemory, ai.motorMemory[i])
    end
    
    -- Train network on recent experiences
    for _, memory in ipairs(recentMemory) do
        local targetOutput = {}
        for i, cmd in ipairs(memory.commands) do
            -- Adjust commands based on reward
            targetOutput[i] = cmd + (reward * 0.1 * (math.random() - 0.5))
            targetOutput[i] = math.max(0, math.min(1, targetOutput[i])) -- Clamp
        end
        
        ai.motorNetwork:backward(memory.state, targetOutput, 0.01)
    end
    
    print("🎓 Motor training: " .. (success and "SUCCESS" or "FAILURE") .. " | Reward: " .. reward)
end

-- Auto-control loop for a Sentinel
function _G.SentinelBodyControl.startAutoControl(sentinelName, sentinelPart, goalFunction)
    -- Initialize if not already done
    if not _G.SentinelAI[sentinelName] or not _G.SentinelAI[sentinelName].motorNetwork then
        _G.SentinelBodyControl.initializeMotors(sentinelName, sentinelPart)
    end
    
    -- Start control loop
    spawn(function()
        while sentinelPart and sentinelPart.Parent do
            local goal = goalFunction and goalFunction() or {x = 0, y = 0, z = 0}
            _G.SentinelBodyControl.controlCycle(sentinelName, goal)
            wait(0.1) -- 10 Hz control rate
        end
    end)
    
    print("🎮 Auto-control started for " .. sentinelName)
end

-- Manual command: Move limb
function _G.SentinelBodyControl.moveLimb(sentinelName, limbIndex, power, direction)
    local ai = _G.SentinelAI[sentinelName]
    if not ai or not ai.bodyMap then return end
    
    local limb = ai.bodyMap.limbs[limbIndex]
    if not limb then
        warn("⚠️ Limb " .. limbIndex .. " not found")
        return
    end
    
    if limb.constraint:IsA("Motor6D") then
        -- Motor6D uses C0/C1 CFrame offsets for rotation
        local currentC0 = limb.constraint.C0
        local rotationAngle = direction * 0.1 -- Scale rotation
        -- Rotate around Y axis (can be customized per limb)
        local rotation = CFrame.Angles(0, rotationAngle, 0)
        limb.constraint.C0 = currentC0 * rotation
        print("🦾 Limb " .. limbIndex .. " (Motor6D) moving: power=" .. power .. ", dir=" .. direction)
        
    elseif limb.constraint:IsA("HingeConstraint") then
        limb.constraint.MotorMaxTorque = math.abs(power)
        limb.constraint.AngularVelocity = direction
        print("🦾 Limb " .. limbIndex .. " (Hinge) moving: power=" .. power .. ", dir=" .. direction)
        
    elseif limb.constraint:IsA("BallSocketConstraint") then
        -- For ball socket, apply torque in multiple axes
        if not limb.part:FindFirstChild("BodyAngularVelocity") then
            local bav = Instance.new("BodyAngularVelocity")
            bav.MaxTorque = Vector3.new(4000, 4000, 4000)
            bav.Parent = limb.part
        end
        limb.part.BodyAngularVelocity.AngularVelocity = Vector3.new(
            direction * power * 0.1,
            direction * power * 0.1,
            direction * power * 0.1
        )
        print("🦾 Limb " .. limbIndex .. " (BallSocket) moving: power=" .. power .. ", dir=" .. direction)
    end
end

-- Get body info
function _G.SentinelBodyControl.getBodyInfo(sentinelName)
    local ai = _G.SentinelAI[sentinelName]
    if not ai or not ai.bodyMap then
        return "No body mapped"
    end
    
    local info = "🦾 Sentinel Body:\n"
    info = info .. "Core: " .. ai.bodyMap.core.Name .. "\n"
    info = info .. "Limbs: " .. #ai.bodyMap.limbs .. "\n\n"
    
    for i, limb in ipairs(ai.bodyMap.limbs) do
        info = info .. "  " .. i .. ". " .. limb.part.Name .. "\n"
        info = info .. "     Type: " .. limb.limbType .. " (" .. limb.type .. ")\n"
    end
    
    return info
end

