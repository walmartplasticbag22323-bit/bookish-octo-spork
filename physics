            -- Start function (Part 1 - Setup)
            local function startPartControl()
                if #selectedParts == 0 then
                    statusLabel.Text = "Status: No part selected!"
                    statusLabel.BackgroundColor3 = Color3.fromRGB(150, 50, 50)
                    task.wait(2)
                    statusLabel.Text = "Status: Inactive"
                    statusLabel.BackgroundColor3 = Color3.fromRGB(60, 60, 70)
                    return
                end
                
                local part = selectedParts[1]
                if not part or not part.Parent then
                    statusLabel.Text = "Status: Invalid part!"
                    statusLabel.BackgroundColor3 = Color3.fromRGB(150, 50, 50)
                    return
                end
                
                partControllerActive = true
                partControllerData.controlledPart = part
                partControllerData.shapeType = shapeDropdown.Text
                partControllerData.stepRotation = part.CFrame - part.CFrame.Position
                
                -- Set up physics
                replicateToServer(function()
                    setNetworkOwnership(part)
                    
                    -- Create BodyAngularVelocity for torque-based rolling
                    local bodyAngularVelocity = Instance.new("BodyAngularVelocity")
                    bodyAngularVelocity.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
                    bodyAngularVelocity.AngularVelocity = Vector3.new(0, 0, 0)
                    bodyAngularVelocity.Parent = part
                    partControllerData.bodyAngularVelocity = bodyAngularVelocity
                    
                    -- Create BodyVelocity for fly mode (will be enabled/disabled as needed)
                    local bodyVelocity = Instance.new("BodyVelocity")
                    bodyVelocity.MaxForce = Vector3.new(0, 0, 0) -- Disabled by default
                    bodyVelocity.Velocity = Vector3.new(0, 0, 0)
                    bodyVelocity.Parent = part
                    partControllerData.bodyVelocity = bodyVelocity
                    
                    -- Create BodyGyro for fly mode camera orientation
                    local bodyGyro = Instance.new("BodyGyro")
                    bodyGyro.MaxTorque = Vector3.new(0, 0, 0) -- Disabled by default
                    bodyGyro.D = partControllerData.gyroD
                    bodyGyro.P = partControllerData.gyroP
                    bodyGyro.CFrame = part.CFrame
                    bodyGyro.Parent = part
                    partControllerData.bodyGyro = bodyGyro
                end)
                
                -- Determine shape for rolling physics
                local shapeType = partControllerData.shapeType
                if shapeType == "Auto" then
                    if part:IsA("Part") then
                        if part.Shape == Enum.PartType.Ball then
                            shapeType = "Sphere"
                        elseif part.Shape == Enum.PartType.Cylinder then
                            shapeType = "Cylinder"
                        else
                            shapeType = "Cube"
                        end
                    else
                        shapeType = "Cube"
                    end
                end
                
                -- Set up camera (SIMPLE - let Roblox handle it!)
                local camera = workspace.CurrentCamera
                partControllerData.originalCameraType = camera.CameraType
                partControllerData.originalCameraSubject = camera.CameraSubject
                
                -- Set camera based on delayed camera setting
                if not partControllerData.delayedCamera then
                    -- Immediate camera lock - Roblox handles rotation/zoom/everything!
                    camera.CameraType = Enum.CameraType.Custom
                    camera.CameraSubject = part
                    print("📷 Camera locked to part - use mouse to look around!")
                else
                    -- Delayed camera - will smoothly transition after a moment
                    task.spawn(function()
                        task.wait(0.5)
                        if partControllerActive and part and part.Parent then
                            camera.CameraType = Enum.CameraType.Custom
                            camera.CameraSubject = part
                            print("📷 Camera smoothly locked to part!")
                        end
                    end)
                end
                
                -- Control loop
                local keysPressed = {}
                local shiftLockEnabled = false
                
                -- Create jump charge bar (BillboardGui attached to part)
                local jumpChargeGui = Instance.new("BillboardGui")
                jumpChargeGui.Name = "JumpChargeBar"
                jumpChargeGui.Adornee = part
                jumpChargeGui.Size = UDim2.new(4, 0, 0.5, 0)
                jumpChargeGui.StudsOffset = Vector3.new(0, part.Size.Y / 2 + 2, 0)
                jumpChargeGui.AlwaysOnTop = true
                jumpChargeGui.Parent = part
                
                local barBackground = Instance.new("Frame")
                barBackground.Size = UDim2.new(1, 0, 1, 0)
                barBackground.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
                barBackground.BorderSizePixel = 2
                barBackground.BorderColor3 = Color3.fromRGB(255, 255, 255)
                barBackground.Parent = jumpChargeGui
                
                local barFill = Instance.new("Frame")
                barFill.Size = UDim2.new(0, 0, 1, 0)
                barFill.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
                barFill.BorderSizePixel = 0
                barFill.Parent = barBackground
                
                local barLabel = Instance.new("TextLabel")
                barLabel.Size = UDim2.new(1, 0, 1, 0)
                barLabel.BackgroundTransparency = 1
                barLabel.Text = "JUMP: 0%"
                barLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
                barLabel.TextScaled = true
                barLabel.Font = Enum.Font.GothamBold
                barLabel.Parent = barBackground
                
                jumpChargeGui.Enabled = false -- Hidden by default
                
                UserInputService.InputBegan:Connect(function(input, gameProcessed)
                    if gameProcessed or not partControllerActive then return end
                    
                    if input.KeyCode == Enum.KeyCode.LeftShift or input.KeyCode == Enum.KeyCode.RightShift then
                        shiftLockEnabled = not shiftLockEnabled
                    end
                    
                    -- Start charging jump when Space is pressed (only in roll mode)
                    if input.KeyCode == Enum.KeyCode.Space and not partControllerData.flyMode then
                        partControllerData.isChargingJump = true
                        partControllerData.jumpCharge = 0
                        jumpChargeGui.Enabled = true
                    end
                    
                    keysPressed[input.KeyCode] = true
                end)
                
                UserInputService.InputEnded:Connect(function(input)
                    keysPressed[input.KeyCode] = false
                    
                    -- Release jump when Space is released
                    if input.KeyCode == Enum.KeyCode.Space and partControllerData.isChargingJump then
                        partControllerData.isChargingJump = false
                        jumpChargeGui.Enabled = false
                        
                        -- Apply jump force based on charge
                        local jumpPower = partControllerData.jumpCharge * 100 -- Max jump power
                        if jumpPower > 5 then -- Minimum threshold
                            local jumpVelocity = Vector3.new(0, jumpPower, 0)
                            part.AssemblyLinearVelocity = part.AssemblyLinearVelocity + jumpVelocity
                            print("🦘 Jump! Power: " .. math.floor(partControllerData.jumpCharge * 100) .. "%")
                        end
                        
                        partControllerData.jumpCharge = 0
                    end
                end)
                
                partControllerData.controlConnection = RunService.Heartbeat:Connect(function(dt)
                    if not part or not part.Parent or not partControllerActive then
                        stopPartControl()
                        return
                    end
                    
                    local bodyAngularVelocity = partControllerData.bodyAngularVelocity
                    local bodyVelocity = partControllerData.bodyVelocity
                    local bodyGyro = partControllerData.bodyGyro
                    
                    if not bodyAngularVelocity or not bodyVelocity or not bodyGyro then return end
                    
                    -- Update jump charge (oscillates like fishing rod)
                    if partControllerData.isChargingJump then
                        -- Oscillate between 0 and 1 using sine wave (2 second cycle)
                        local oscillationSpeed = 2 -- Full cycle every 2 seconds
                        partControllerData.jumpCharge = (math.sin(tick() * math.pi * oscillationSpeed) + 1) / 2
                        
                        -- Update bar visual
                        barFill.Size = UDim2.new(partControllerData.jumpCharge, 0, 1, 0)
                        barLabel.Text = "JUMP: " .. math.floor(partControllerData.jumpCharge * 100) .. "%"
                        
                        -- Color changes based on charge (green -> yellow -> red)
                        if partControllerData.jumpCharge < 0.33 then
                            barFill.BackgroundColor3 = Color3.fromRGB(50, 200, 50) -- Green
                        elseif partControllerData.jumpCharge < 0.66 then
                            barFill.BackgroundColor3 = Color3.fromRGB(200, 200, 50) -- Yellow
                        else
                            barFill.BackgroundColor3 = Color3.fromRGB(200, 50, 50) -- Red
                        end
                    end
                    
                    local camera = workspace.CurrentCamera
                    local cameraCFrame = camera.CFrame
                    
                    -- Step mode - TFGH for 90 degree rolls
                    if partControllerData.stepMode then
                        if keysPressed[Enum.KeyCode.T] then
                            partControllerData.stepRotation = partControllerData.stepRotation * CFrame.Angles(math.rad(-90), 0, 0)
                            keysPressed[Enum.KeyCode.T] = false
                            task.wait(0.3)
                        elseif keysPressed[Enum.KeyCode.F] then
                            partControllerData.stepRotation = partControllerData.stepRotation * CFrame.Angles(math.rad(90), 0, 0)
                            keysPressed[Enum.KeyCode.F] = false
                            task.wait(0.3)
                        elseif keysPressed[Enum.KeyCode.G] then
                            partControllerData.stepRotation = partControllerData.stepRotation * CFrame.Angles(0, 0, math.rad(90))
                            keysPressed[Enum.KeyCode.G] = false
                            task.wait(0.3)
                        elseif keysPressed[Enum.KeyCode.H] then
                            partControllerData.stepRotation = partControllerData.stepRotation * CFrame.Angles(0, 0, math.rad(-90))
                            keysPressed[Enum.KeyCode.H] = false
                            task.wait(0.3)
                        end
                        
                        -- In step mode, disable rolling and use AlignOrientation (TODO: implement)
                        bodyAngularVelocity.AngularVelocity = Vector3.new(0, 0, 0)
                        bodyVelocity.MaxForce = Vector3.new(0, 0, 0)
                        bodyGyro.MaxTorque = Vector3.new(0, 0, 0)
                        
                    else
                        -- Normal rolling mode
                        local moveDirection = Vector3.new(0, 0, 0)
                        
                        if keysPressed[Enum.KeyCode.W] then
                            moveDirection = moveDirection + cameraCFrame.LookVector
                        end
                        if keysPressed[Enum.KeyCode.S] then
                            moveDirection = moveDirection - cameraCFrame.LookVector
                        end
                        if keysPressed[Enum.KeyCode.A] then
                            moveDirection = moveDirection - cameraCFrame.RightVector
                        end
                        if keysPressed[Enum.KeyCode.D] then
                            moveDirection = moveDirection + cameraCFrame.RightVector
                        end
                        
                        if partControllerData.flyMode then
                            if keysPressed[Enum.KeyCode.Space] then
                                moveDirection = moveDirection + Vector3.new(0, 1, 0)
                            end
                            if keysPressed[Enum.KeyCode.LeftControl] or keysPressed[Enum.KeyCode.RightControl] then
                                moveDirection = moveDirection - Vector3.new(0, 1, 0)
                            end
                        end
                        
                        if moveDirection.Magnitude > 0 then
                            moveDirection = moveDirection.Unit
                            
                            local rollSpeed = partControllerData.rollSpeed
                            
                            -- Pure Velocity Mode - Direct velocity control without physics
                            if partControllerData.pureVelocity then
                                part.AssemblyLinearVelocity = moveDirection * rollSpeed
                                bodyAngularVelocity.AngularVelocity = Vector3.new(0, 0, 0)
                                bodyVelocity.MaxForce = Vector3.new(0, 0, 0)
                                bodyGyro.MaxTorque = Vector3.new(0, 0, 0)
                            elseif partControllerData.flyMode then
                                -- Fly mode: Use BodyVelocity + BodyGyro for camera-oriented flight
                                if partControllerData.noHoverMode then
                                    -- No Hover Mode: Only control X and Z axes, let gravity handle Y
                                    bodyVelocity.MaxForce = Vector3.new(1e5, 0, 1e5) -- No Y-axis force
                                    bodyVelocity.Velocity = Vector3.new(moveDirection.X * rollSpeed, 0, moveDirection.Z * rollSpeed)
                                else
                                    -- Normal Fly Mode: Full 3D control
                                    bodyVelocity.MaxForce = Vector3.new(1e5, 1e5, 1e5)
                                    bodyVelocity.Velocity = moveDirection * rollSpeed
                                end
                                bodyAngularVelocity.AngularVelocity = Vector3.new(0, 0, 0)
                                
                                -- Orient part to face camera direction (update P/D values dynamically)
                                bodyGyro.P = partControllerData.gyroP
                                bodyGyro.D = partControllerData.gyroD
                                bodyGyro.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
                                bodyGyro.CFrame = cameraCFrame
                            else
                                -- Roll mode: Use BodyAngularVelocity for torque-based rolling
                                bodyVelocity.MaxForce = Vector3.new(0, 0, 0) -- Disable fly mode
                                bodyGyro.MaxTorque = Vector3.new(0, 0, 0) -- Disable gyro
                                
                                -- Calculate roll axis (perpendicular to movement direction)
                                local rollAxis = Vector3.new(moveDirection.Z, 0, -moveDirection.X)
                                
                                -- Calculate radius based on shape
                                local radius
                                if shapeType == "Sphere" then
                                    radius = part.Size.Magnitude / 2
                                elseif shapeType == "Cylinder" then
                                    radius = math.max(part.Size.X, part.Size.Z) / 2
                                elseif shapeType == "Cube" then
                                    radius = part.Size.Magnitude / 3
                                else
                                    radius = part.Size.Magnitude / 2
                                end
                                
                                -- Calculate angular speed: v = ω * r → ω = v / r
                                -- Multiply by torqueMultiplier for more visible rolling
                                local angularSpeed = (rollSpeed * partControllerData.torqueMultiplier) / radius
                                
                                -- Apply angular velocity
                                bodyAngularVelocity.AngularVelocity = rollAxis * angularSpeed
                            end
                        else
                            -- No movement
                            if partControllerData.flyMode then
                                -- In fly mode, keep hovering (zero velocity but keep forces active)
                                if partControllerData.noHoverMode then
                                    -- No Hover Mode: Only control X and Z axes, let gravity handle Y
                                    bodyVelocity.MaxForce = Vector3.new(1e5, 0, 1e5) -- No Y-axis force
                                else
                                    -- Normal Fly Mode: Full 3D control
                                    bodyVelocity.MaxForce = Vector3.new(1e5, 1e5, 1e5)
                                end
                                bodyVelocity.Velocity = Vector3.new(0, 0, 0)
                                bodyAngularVelocity.AngularVelocity = Vector3.new(0, 0, 0)
                                -- Update BodyGyro P/D values dynamically
                                bodyGyro.P = partControllerData.gyroP
                                bodyGyro.D = partControllerData.gyroD
                                bodyGyro.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
                                bodyGyro.CFrame = cameraCFrame
                            elseif partControllerData.pureVelocity then
                                -- Pure velocity mode - stop movement
                                part.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                                bodyAngularVelocity.AngularVelocity = Vector3.new(0, 0, 0)
                                bodyVelocity.MaxForce = Vector3.new(0, 0, 0)
                                bodyGyro.MaxTorque = Vector3.new(0, 0, 0)
                            else
                                -- Roll mode - stop
                                bodyAngularVelocity.AngularVelocity = Vector3.new(0, 0, 0)
                                bodyVelocity.MaxForce = Vector3.new(0, 0, 0)
                                bodyGyro.MaxTorque = Vector3.new(0, 0, 0)
                            end
                        end
                        
                        -- No Rotation Mode - Lock rotation
                        if partControllerData.noRotation then
                            bodyAngularVelocity.AngularVelocity = Vector3.new(0, 0, 0)
                            part.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                        end
                    end
                    
                    -- Update status
                    local modeText = partControllerData.flyMode and "FLY" or "ROLL"
                    if partControllerData.stepMode then modeText = "STEP" end
                    if partControllerData.pureVelocity then modeText = "PURE VEL" end
                    if partControllerData.noRotation then modeText = modeText .. " | NO ROT" end
                    statusLabel.Text = "Status: Active (" .. modeText .. " | " .. shapeType .. ")"
                end)
                
                statusLabel.Text = "Status: Active (" .. shapeType .. ")"
                statusLabel.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
                controlBtn.Text = "⏹️ STOP CONTROL"
                controlBtn.BackgroundColor3 = Color3.fromRGB(150, 50, 50)
                
                print("🎮 Part control started on " .. part.Name)
            end
            
