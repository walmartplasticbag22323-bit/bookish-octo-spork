    -- NEW: Drag selection box system
    local dragSelectionActive = false
    local dragStartPos = nil
    local dragSelectionBox = nil
    local dragConnection = nil
    
    local function createDragSelectionBox(startPos, endPos)
        if dragSelectionBox then
            dragSelectionBox:Destroy()
        end
        
        -- Calculate size and position
        local minX = math.min(startPos.X, endPos.X)
        local minY = math.min(startPos.Y, endPos.Y)
        local width = math.abs(endPos.X - startPos.X)
        local height = math.abs(endPos.Y - startPos.Y)
        
        -- Create visual selection box on screen
        dragSelectionBox = Instance.new("Frame")
        dragSelectionBox.Size = UDim2.new(0, width, 0, height)
        dragSelectionBox.Position = UDim2.new(0, minX, 0, minY)
        dragSelectionBox.BackgroundColor3 = Color3.fromRGB(70, 130, 180)
        dragSelectionBox.BackgroundTransparency = 0.7
        dragSelectionBox.BorderSizePixel = 2
        dragSelectionBox.BorderColor3 = Color3.fromRGB(0, 200, 255)
        dragSelectionBox.ZIndex = 10
        dragSelectionBox.Parent = screenGui
    end
    
    local function getPartsInDragBox(startPos, endPos)
        local camera = workspace.CurrentCamera
        local selectedPartsInBox = {}
        
        -- Get all parts in workspace
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") and obj.Parent ~= player.Character then
                -- Project 3D position to 2D screen
                local screenPos, onScreen = camera:WorldToViewportPoint(obj.Position)
                
                if onScreen then
                    local minX = math.min(startPos.X, endPos.X)
                    local maxX = math.max(startPos.X, endPos.X)
                    local minY = math.min(startPos.Y, endPos.Y)
                    local maxY = math.max(startPos.Y, endPos.Y)
                    
                    -- Check if part's screen position is inside drag box
                    if screenPos.X >= minX and screenPos.X <= maxX and 
                       screenPos.Y >= minY and screenPos.Y <= maxY then
                        table.insert(selectedPartsInBox, obj)
                    end
                end
            end
        end
        
        return selectedPartsInBox
    end

