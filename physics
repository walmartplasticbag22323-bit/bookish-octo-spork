-- Initialize AI for a Sentinel
function _G.SentinelAI.initialize(sentinelName)
    if not _G.SentinelAI[sentinelName] then
        _G.SentinelAI[sentinelName] = {
            network = NeuralNetwork.new(20, 15, 5), -- 20 input, 15 hidden, 5 output neurons
            vocabulary = {"hello", "hi", "status", "help", "attack", "fire", "thanks", "bye", "you", "how", 
                         "what", "can", "do", "are", "okay", "working", "assist", "target", "engage", "shoot"},
            experienceBuffer = {},
            chatHistory = {},
            learningEnabled = true
        }
        print("🤖 AI initialized for " .. sentinelName)
    end
    return _G.SentinelAI[sentinelName]
end

-- Generate AI response
function _G.SentinelAI.generateResponse(sentinelName, userInput)
    local ai = _G.SentinelAI.initialize(sentinelName)
    
    -- 🔥 DETECT CATEGORY AND GENERATE UNIQUE SENTENCE
    local category = detectCategory(userInput)
    local response = SentenceGenerator.generate(category, ai)
    
    -- Store in chat history
    table.insert(ai.chatHistory, {
        input = userInput,
        response = response,
        category = category,
        timestamp = tick()
    })
    
    -- Keep only last 50 messages
    if #ai.chatHistory > 50 then
        table.remove(ai.chatHistory, 1)
    end
    
    -- Convert to vector and run through neural network (for learning)
    if ai.learningEnabled then
        local inputVector = textToVector(userInput, ai.vocabulary)
        local outputs = ai.network:forward(inputVector)
        
        -- Store experience for replay learning
        table.insert(ai.experienceBuffer, {
            input = inputVector,
            response = response,
            outputs = outputs
        })
        
        -- Keep buffer size manageable
        if #ai.experienceBuffer > 100 then
            table.remove(ai.experienceBuffer, 1)
        end
    end
    
    return response
end

-- Train the AI with feedback
function _G.SentinelAI.trainWithFeedback(sentinelName, userInput, correctResponse, rating)
    local ai = _G.SentinelAI[sentinelName]
    if not ai then return end
    
    rating = rating or 1.0 -- 0.0 to 1.0
    
    local inputVector = textToVector(userInput, ai.vocabulary)
    local targetOutput = {}
    
    -- Create target output based on rating
    for i = 1, ai.network.outputSize do
        targetOutput[i] = rating
    end
    
    -- Train the network
    ai.network:train(inputVector, targetOutput, 0.1)
    
    print("✅ AI trained for " .. sentinelName .. " (Rating: " .. rating .. ")")
end

-- Experience replay learning (background learning)
function _G.SentinelAI.replayLearning(sentinelName, iterations)
    local ai = _G.SentinelAI[sentinelName]
    if not ai or #ai.experienceBuffer == 0 then return end
    
    iterations = iterations or 10
    
    for i = 1, iterations do
        local experience = ai.experienceBuffer[math.random(1, #ai.experienceBuffer)]
        local targetOutput = {}
        
        -- Use previous outputs as targets (self-supervised learning)
        for j = 1, #experience.outputs do
            targetOutput[j] = experience.outputs[j]
        end
        
        ai.network:train(experience.input, targetOutput, 0.05)
    end
end

