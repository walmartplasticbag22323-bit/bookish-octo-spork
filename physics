        if sentinelParts[part] then
            return sentinelParts[part]
        end
        return nil
    end
    
    -- NEW: Fun Mode - Biblically Accurate Angel Animation
    local funModeActive = false
    local funModeConnections = {}
    
    local function applyFunMode(character)
        if not character then return end
        
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if not humanoid then return end
        
        -- Only works on R6
        local torso = character:FindFirstChild("Torso")
        if not torso then
            warn("Fun Mode only works on R6!")
            return
        end
        
        local limbs = {
            character:FindFirstChild("Left Arm"),
            character:FindFirstChild("Right Arm"),
            character:FindFirstChild("Left Leg"),
            character:FindFirstChild("Right Leg")
        }
        
        -- Store original motor6ds
        local motors = {}
        for _, limb in ipairs(limbs) do
            if limb then
                for _, motor in ipairs(torso:GetChildren()) do
                    if motor:IsA("Motor6D") and motor.Part1 == limb then
                        table.insert(motors, {motor = motor, part = limb, c0 = motor.C0, c1 = motor.C1})
                    end
                end
            end
        end
        
        -- Create orbital animation
        local angle = 0
        local connection = RunService.Heartbeat:Connect(function(dt)
            if not character.Parent or not toolSettings.funModeEnabled then
                connection:Disconnect()
                -- Restore original positions
                for _, data in ipairs(motors) do
                    if data.motor.Parent then
                        data.motor.C0 = data.c0
                        data.motor.C1 = data.c1
                    end
                end
                return
            end
            
            angle = angle + (dt * 3)
            
            for i, data in ipairs(motors) do
                if data.motor.Parent and data.part.Parent then
                    local offset = (i - 1) * (math.pi / 2)
                    local radius = 3
                    local x = math.cos(angle + offset) * radius
                    local z = math.sin(angle + offset) * radius
                    local y = math.sin(angle * 2 + offset) * 1.5
                    
                    -- Animate using Motor6D C0
                    data.motor.C0 = data.c0 * CFrame.new(x, y, z) * CFrame.Angles(angle, angle * 0.5, 0)
                end
            end
        end)
        
        table.insert(funModeConnections, connection)
    end
    
    local function toggleFunMode()
        toolSettings.funModeEnabled = not toolSettings.funModeEnabled
        
        if toolSettings.funModeEnabled then
            -- Apply to player
            if player.Character then
                applyFunMode(player.Character)
            end
            
            -- Apply to future respawns
            player.CharacterAdded:Connect(function(char)
                if toolSettings.funModeEnabled then
                    task.wait(1)
                    applyFunMode(char)
                end
            end)
            
            print("👼 Fun Mode: ON - Biblically Accurate Angel Animation!")
        else
            -- Disable all
            for _, conn in ipairs(funModeConnections) do
                if conn then conn:Disconnect() end
            end
            funModeConnections = {}
            
            print("Fun Mode: OFF")
        end
    end

