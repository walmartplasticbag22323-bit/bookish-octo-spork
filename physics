-- Neural Network Module
local NeuralNetwork = {}
NeuralNetwork.__index = NeuralNetwork

function NeuralNetwork.new(inputSize, hiddenSize, outputSize)
    local self = setmetatable({}, NeuralNetwork)
    self.inputSize = inputSize
    self.hiddenSize = hiddenSize
    self.outputSize = outputSize
    
    -- Initialize weights randomly
    self.weightsInputHidden = {}
    self.weightsHiddenOutput = {}
    
    for i = 1, inputSize do
        self.weightsInputHidden[i] = {}
        for j = 1, hiddenSize do
            self.weightsInputHidden[i][j] = math.random() * 2 - 1
        end
    end
    
    for i = 1, hiddenSize do
        self.weightsHiddenOutput[i] = {}
        for j = 1, outputSize do
            self.weightsHiddenOutput[i][j] = math.random() * 2 - 1
        end
    end
    
    self.biasHidden = {}
    self.biasOutput = {}
    for i = 1, hiddenSize do
        self.biasHidden[i] = math.random() * 2 - 1
    end
    for i = 1, outputSize do
        self.biasOutput[i] = math.random() * 2 - 1
    end
    
    return self
end

function NeuralNetwork:sigmoid(x)
    return 1 / (1 + math.exp(-x))
end

function NeuralNetwork:sigmoidDerivative(x)
    return x * (1 - x)
end

function NeuralNetwork:forward(inputs)
    -- Input to hidden
    local hidden = {}
    for j = 1, self.hiddenSize do
        local sum = self.biasHidden[j]
        for i = 1, self.inputSize do
            sum = sum + inputs[i] * self.weightsInputHidden[i][j]
        end
        hidden[j] = self:sigmoid(sum)
    end
    
    -- Hidden to output
    local outputs = {}
    for j = 1, self.outputSize do
        local sum = self.biasOutput[j]
        for i = 1, self.hiddenSize do
            sum = sum + hidden[i] * self.weightsHiddenOutput[i][j]
        end
        outputs[j] = self:sigmoid(sum)
    end
    
    return outputs, hidden
end

function NeuralNetwork:train(inputs, targetOutputs, learningRate)
    learningRate = learningRate or 0.1
    
    -- Forward pass
    local outputs, hidden = self:forward(inputs)
    
    -- Calculate output errors
    local outputErrors = {}
    for i = 1, self.outputSize do
        outputErrors[i] = targetOutputs[i] - outputs[i]
    end
    
    -- Calculate hidden errors
    local hiddenErrors = {}
    for i = 1, self.hiddenSize do
        local error = 0
        for j = 1, self.outputSize do
            error = error + outputErrors[j] * self.weightsHiddenOutput[i][j]
        end
        hiddenErrors[i] = error
    end
    
    -- Update weights hidden to output
    for i = 1, self.hiddenSize do
        for j = 1, self.outputSize do
            local delta = outputErrors[j] * self:sigmoidDerivative(outputs[j])
            self.weightsHiddenOutput[i][j] = self.weightsHiddenOutput[i][j] + learningRate * delta * hidden[i]
        end
    end
    
    -- Update weights input to hidden
    for i = 1, self.inputSize do
        for j = 1, self.hiddenSize do
            local delta = hiddenErrors[j] * self:sigmoidDerivative(hidden[j])
            self.weightsInputHidden[i][j] = self.weightsInputHidden[i][j] + learningRate * delta * inputs[i]
        end
    end
    
    -- Update biases
    for i = 1, self.outputSize do
        local delta = outputErrors[i] * self:sigmoidDerivative(outputs[i])
        self.biasOutput[i] = self.biasOutput[i] + learningRate * delta
    end
    
    for i = 1, self.hiddenSize do
        local delta = hiddenErrors[i] * self:sigmoidDerivative(hidden[i])
        self.biasHidden[i] = self.biasHidden[i] + learningRate * delta
    end
end

