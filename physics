-- Text to vector conversion (simple bag-of-words)
local function textToVector(text, vocabulary)
    local vector = {}
    local words = {}
    for word in string.gmatch(text:lower(), "%w+") do
        words[word] = (words[word] or 0) + 1
    end
    
    for i, vocabWord in ipairs(vocabulary) do
        vector[i] = words[vocabWord] or 0
    end
    
    return vector
end

-- Pattern matching function (returns category, not response)
local function detectCategory(input)
    input = input:lower()
    
    for category, data in pairs(ChatPatterns) do
        if category ~= "default" then
            for _, pattern in ipairs(data.patterns) do
                if input:find(pattern) then
                    return category
                end
            end
        end
    end
    
    return "default"
end

