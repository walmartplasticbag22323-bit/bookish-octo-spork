    -- NEW: Get closest face on a part based on click position
    local function getClosestFace(part, position)
        local rel = part.CFrame:PointToObjectSpace(position)
        local size = part.Size/2
        local faces = {
            {Vector3.new(0,1,0), math.abs(rel.Y - size.Y)},
            {Vector3.new(0,-1,0), math.abs(rel.Y + size.Y)},
            {Vector3.new(1,0,0), math.abs(rel.X - size.X)},
            {Vector3.new(-1,0,0), math.abs(rel.X + size.X)},
            {Vector3.new(0,0,1), math.abs(rel.Z - size.Z)},
            {Vector3.new(0,0,-1), math.abs(rel.Z + size.Z)}
        }
        table.sort(faces, function(a,b) return a[2] < b[2] end)
        return faces[1][1]
    end

    -- NEW: Auto-detect touching faces between parts
    local function findTouchingFaces(part1, part2)
        local center1 = part1.Position
        local center2 = part2.Position
        local direction = (center2 - center1).Unit
        local localDir1 = part1.CFrame:VectorToObjectSpace(direction)
        local absX, absY, absZ = math.abs(localDir1.X), math.abs(localDir1.Y), math.abs(localDir1.Z)
        local face1
        if absX > absY and absX > absZ then
            face1 = localDir1.X > 0 and Vector3.new(1, 0, 0) or Vector3.new(-1, 0, 0)
        elseif absY > absZ then
            face1 = localDir1.Y > 0 and Vector3.new(0, 1, 0) or Vector3.new(0, -1, 0)
        else
            face1 = localDir1.Z > 0 and Vector3.new(0, 0, 1) or Vector3.new(0, 0, -1)
        end
        local localDir2 = part2.CFrame:VectorToObjectSpace(-direction)
        absX, absY, absZ = math.abs(localDir2.X), math.abs(localDir2.Y), math.abs(localDir2.Z)
        local face2
        if absX > absY and absX > absZ then
            face2 = localDir2.X > 0 and Vector3.new(1, 0, 0) or Vector3.new(-1, 0, 0)
        elseif absY > absZ then
            face2 = localDir2.Y > 0 and Vector3.new(0, 1, 0) or Vector3.new(0, -1, 0)
        else
            face2 = localDir2.Z > 0 and Vector3.new(0, 0, 1) or Vector3.new(0, 0, -1)
        end
        local surfacePos1 = (part1.Size / 2) * face1
        local surfacePos2 = (part2.Size / 2) * face2
        return face1, face2, surfacePos1, surfacePos2
    end
    
    -- NEW: Find furthest faces (opposite of Auto Face)
    local function findFurthestFaces(part1, part2)
        local center1 = part1.Position
        local center2 = part2.Position
        local direction = (center2 - center1).Unit
        
        -- For part1, find the face pointing AWAY from part2
        local localDir1 = part1.CFrame:VectorToObjectSpace(-direction)  -- Note: negative direction
        local absX, absY, absZ = math.abs(localDir1.X), math.abs(localDir1.Y), math.abs(localDir1.Z)
        local face1
        if absX > absY and absX > absZ then
            face1 = localDir1.X > 0 and Vector3.new(1, 0, 0) or Vector3.new(-1, 0, 0)
        elseif absY > absZ then
            face1 = localDir1.Y > 0 and Vector3.new(0, 1, 0) or Vector3.new(0, -1, 0)
        else
            face1 = localDir1.Z > 0 and Vector3.new(0, 0, 1) or Vector3.new(0, 0, -1)
        end
        
        -- For part2, find the face pointing AWAY from part1
        local localDir2 = part2.CFrame:VectorToObjectSpace(direction)  -- Note: positive direction
        absX, absY, absZ = math.abs(localDir2.X), math.abs(localDir2.Y), math.abs(localDir2.Z)
        local face2
        if absX > absY and absX > absZ then
            face2 = localDir2.X > 0 and Vector3.new(1, 0, 0) or Vector3.new(-1, 0, 0)
        elseif absY > absZ then
            face2 = localDir2.Y > 0 and Vector3.new(0, 1, 0) or Vector3.new(0, -1, 0)
        else
            face2 = localDir2.Z > 0 and Vector3.new(0, 0, 1) or Vector3.new(0, 0, -1)
        end
        
        local surfacePos1 = (part1.Size / 2) * face1
        local surfacePos2 = (part2.Size / 2) * face2
        return face1, face2, surfacePos1, surfacePos2
    end
    
    -- NEW: Find nearest neighboring part to a part
    local function findNearestNeighbor(part, candidateParts)
        local nearest = nil
        local nearestDist = math.huge
        for _, candidate in ipairs(candidateParts) do
            if candidate ~= part and candidate.Parent then
                local dist = (candidate.Position - part.Position).Magnitude
                if dist < nearestDist then
                    nearestDist = dist
                    nearest = candidate
                end
            end
        end
        return nearest
    end

    -- NEW: Enhanced constraint application with modes including Auto Face
    -- NEW: Collision Constraint (opposite of NoCollision)
    local function applyCollisionConstraint()
        if #selectedParts < 2 then
            warn("Need 2 parts for Collision constraint")
            return
        end
        
        for i = 1, #selectedParts - 1 do
            for j = i + 1, #selectedParts do
                local part1, part2 = selectedParts[i], selectedParts[j]
                
                replicateToServer(function()
                    setNetworkOwnership(part1)
                    setNetworkOwnership(part2)
                    
                    -- Remove any existing NoCollisionConstraints between these parts
                    for _, constraint in ipairs(part1:GetChildren()) do
                        if constraint:IsA("NoCollisionConstraint") then
                            if constraint.Part0 == part2 or constraint.Part1 == part2 then
                                constraint:Destroy()
                            end
                        end
                    end
                    
                    -- Collision is default behavior, but we create a tag to track it
                    local collisionMarker = Instance.new("BoolValue")
                    collisionMarker.Name = "CollisionConstraintWith_" .. part2.Name
                    collisionMarker.Parent = part1
                    
                    print("✅ Forced collision between " .. part1.Name .. " and " .. part2.Name)
                end)
            end
        end
    end
    
    local function removeAllCollisionConstraints()
        for _, part in ipairs(workspace:GetDescendants()) do
            if part:IsA("BasePart") then
                for _, child in ipairs(part:GetChildren()) do
                    if child:IsA("BoolValue") and child.Name:match("^CollisionConstraintWith_") then
                        child:Destroy()
                    end
                end
            end
        end
        print("Removed all Collision constraint markers")
    end

    -- NEW: Create collision rope with segments
    local function createCollisionRope(part1, part2, segmentsPerStud, useCollision)
        segmentsPerStud = segmentsPerStud or 5
        local distance = (part1.Position - part2.Position).Magnitude
        local numSegments = math.max(2, math.floor(distance * segmentsPerStud))
        
        -- Get faces for both parts
        local face1, face2, surfacePos1, surfacePos2 = findTouchingFaces(part1, part2)
        
        local segments = {}
        local segmentSize = Vector3.new(0.2, 0.2, distance / numSegments)
        
        -- Create segment parts
        for i = 1, numSegments do
            local segment = Instance.new("Part")
            segment.Name = "RopeSegment_" .. i
            segment.Size = segmentSize
            segment.Material = Enum.Material.Fabric
            segment.Color = Color3.fromRGB(150, 100, 50)
            segment.CanCollide = useCollision
            segment.Anchored = false
            segment.Massless = true
            
            -- Position segments between part1 and part2
            local alpha = i / (numSegments + 1)
            local startPos = part1.CFrame:PointToWorldSpace(surfacePos1)
            local endPos = part2.CFrame:PointToWorldSpace(surfacePos2)
            segment.Position = startPos:Lerp(endPos, alpha)
            
            segment.Parent = workspace
            table.insert(segments, segment)
        end
        
        -- Connect first segment to part1 using FACE
        local att1 = Instance.new("Attachment")
        att1.Position = surfacePos1
        att1.Parent = part1
        
        local firstSegmentAtt = Instance.new("Attachment")
        firstSegmentAtt.Position = Vector3.new(0, 0, -segmentSize.Z/2) -- Front face
        firstSegmentAtt.Parent = segments[1]
        
        local ballSocket1 = Instance.new("BallSocketConstraint")
        ballSocket1.Attachment0 = att1
        ballSocket1.Attachment1 = firstSegmentAtt
        ballSocket1.Parent = part1
        
        -- Connect segments to each other using BallSocket
        for i = 1, #segments - 1 do
            local seg1 = segments[i]
            local seg2 = segments[i + 1]
            
            local att1 = Instance.new("Attachment")
            att1.Position = Vector3.new(0, 0, segmentSize.Z/2) -- Back face
            att1.Parent = seg1
            
            local att2 = Instance.new("Attachment")
            att2.Position = Vector3.new(0, 0, -segmentSize.Z/2) -- Front face
            att2.Parent = seg2
            
            local ballSocket = Instance.new("BallSocketConstraint")
            ballSocket.Attachment0 = att1
            ballSocket.Attachment1 = att2
            ballSocket.Parent = seg1
        end
        
        -- Connect last segment to part2 using FACE
        local lastSegmentAtt = Instance.new("Attachment")
        lastSegmentAtt.Position = Vector3.new(0, 0, segmentSize.Z/2) -- Back face
        lastSegmentAtt.Parent = segments[#segments]
        
        local att2 = Instance.new("Attachment")
        att2.Position = surfacePos2
        att2.Parent = part2
        
        local ballSocket2 = Instance.new("BallSocketConstraint")
        ballSocket2.Attachment0 = lastSegmentAtt
        ballSocket2.Attachment1 = att2
        ballSocket2.Parent = segments[#segments]
        
        print("✅ Created collision rope with " .. numSegments .. " segments (" .. segmentsPerStud .. " per stud)")
        return segments
    end
    
    local function applyConstraint(constraintType, showSpringVisual, chainMode, advancedSettings)
        chainMode = chainMode or "Chain"
        advancedSettings = advancedSettings or {}
        
        if #selectedParts < 2 then
            warn("Need 2+ parts for constraints")
            return
        end
        
        -- Chain Mode: Connect parts in sequence (1→2, 2→3, 3→4, etc.)
        if chainMode == "Chain" then
            for i = 1, #selectedParts - 1 do
                local part1, part2 = selectedParts[i], selectedParts[i + 1]
                
                replicateToServer(function()
                    setNetworkOwnership(part1)
                    setNetworkOwnership(part2)
                    
                    local constraint
                    
                    if constraintType:find("Rope") then
                        -- NEW: Check if collision rope is enabled
                        if advancedSettings.useCollisionRope then
                            if constraintMode == "Face" or constraintMode == "Auto Face" or constraintMode == "Anti-AutoFace" then
                                createCollisionRope(part1, part2, advancedSettings.segmentsPerStud or 5, true)
                                print("Applied Collision Rope with segments")
                                return -- Don't create default rope
                            else
                                warn("⚠️ Collision Rope requires Face mode! Switch to Face/Auto Face/Anti-AutoFace")
                                return
                            end
                        end
                        
                        -- Default rope (no collision)
                        constraint = Instance.new("RopeConstraint")
                        constraint.Length = (part1.Position - part2.Position).Magnitude
                        constraint.Visible = constraintVisual
                        constraint.Restitution = advancedSettings.restitution or 0
                    elseif constraintType:find("Rod") then
                        constraint = Instance.new("RodConstraint")
                        constraint.Length = (part1.Position - part2.Position).Magnitude
                    elseif constraintType:find("Hinge") then
                        constraint = Instance.new("HingeConstraint")
                        
                        -- Apply Hinge Type (Motor/Servo)
                        local hingeType = advancedSettings.hingeType or "None"
                        if hingeType == "Motor" then
                            constraint.ActuatorType = Enum.ActuatorType.Motor
                            constraint.MotorMaxTorque = advancedSettings.maxForce or math.huge
                            constraint.AngularVelocity = advancedSettings.hingeSpeed or 10
                        elseif hingeType == "Servo" then
                            constraint.ActuatorType = Enum.ActuatorType.Servo
                            constraint.ServoMaxTorque = advancedSettings.maxForce or math.huge
                            constraint.AngularSpeed = advancedSettings.hingeSpeed or 10
                            constraint.TargetAngle = 0
                        else
                            constraint.ActuatorType = Enum.ActuatorType.None
                        end
                    elseif constraintType:find("BallSocket") then
                        constraint = Instance.new("BallSocketConstraint")
                    elseif constraintType:find("Chain") then
                        constraint = Instance.new("RopeConstraint")
                        constraint.Length = (part1.Position - part2.Position).Magnitude
                        constraint.Visible = constraintVisual
                        constraint.Restitution = advancedSettings.restitution or 0
                        part1.CustomPhysicalProperties = PhysicalProperties.new(5, 0.3, 0.5)
                        part2.CustomPhysicalProperties = PhysicalProperties.new(5, 0.3, 0.5)
                    elseif constraintType:find("Plane") then
                        constraint = Instance.new("PlaneConstraint")
                    elseif constraintType:find("Cylindrical") then
                        constraint = Instance.new("CylindricalConstraint")
                        -- Add motor support for Cylindrical
                        if advancedSettings.hingeType == "Motor" then
                            constraint.AngularActuatorType = Enum.ActuatorType.Motor
                            constraint.MotorMaxTorque = advancedSettings.maxForce or math.huge
                            constraint.AngularVelocity = advancedSettings.hingeSpeed or 10
                        elseif advancedSettings.hingeType == "Servo" then
                            constraint.AngularActuatorType = Enum.ActuatorType.Servo
                            constraint.ServoMaxTorque = advancedSettings.maxForce or math.huge
                            constraint.AngularSpeed = advancedSettings.hingeSpeed or 10
                        end
                    elseif constraintType:find("Prismatic") then
                        constraint = Instance.new("PrismaticConstraint")
                        -- Add motor support for Prismatic
                        if advancedSettings.hingeType == "Motor" then
                            constraint.ActuatorType = Enum.ActuatorType.Motor
                            constraint.MotorMaxForce = advancedSettings.maxForce or math.huge
                            constraint.Velocity = advancedSettings.hingeSpeed or 10
                        elseif advancedSettings.hingeType == "Servo" then
                            constraint.ActuatorType = Enum.ActuatorType.Servo
                            constraint.ServoMaxForce = advancedSettings.maxForce or math.huge
                            constraint.Speed = advancedSettings.hingeSpeed or 10
                        end
                    elseif constraintType == "LinearSpring" then
                        -- LinearSpring: Pure spring without prismatic
                        constraint = Instance.new("SpringConstraint")
                        constraint.FreeLength = (part1.Position - part2.Position).Magnitude
                        constraint.Stiffness = advancedSettings.stiffness or 1000
                        constraint.Damping = advancedSettings.damping or 100
                        constraint.Visible = showSpringVisual or false
                        print("  ✅ Applied LinearSpring (pure spring, no prismatic)")
                    elseif constraintType == "TorsionSpring" then
                        -- TorsionSpring: Rotational spring
                        constraint = Instance.new("TorsionSpringConstraint")
                        constraint.Stiffness = advancedSettings.stiffness or 1000
                        constraint.Damping = advancedSettings.damping or 100
                        constraint.MaxTorque = advancedSettings.maxTorque or math.huge
                        constraint.Restitution = 0
                        print("  ✅ Applied TorsionSpring (rotational spring)")
                    elseif constraintType == "MatchRotation" then
                        -- MatchRotation: AlignOrientation with spring behavior
                        constraint = Instance.new("AlignOrientation")
                        constraint.Mode = Enum.OrientationAlignmentMode.OneAttachment
                        constraint.AlignType = Enum.AlignType.PrimaryAxisParallel
                        constraint.MaxTorque = advancedSettings.maxTorque or 10000
                        constraint.Responsiveness = advancedSettings.responsiveness or 10
                        constraint.RigidityEnabled = false
                        print("  ✅ Applied MatchRotation (align orientation with spring)")
                    elseif constraintType == "Spring" then
                        -- Spring with Prismatic: SpringConstraint + PrismaticConstraint
                        constraint = Instance.new("SpringConstraint")
                        constraint.FreeLength = (part1.Position - part2.Position).Magnitude
                        constraint.Stiffness = advancedSettings.stiffness or 1000
                        constraint.Damping = advancedSettings.damping or 100
                        constraint.Visible = showSpringVisual or false
                        
                        -- Add prismatic to lock movement to axis
                        local prismatic = Instance.new("PrismaticConstraint")
                        prismatic.Attachment0 = att1
                        prismatic.Attachment1 = att2
                        prismatic.Parent = part2
                        
                        print("  ✅ Applied Spring (with prismatic axis lock)")
                    elseif constraintType == "PrismaticSpring" then
                        -- Rigid Linear Spring: SpringConstraint + PrismaticConstraint (locked to axis)
                        constraint = Instance.new("SpringConstraint")
                        constraint.FreeLength = (part1.Position - part2.Position).Magnitude
                        constraint.Stiffness = advancedSettings.stiffness or 1000
                        constraint.Damping = advancedSettings.damping or 100
                        constraint.Visible = showSpringVisual or false
                        
                        -- Add prismatic to lock movement to axis
                        local prismatic = Instance.new("PrismaticConstraint")
                        prismatic.Attachment0 = att1
                        prismatic.Attachment1 = att2
                        prismatic.Parent = part2
                        
                        print("  ✅ Applied PrismaticSpring (rigid axis-locked spring)")
                    elseif constraintType:find("Spring") then
                        -- Fallback for any other spring types (LinearSpring, TorsionSpring handled above)
                        constraint = Instance.new("SpringConstraint")
                        constraint.FreeLength = (part1.Position - part2.Position).Magnitude
                        constraint.Stiffness = advancedSettings.stiffness or 1000
                        constraint.Damping = advancedSettings.damping or 100
                        constraint.Visible = showSpringVisual or false
                        print("  ✅ Applied Spring constraint (generic fallback)")
                    end
                    
                    if constraint then
                        local attachment1 = Instance.new("Attachment")
                        local attachment2 = Instance.new("Attachment")
                        
                        if constraintMode == "Face" then
                            local face1 = selectedFaces[part1] or Vector3.new(0,0,0)
                            local face2 = selectedFaces[part2] or Vector3.new(0,0,0)
                            attachment1.Position = (part1.Size/2) * face1
                            attachment2.Position = (part2.Size/2) * face2
                        elseif constraintMode == "Auto Face" then
                            local face1, face2 = findTouchingFaces(part1, part2)
                            attachment1.Position = (part1.Size/2) * face1
                            attachment2.Position = (part2.Size/2) * face2
                        elseif constraintMode == "Anti-AutoFace" then
                            local face1, face2 = findFurthestFaces(part1, part2)
                            attachment1.Position = (part1.Size/2) * face1
                            attachment2.Position = (part2.Size/2) * face2
                        elseif constraintMode == "Exact Point" then
                            local localPos1 = exactClickPositions[part1] or Vector3.new(0,0,0)
                            local localPos2 = exactClickPositions[part2] or Vector3.new(0,0,0)
                            attachment1.Position = localPos1
                            attachment2.Position = localPos2
                        end
                        
                        attachment1.Parent = part1
                        attachment2.Parent = part2
                        
                        -- Set axis for Prismatic/Cylindrical constraints
                        if (constraintType:find("Prismatic") or constraintType:find("Cylindrical")) and advancedSettings.constraintAxis then
                            local axisVector = Vector3.new(0, 1, 0) -- Default Y
                            if advancedSettings.constraintAxis == "X" then
                                axisVector = Vector3.new(1, 0, 0)
                            elseif advancedSettings.constraintAxis == "Z" then
                                axisVector = Vector3.new(0, 0, 1)
                            end
                            attachment1.Axis = axisVector
                            attachment2.Axis = axisVector
                        end
                        
                        -- Set axis for TorsionSpring
                        if constraintType == "TorsionSpring" and advancedSettings.constraintAxis then
                            local axisVector = Vector3.new(0, 1, 0) -- Default Y
                            if advancedSettings.constraintAxis == "X" then
                                axisVector = Vector3.new(1, 0, 0)
                            elseif advancedSettings.constraintAxis == "Z" then
                                axisVector = Vector3.new(0, 0, 1)
                            end
                            attachment1.Axis = axisVector
                            attachment2.Axis = axisVector
                        end
                        
                        constraint.Attachment0 = attachment1
                        constraint.Attachment1 = attachment2
                        
                        if constraint:IsA("RopeConstraint") or constraint:IsA("RodConstraint") then
                            constraint.Visible = constraintVisual
                        end
                        
                        if not constraintCollision and constraint:FindFirstChild("LimitsEnabled") then
                            pcall(function() constraint.LimitsEnabled = false end)
                        end
                        
                        -- NEW: Apply Limits Angle (for Hinge constraints)
                        if constraint:IsA("HingeConstraint") and advancedSettings.limitsEnabled then
                            pcall(function()
                                constraint.LimitsEnabled = true
                                constraint.UpperAngle = advancedSettings.limitsAngle or 45
                                constraint.LowerAngle = -(advancedSettings.limitsAngle or 45)
                            end)
                        end
                        
                        -- NEW: Apply MaxFrictionTorque (for Hinge constraints)
                        if constraint:IsA("HingeConstraint") and advancedSettings.maxFrictionTorqueEnabled then
                            pcall(function()
                                constraint.MaxFrictionTorque = advancedSettings.maxFrictionTorque or 100
                            end)
                        end
                        
                        -- NEW: Apply Restitution (for applicable constraints)
                        if advancedSettings.restitution and advancedSettings.restitution > 0 then
                            pcall(function()
                                if constraint:IsA("RopeConstraint") then
                                    constraint.Restitution = advancedSettings.restitution
                                end
                            end)
                        end
                        
                        constraint.Parent = workspace
                        
                        print("Applied " .. constraintType .. " (" .. constraintMode .. ") between " .. part1.Name .. " and " .. part2.Name)
                        
                        -- Log advanced settings if used
                        if advancedSettings.hingeType and advancedSettings.hingeType ~= "None" then
                            print("  ⚙️ Type: " .. advancedSettings.hingeType .. " | Speed: " .. (advancedSettings.hingeSpeed or 10))
                        end
                        if advancedSettings.stiffness and constraintType:find("Spring") then
                            print("  ⚙️ Stiffness: " .. advancedSettings.stiffness .. " | Damping: " .. advancedSettings.damping)
                        end
                        if advancedSettings.limitsEnabled then
                            print("  🔒 Limits Angle: ±" .. (advancedSettings.limitsAngle or 45) .. "°")
                        end
                        if advancedSettings.maxFrictionTorqueEnabled then
                            print("  ⚡ MaxFrictionTorque: " .. (advancedSettings.maxFrictionTorque or 100))
                        end
                        if advancedSettings.restitution and advancedSettings.restitution > 0 then
                            print("  🎾 Restitution: " .. advancedSettings.restitution)
                        end
                    end
                end)
            end
        
        -- First to All Mode: Connect first part to all other parts (1→2, 1→3, 1→4, etc.)
        elseif chainMode == "First to All" then
            local firstPart = selectedParts[1]
            
            for i = 2, #selectedParts do
                local part2 = selectedParts[i]
                
                replicateToServer(function()
                    setNetworkOwnership(firstPart)
                    setNetworkOwnership(part2)
                    
                    local constraint
                    
                    if constraintType:find("Rope") then
                        constraint = Instance.new("RopeConstraint")
                        constraint.Length = (firstPart.Position - part2.Position).Magnitude
                        constraint.Visible = constraintVisual
                    elseif constraintType:find("Rod") then
                        constraint = Instance.new("RodConstraint")
                        constraint.Length = (firstPart.Position - part2.Position).Magnitude
                    elseif constraintType:find("Hinge") then
                        constraint = Instance.new("HingeConstraint")
                    elseif constraintType:find("BallSocket") then
                        constraint = Instance.new("BallSocketConstraint")
                    elseif constraintType:find("Chain") then
                        constraint = Instance.new("RopeConstraint")
                        constraint.Length = (firstPart.Position - part2.Position).Magnitude
                        constraint.Visible = constraintVisual
                        firstPart.CustomPhysicalProperties = PhysicalProperties.new(5, 0.3, 0.5)
                        part2.CustomPhysicalProperties = PhysicalProperties.new(5, 0.3, 0.5)
                    elseif constraintType:find("Plane") then
                        constraint = Instance.new("PlaneConstraint")
                    elseif constraintType:find("Cylindrical") then
                        constraint = Instance.new("CylindricalConstraint")
                    elseif constraintType:find("Prismatic") then
                        constraint = Instance.new("PrismaticConstraint")
                    elseif constraintType == "LinearSpring" then
                        -- LinearSpring: Pure spring without prismatic
                        constraint = Instance.new("SpringConstraint")
                        constraint.FreeLength = (part1.Position - part2.Position).Magnitude
                        constraint.Stiffness = advancedSettings.stiffness or 1000
                        constraint.Damping = advancedSettings.damping or 100
                        constraint.Visible = showSpringVisual or false
                        print("  ✅ Applied LinearSpring (pure spring, no prismatic)")
                    elseif constraintType == "TorsionSpring" then
                        -- TorsionSpring: Rotational spring
                        constraint = Instance.new("TorsionSpringConstraint")
                        constraint.Stiffness = advancedSettings.stiffness or 1000
                        constraint.Damping = advancedSettings.damping or 100
                        constraint.MaxTorque = advancedSettings.maxTorque or math.huge
                        constraint.Restitution = 0
                        print("  ✅ Applied TorsionSpring (rotational spring)")
                    elseif constraintType == "MatchRotation" then
                        -- MatchRotation: AlignOrientation with spring behavior
                        constraint = Instance.new("AlignOrientation")
                        constraint.Mode = Enum.OrientationAlignmentMode.OneAttachment
                        constraint.AlignType = Enum.AlignType.PrimaryAxisParallel
                        constraint.MaxTorque = advancedSettings.maxTorque or 10000
                        constraint.Responsiveness = advancedSettings.responsiveness or 10
                        constraint.RigidityEnabled = false
                        print("  ✅ Applied MatchRotation (align orientation with spring)")
                    elseif constraintType == "Spring" then
                        -- Spring with Prismatic (chain mode)
                        constraint = Instance.new("SpringConstraint")
                        constraint.FreeLength = (firstPart.Position - part2.Position).Magnitude
                        constraint.Stiffness = 1000
                        constraint.Damping = 100
                        constraint.Visible = showSpringVisual or false
                        
                        local prismatic = Instance.new("PrismaticConstraint")
                        prismatic.Attachment0 = att1
                        prismatic.Attachment1 = att2
                        prismatic.Parent = part2
                        
                        print("  ✅ Applied Spring (with prismatic, chain)")
                    elseif constraintType == "PrismaticSpring" then
                        -- Rigid Linear Spring (chain mode)
                        constraint = Instance.new("SpringConstraint")
                        constraint.FreeLength = (firstPart.Position - part2.Position).Magnitude
                        constraint.Stiffness = 1000
                        constraint.Damping = 100
                        constraint.Visible = showSpringVisual or false
                        
                        local prismatic = Instance.new("PrismaticConstraint")
                        prismatic.Attachment0 = att1
                        prismatic.Attachment1 = att2
                        prismatic.Parent = part2
                        
                        print("  ✅ Applied PrismaticSpring (rigid, chain)")
                    elseif constraintType:find("Spring") then
                        -- Fallback for other spring types
                        constraint = Instance.new("SpringConstraint")
                        constraint.FreeLength = (firstPart.Position - part2.Position).Magnitude
                        constraint.Stiffness = 1000
                        constraint.Damping = 100
                        constraint.Visible = showSpringVisual or false
                        print("  ✅ Applied Spring (chain, generic fallback)")
                    end
                    
                    if constraint then
                        local attachment1 = Instance.new("Attachment")
                        local attachment2 = Instance.new("Attachment")
                        
                        if constraintMode == "Face" then
                            local face1 = selectedFaces[firstPart] or Vector3.new(0,0,0)
                            local face2 = selectedFaces[part2] or Vector3.new(0,0,0)
                            attachment1.Position = (firstPart.Size/2) * face1
                            attachment2.Position = (part2.Size/2) * face2
                        elseif constraintMode == "Auto Face" then
                            local face1, face2 = findTouchingFaces(firstPart, part2)
                            attachment1.Position = (firstPart.Size/2) * face1
                            attachment2.Position = (part2.Size/2) * face2
                        elseif constraintMode == "Anti-AutoFace" then
                            local face1, face2 = findFurthestFaces(firstPart, part2)
                            attachment1.Position = (firstPart.Size/2) * face1
                            attachment2.Position = (part2.Size/2) * face2
                        end
                        
                        attachment1.Parent = firstPart
                        attachment2.Parent = part2
                        
                        -- Set axis for TorsionSpring
                        if constraintType == "TorsionSpring" and advancedSettings.constraintAxis then
                            local axisVector = Vector3.new(0, 1, 0) -- Default Y
                            if advancedSettings.constraintAxis == "X" then
                                axisVector = Vector3.new(1, 0, 0)
                            elseif advancedSettings.constraintAxis == "Z" then
                                axisVector = Vector3.new(0, 0, 1)
                            end
                            attachment1.Axis = axisVector
                            attachment2.Axis = axisVector
                        end
                        
                        constraint.Attachment0 = attachment1
                        constraint.Attachment1 = attachment2
                        
                        if constraint:IsA("RopeConstraint") or constraint:IsA("RodConstraint") then
                            constraint.Visible = constraintVisual
                        end
                        
                        if not constraintCollision and constraint:FindFirstChild("LimitsEnabled") then
                            pcall(function() constraint.LimitsEnabled = false end)
                        end
                        
                        -- NEW: Apply Limits Angle (for Hinge constraints)
                        if constraint:IsA("HingeConstraint") and advancedSettings.limitsEnabled then
                            pcall(function()
                                constraint.LimitsEnabled = true
                                constraint.UpperAngle = advancedSettings.limitsAngle or 45
                                constraint.LowerAngle = -(advancedSettings.limitsAngle or 45)
                            end)
                        end
                        
                        -- NEW: Apply MaxFrictionTorque (for Hinge constraints)
                        if constraint:IsA("HingeConstraint") and advancedSettings.maxFrictionTorqueEnabled then
                            pcall(function()
                                constraint.MaxFrictionTorque = advancedSettings.maxFrictionTorque or 100
                            end)
                        end
                        
                        -- NEW: Apply Restitution (for applicable constraints)
                        if advancedSettings.restitution and advancedSettings.restitution > 0 then
                            pcall(function()
                                if constraint:IsA("RopeConstraint") then
                                    constraint.Restitution = advancedSettings.restitution
                                end
                            end)
                        end
                        
                        constraint.Parent = workspace
                        
                        print("Applied " .. constraintType .. " (" .. constraintMode .. ") between " .. firstPart.Name .. " and " .. part2.Name)
                        
                        -- Log advanced settings if used
                        if advancedSettings.hingeType and advancedSettings.hingeType ~= "None" then
                            print("  ⚙️ Type: " .. advancedSettings.hingeType .. " | Speed: " .. (advancedSettings.hingeSpeed or 10))
                        end
                        if advancedSettings.stiffness and constraintType:find("Spring") then
                            print("  ⚙️ Stiffness: " .. advancedSettings.stiffness .. " | Damping: " .. advancedSettings.damping)
                        end
                        if advancedSettings.limitsEnabled then
                            print("  🔒 Limits Angle: ±" .. (advancedSettings.limitsAngle or 45) .. "°")
                        end
                        if advancedSettings.maxFrictionTorqueEnabled then
                            print("  ⚡ MaxFrictionTorque: " .. (advancedSettings.maxFrictionTorque or 100))
                        end
                        if advancedSettings.restitution and advancedSettings.restitution > 0 then
                            print("  🎾 Restitution: " .. advancedSettings.restitution)
                        end
                    end
                end)
            end
        end
    end

    local function applyVelocity(velocity, method, mode, keybind, applicationType, velocityToAxis, forceful)
        method = method or "BodyVelocity"
        mode = mode or "Always On"
        keybind = keybind or "W"
        applicationType = applicationType or "Constant"
        velocityToAxis = velocityToAxis or "Off"
        forceful = forceful or false
        
        for _, part in ipairs(selectedParts) do
            replicateToServer(function()
                setNetworkOwnership(part)
                
                -- Clean up existing velocity controls to override instead of stacking
                if velocityControls[part] then
                    for _, control in ipairs(velocityControls[part]) do
                        if control.connection then control.connection:Disconnect() end
                        if control.keybindConnection then control.keybindConnection:Disconnect() end
                        if control.bodyVel then control.bodyVel:Destroy() end
                        if control.vectorForce then control.vectorForce:Destroy() end
                        if control.linearVelocity then control.linearVelocity:Destroy() end
                        if control.attachment then control.attachment:Destroy() end
                    end
                end
                
                -- Initialize as array
                velocityControls[part] = {}
                
                if velocity.Magnitude == 0 then
                    if not part.Anchored then
                        part.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                    end
                    print("Disabled velocity control for " .. part.Name)
                else
                    local bodyVel = nil
                    local vectorForce = nil
                    local attachment = nil
                    local connection = nil
                    local keybindConnection = nil
                    local isKeyDown = false
                    
                    -- Parse keybind
                    local keyEnum = nil
                    if keybind:len() == 1 then
                        keyEnum = Enum.KeyCode[keybind:upper()]
                    else
                        keyEnum = Enum.KeyCode[keybind]
                    end
                    
                    if mode == "Keybind Move" then
                        -- Setup keybind listeners
                        keybindConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
                            if gameProcessed then return end
                            if input.KeyCode == keyEnum then
                                isKeyDown = true
                            end
                        end)
                        
                        local keyUpConnection = UserInputService.InputEnded:Connect(function(input)
                            if input.KeyCode == keyEnum then
                                isKeyDown = false
                            end
                        end)
                    end
                    
                    -- Helper function to convert to local space
                    local function getLocalVelocity(worldVel, partCFrame)
                        if velocityToAxis == "Velocity to Axis" then
                            return partCFrame:VectorToWorldSpace(worldVel)
                        elseif velocityToAxis == "Updating Velocity to Axis" then
                            return partCFrame:VectorToWorldSpace(worldVel)
                        else
                            return worldVel
                        end
                    end
                    
                    if part.Anchored then
                        -- For anchored parts - push touching AND inside parts
                        connection = RunService.Heartbeat:Connect(function()
                            if part.Parent then
                                local shouldApply = (mode == "Always On") or (mode == "Keybind Move" and isKeyDown)
                                
                                if shouldApply then
                                    local touching = part:GetTouchingParts()
                                    local effectiveVel = getLocalVelocity(velocity, part.CFrame)
                                    
                                    -- Get parts inside the anchored part using Region3
                                    local region = Region3.new(
                                        part.Position - part.Size/2,
                                        part.Position + part.Size/2
                                    ):ExpandToGrid(4)
                                    local partsInRegion = workspace:FindPartsInRegion3(region, part, 100)
                                    
                                    -- Combine touching and inside parts
                                    local allAffectedParts = {}
                                    for _, p in pairs(touching) do
                                        allAffectedParts[p] = true
                                    end
                                    for _, p in pairs(partsInRegion) do
                                        allAffectedParts[p] = true
                                    end
                                    
                                    for affectedPart, _ in pairs(allAffectedParts) do
                                        if affectedPart ~= part and not affectedPart.Anchored and affectedPart.Parent ~= player.Character then
                                            if applicationType == "Constant" then
                                                affectedPart.AssemblyLinearVelocity = effectiveVel
                                            else -- Push
                                                affectedPart:ApplyImpulse(effectiveVel * affectedPart.Mass * 0.1)
                                            end
                                        end
                                    end
                                end
                            else
                                connection:Disconnect()
                            end
                        end)
                        
                        print("Applied anchored velocity conveyor " .. tostring(velocity) .. " to " .. part.Name .. " (" .. mode .. ", " .. applicationType .. ")")
                        
                    else
                        -- For unanchored parts - use selected method
                        if method == "BodyVelocity" then
                            bodyVel = Instance.new("BodyVelocity")
                            bodyVel.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
                            bodyVel.Velocity = Vector3.new(0, 0, 0)
                            bodyVel.Parent = part
                            
                            connection = RunService.Heartbeat:Connect(function()
                                if bodyVel.Parent and part.Parent then
                                    local shouldApply = (mode == "Always On") or (mode == "Keybind Move" and isKeyDown)
                                    
                                    if shouldApply then
                                        local effectiveVel = getLocalVelocity(velocity, part.CFrame)
                                        
                                        if applicationType == "Constant" then
                                            bodyVel.Velocity = effectiveVel
                                            if forceful then
                                                part.AssemblyLinearVelocity = effectiveVel
                                            end
                                        else -- Push
                                            part:ApplyImpulse(effectiveVel * part.Mass * 0.1)
                                        end
                                    else
                                        bodyVel.Velocity = Vector3.new(0, 0, 0)
                                    end
                                else
                                    connection:Disconnect()
                                end
                            end)
                            
                            print("Applied BodyVelocity " .. tostring(velocity) .. " to " .. part.Name .. " (" .. mode .. ", " .. applicationType .. (forceful and ", FORCEFUL" or "") .. ")")
                            
                        elseif method == "AssemblyLinearVelocity" then
                            connection = RunService.Heartbeat:Connect(function()
                                if part.Parent then
                                    local shouldApply = (mode == "Always On") or (mode == "Keybind Move" and isKeyDown)
                                    
                                    if shouldApply then
                                        local effectiveVel = getLocalVelocity(velocity, part.CFrame)
                                        
                                        if applicationType == "Constant" then
                                            part.AssemblyLinearVelocity = effectiveVel
                                            if forceful then
                                                -- Extra force to overcome resistance
                                                local velocityDiff = effectiveVel - part.AssemblyLinearVelocity
                                                if velocityDiff.Magnitude > 0.1 then
                                                    part:ApplyImpulse(velocityDiff * part.Mass * 0.5)
                                                end
                                            end
                                        else -- Push
                                            part:ApplyImpulse(effectiveVel * part.Mass * 0.1)
                                        end
                                    else
                                        part.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                                    end
                                else
                                    connection:Disconnect()
                                end
                            end)
                            
                            print("Applied AssemblyLinearVelocity " .. tostring(velocity) .. " to " .. part.Name .. " (" .. mode .. ", " .. applicationType .. (forceful and ", FORCEFUL" or "") .. ")")
                            
                        elseif method == "VectorForce" then
                            attachment = Instance.new("Attachment")
                            attachment.Parent = part
                            
                            vectorForce = Instance.new("VectorForce")
                            vectorForce.Attachment0 = attachment
                            vectorForce.ApplyAtCenterOfMass = true
                            vectorForce.RelativeTo = Enum.ActuatorRelativeTo.World
                            vectorForce.Parent = part
                            
                            connection = RunService.Heartbeat:Connect(function()
                                if vectorForce.Parent and part.Parent then
                                    local shouldApply = (mode == "Always On") or (mode == "Keybind Move" and isKeyDown)
                                    
                                    if shouldApply then
                                        local effectiveVel = getLocalVelocity(velocity, part.CFrame)
                                        
                                        if applicationType == "Constant" then
                                            local currentVel = part.AssemblyLinearVelocity
                                            local velocityDiff = effectiveVel - currentVel
                                            -- Increased force multiplier for better control
                                            local forceMultiplier = forceful and 50 or 30
                                            vectorForce.Force = velocityDiff * part.AssemblyMass * forceMultiplier
                                        else -- Push
                                            local forceMultiplier = forceful and 100 or 50
                                            vectorForce.Force = effectiveVel * part.AssemblyMass * forceMultiplier
                                        end
                                    else
                                        vectorForce.Force = Vector3.new(0, 0, 0)
                                    end
                                else
                                    connection:Disconnect()
                                end
                            end)
                            
                            print("Applied VectorForce velocity " .. tostring(velocity) .. " to " .. part.Name .. " (" .. mode .. ", " .. applicationType .. (forceful and ", FORCEFUL" or "") .. ")")
                        
                        elseif method == "LinearVelocity" then
                            -- Modern constraint-based method using LinearVelocity
                            attachment = Instance.new("Attachment")
                            attachment.Parent = part
                            
                            local linearVelocity = Instance.new("LinearVelocity")
                            linearVelocity.Attachment0 = attachment
                            linearVelocity.RelativeTo = Enum.ActuatorRelativeTo.World
                            linearVelocity.MaxForce = math.huge
                            linearVelocity.VectorVelocity = Vector3.new(0, 0, 0)
                            linearVelocity.Parent = part
                            
                            connection = RunService.Heartbeat:Connect(function()
                                if linearVelocity.Parent and part.Parent then
                                    local shouldApply = (mode == "Always On") or (mode == "Keybind Move" and isKeyDown)
                                    
                                    if shouldApply then
                                        local effectiveVel = getLocalVelocity(velocity, part.CFrame)
                                        linearVelocity.VectorVelocity = effectiveVel
                                        
                                        if forceful then
                                            -- Extra force to maintain velocity
                                            local velocityDiff = effectiveVel - part.AssemblyLinearVelocity
                                            if velocityDiff.Magnitude > 0.1 then
                                                part:ApplyImpulse(velocityDiff * part.AssemblyMass * 0.5)
                                            end
                                        end
                                    else
                                        linearVelocity.VectorVelocity = Vector3.new(0, 0, 0)
                                    end
                                else
                                    connection:Disconnect()
                                end
                            end)
                            
                            -- Store linearVelocity in the control
                            local controlId = #velocityControls[part] + 1
                            velocityControls[part][controlId] = {
                                linearVelocity = linearVelocity,
                                attachment = attachment,
                                connection = connection,
                                keybindConnection = keybindConnection
                            }
                            
                            print("Applied LinearVelocity constraint " .. tostring(velocity) .. " to " .. part.Name .. " (" .. mode .. ", " .. applicationType .. (forceful and ", FORCEFUL" or "") .. ")")
                        end
                    end
                    
                    -- Store in array to allow multiple velocity controls per part
                    local controlId = #velocityControls[part] + 1
                    velocityControls[part][controlId] = {
                        bodyVel = bodyVel,
                        vectorForce = vectorForce,
                        attachment = attachment,
                        connection = connection,
                        keybindConnection = keybindConnection
                    }
                    
                    task.wait(0.05)
                    if not part.Anchored and mode == "Always On" and applicationType == "Constant" then
                        local effectiveVel = getLocalVelocity(velocity, part.CFrame)
                        part.AssemblyLinearVelocity = effectiveVel
                    end
                end
            end)
        end
    end

    local function applyAngularVelocity(angularVel, mode, method, keybind, spinAxis, torque, targetAngle, targetAxis)
        mode = mode or "Spinnable Movable"
        method = method or "BodyAngularVelocity"
        keybind = keybind or "E"
        spinAxis = spinAxis or "Off"
        torque = torque or 5000
        targetAngle = targetAngle or 180
        targetAxis = targetAxis or "Y"
        
        for _, part in ipairs(selectedParts) do
            replicateToServer(function()
                setNetworkOwnership(part)
                
                -- Clean up existing angular controls to override instead of stacking
                if angularControls[part] then
                    if angularControls[part].controls then
                        for _, control in ipairs(angularControls[part].controls) do
                            if control.connection then control.connection:Disconnect() end
                            if control.keybindConnection then control.keybindConnection:Disconnect() end
                            if control.safetyConnection then control.safetyConnection:Disconnect() end
                            if control.bodyAngVel then control.bodyAngVel:Destroy() end
                            if control.bodyPosition then control.bodyPosition:Destroy() end
                            if control.bodyGyro then control.bodyGyro:Destroy() end
                            if control.attachment then control.attachment:Destroy() end
                            if control.torqueForce then control.torqueForce:Destroy() end
                            if control.angularVelocityConstraint then control.angularVelocityConstraint:Destroy() end
                            if control.weldConstraint then control.weldConstraint:Destroy() end
                            if control.anchorPart then control.anchorPart:Destroy() end
                            if control.hingeConstraint then control.hingeConstraint:Destroy() end
                        end
                    end
                end
                
                -- Initialize clean arrays
                angularControls[part] = {controls = {}, keybinds = {}}
                
                if angularVel.Magnitude == 0 then
                    if not part.Anchored then
                        part.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                    end
                    print("Disabled angular control for " .. part.Name)
                else
                    local bodyAngVel = nil
                    local bodyPosition = nil
                    local bodyGyro = nil
                    local attachment = nil
                    local torqueForce = nil
                    local weldConstraint = nil
                    local anchorPart = nil
                    local connection = nil
                    local keybindConnection = nil
                    local hingeConstraint = nil
                    local safetyConnection = nil
                    local initialPosition = part.Position
                    local lastCheckTime = tick()
                    local isKeyDown = false
                    
                    -- Parse mode
                    local isSpinnable = mode:find("Spinnable")
                    local isMovable = mode:find("Movable")
                    local isKeybind = (mode == "Keybind Spin")
                    
                    -- Parse keybind
                    local keyEnum = nil
                    if isKeybind then
                        if keybind:len() == 1 then
                            keyEnum = Enum.KeyCode[keybind:upper()]
                        else
                            keyEnum = Enum.KeyCode[keybind]
                        end
                        
                        keybindConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
                            if gameProcessed then return end
                            if input.KeyCode == keyEnum then
                                isKeyDown = true
                            end
                        end)
                        
                        local keyUpConnection = UserInputService.InputEnded:Connect(function(input)
                            if input.KeyCode == keyEnum then
                                isKeyDown = false
                            end
                        end)
                    end
                    
                    if part.Anchored then
                        -- For anchored parts - spin touching AND inside parts
                        connection = RunService.Heartbeat:Connect(function()
                            if part.Parent then
                                local shouldApply = not isKeybind or (isKeybind and isKeyDown)
                                
                                if shouldApply then
                                    local touching = part:GetTouchingParts()
                                    
                                    -- Get parts inside using Region3
                                    local region = Region3.new(
                                        part.Position - part.Size/2,
                                        part.Position + part.Size/2
                                    ):ExpandToGrid(4)
                                    local partsInRegion = workspace:FindPartsInRegion3(region, part, 100)
                                    
                                    -- Combine touching and inside parts
                                    local allAffectedParts = {}
                                    for _, p in pairs(touching) do
                                        allAffectedParts[p] = true
                                    end
                                    for _, p in pairs(partsInRegion) do
                                        allAffectedParts[p] = true
                                    end
                                    
                                    for affectedPart, _ in pairs(allAffectedParts) do
                                        if affectedPart ~= part and not affectedPart.Anchored and affectedPart.Parent ~= player.Character then
                                            affectedPart.AssemblyAngularVelocity = angularVel
                                        end
                                    end
                                end
                            else
                                connection:Disconnect()
                            end
                        end)
                        
                        print("Applied anchored angular velocity conveyor " .. tostring(angularVel) .. " to " .. part.Name)
                        
                    else
                        -- For unanchored parts - apply based on mode and method
                        
                        -- ULTRA LOCK for unmovable parts - uses WeldConstraint to invisible anchored part
                        if not isMovable and not isKeybind then
                            anchorPart = Instance.new("Part")
                            anchorPart.Name = "UltraLockAnchor"
                            anchorPart.Size = Vector3.new(0.1, 0.1, 0.1)
                            anchorPart.CFrame = part.CFrame
                            anchorPart.Anchored = true
                            anchorPart.CanCollide = false
                            anchorPart.Transparency = 1
                            anchorPart.Parent = workspace
                            
                            weldConstraint = Instance.new("WeldConstraint")
                            weldConstraint.Part0 = part
                            weldConstraint.Part1 = anchorPart
                            weldConstraint.Parent = part
                        end
                        
                        if method == "BodyAngularVelocity" then
                            -- Classic method - uses BodyAngularVelocity
                            bodyAngVel = Instance.new("BodyAngularVelocity")
                            bodyAngVel.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
                            bodyAngVel.AngularVelocity = Vector3.new(0, 0, 0)
                            bodyAngVel.P = 1000000 -- MASSIVELY increased power to prevent collision stoppage
                            bodyAngVel.Parent = part
                            
                            -- Store initial CFrame for Spin to Axis modes
                            local initialCFrame = part.CFrame
                            
                            -- For Specific Stop mode, calculate target rotation
                            local targetReached = false
                            local initialAngle = 0
                            local targetAngleRad = math.rad(targetAngle)
                            
                            if spinAxis == "Specific Stop" then
                                -- Get current angle on the target axis
                                local _, currentX, currentY, currentZ = part.CFrame:ToEulerAnglesXYZ()
                                if targetAxis == "X" then
                                    initialAngle = math.deg(currentX)
                                elseif targetAxis == "Y" then
                                    initialAngle = math.deg(currentY)
                                elseif targetAxis == "Z" then
                                    initialAngle = math.deg(currentZ)
                                end
                                print("Initial angle on " .. targetAxis .. " axis: " .. initialAngle .. " degrees. Target: " .. (initialAngle + targetAngle) .. " degrees")
                            end
                            
                            connection = RunService.Heartbeat:Connect(function()
                                if bodyAngVel.Parent and part.Parent then
                                    local shouldApply = not isKeybind or (isKeybind and isKeyDown)
                                    
                                    if shouldApply then
                                        -- Handle Spin to Axis modes
                                        if spinAxis == "Specific Stop" then
                                            -- Get current angle on the target axis
                                            local _, currentX, currentY, currentZ = part.CFrame:ToEulerAnglesXYZ()
                                            local currentAngle = 0
                                            if targetAxis == "X" then
                                                currentAngle = math.deg(currentX)
                                            elseif targetAxis == "Y" then
                                                currentAngle = math.deg(currentY)
                                            elseif targetAxis == "Z" then
                                                currentAngle = math.deg(currentZ)
                                            end
                                            
                                            -- Calculate angle difference (how much more to rotate)
                                            local targetFinalAngle = initialAngle + targetAngle
                                            local angleDiff = targetFinalAngle - currentAngle
                                            
