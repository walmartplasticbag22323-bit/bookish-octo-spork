    -- NEW: Physics Paint
    local function applyPhysicsPaint(paintType)
        for _, part in ipairs(selectedParts) do
            if physicsPaints[part] then
                if physicsPaints[part].connection then physicsPaints[part].connection:Disconnect() end
            end
            
            if paintType == "Slippery" then
                part.CustomPhysicalProperties = PhysicalProperties.new(0.7, 0.01, 0.5)
                physicsPaints[part] = {type = "Slippery"}
            elseif paintType == "Bouncy" then
                part.CustomPhysicalProperties = PhysicalProperties.new(0.7, 0.3, 1)
                physicsPaints[part] = {type = "Bouncy"}
            elseif paintType == "Magnetic" then
                -- Dynamic Color-Based Magnet System
                -- Red ↔ Blue = ATTRACT | Red ↔ Red / Blue ↔ Blue = REPEL
                local magnetStrength = magnetSettings.strength or 500
                local snapDistance = magnetSettings.snapDistance or 50
                
                local connection = RunService.Heartbeat:Connect(function()
                    if part.Parent then
                        for otherPart, data in pairs(physicsPaints) do
                            if data.type == "Magnetic" and otherPart ~= part and otherPart.Parent then
                                local dist = (part.Position - otherPart.Position).Magnitude
                                
                                if dist < snapDistance then
                                    -- Determine colors (Red = R>0.5, Blue = B>0.5)
                                    local partColor = part.Color
                                    local otherColor = otherPart.Color
                                    
                                    local isPartRed = partColor.R > 0.5 and partColor.R > partColor.B
                                    local isPartBlue = partColor.B > 0.5 and partColor.B > partColor.R
                                    local isOtherRed = otherColor.R > 0.5 and otherColor.R > otherColor.B
                                    local isOtherBlue = otherColor.B > 0.5 and otherColor.B > otherColor.R
                                    
                                    -- Determine if attract or repel
                                    local shouldAttract = false
                                    if (isPartRed and isOtherBlue) or (isPartBlue and isOtherRed) then
                                        shouldAttract = true -- Opposite colors attract
                                    elseif (isPartRed and isOtherRed) or (isPartBlue and isOtherBlue) then
                                        shouldAttract = false -- Same colors repel
                                    else
                                        -- Neutral colors (not clearly red or blue) - no force
                                        return
                                    end
                                    
                                    -- Calculate force direction
                                    local direction = (otherPart.Position - part.Position).Unit
                                    if not shouldAttract then
                                        direction = -direction -- Reverse for repulsion
                                    end
                                    
                                    -- Apply force (inverse square law)
                                    local forceMagnitude = magnetStrength / (dist * dist)
                                    local force = direction * forceMagnitude
                                    part.AssemblyLinearVelocity = part.AssemblyLinearVelocity + force * 0.01
                                end
                            end
                        end
                    else
                        connection:Disconnect()
                    end
                end)
                physicsPaints[part] = {type = "Magnetic", connection = connection}
            elseif paintType == "Gooey" then
                local connection = RunService.Heartbeat:Connect(function()
                    if part.Parent then
                        local touching = part:GetTouchingParts()
                        for _, touchPart in pairs(touching) do
                            if touchPart.Anchored then
                                part.AssemblyLinearVelocity = part.AssemblyLinearVelocity * 0.5
                            end
                        end
                    else
                        connection:Disconnect()
                    end
                end)
                physicsPaints[part] = {type = "Gooey", connection = connection}
            elseif paintType == "Water" then
                -- Water physics paint - acts like terrain water
                local connection = RunService.Heartbeat:Connect(function()
                    if part.Parent then
                        -- Get all parts inside this water-painted part
                        local region = Region3.new(
                            part.Position - part.Size/2,
                            part.Position + part.Size/2
                        ):ExpandToGrid(4)
                        local partsInside = workspace:FindPartsInRegion3(region, part, 100)
                        
                        for _, insidePart in pairs(partsInside) do
                            if insidePart ~= part and not insidePart.Anchored and insidePart.Parent ~= player.Character then
                                -- Water buoyancy - upward force
                                local density = insidePart.CustomPhysicalProperties and insidePart.CustomPhysicalProperties.Density or 0.7
                                local buoyancyForce = Vector3.new(0, workspace.Gravity * insidePart.Mass * (1 / density) * 0.8, 0)
                                insidePart.AssemblyLinearVelocity = insidePart.AssemblyLinearVelocity + buoyancyForce * 0.01
                                
                                -- Water drag - slow down movement
                                local currentVel = insidePart.AssemblyLinearVelocity
                                local dragForce = -currentVel * 0.15
                                insidePart.AssemblyLinearVelocity = insidePart.AssemblyLinearVelocity + dragForce
                                
                                -- Angular drag - slow down rotation
                                local angVel = insidePart.AssemblyAngularVelocity
                                if angVel.Magnitude > 0.1 then
                                    insidePart.AssemblyAngularVelocity = angVel * 0.9
                                end
                            end
                        end
                    else
                        connection:Disconnect()
                    end
                end)
                physicsPaints[part] = {type = "Water", connection = connection}
            elseif paintType == "No Lost Energy" then
                -- Set Elasticity to 1 (perfect bounce) and zero friction
                part.CustomPhysicalProperties = PhysicalProperties.new(0.7, 0, 1)
                
                -- Continuously restore velocity to prevent energy loss
                local connection = RunService.Heartbeat:Connect(function()
                    if part.Parent then
                        local currentSpeed = part.AssemblyLinearVelocity.Magnitude
                        
                        -- If moving, maintain that speed by countering any slowdown
                        if currentSpeed > 0.1 then
                            -- Store the velocity direction
                            local direction = part.AssemblyLinearVelocity.Unit
                            
                            -- Reapply the velocity to counter air resistance and other losses
                            part.AssemblyLinearVelocity = direction * currentSpeed
                        end
                    else
                        connection:Disconnect()
                    end
                end)
                physicsPaints[part] = {type = "No Lost Energy", connection = connection}
            elseif paintType == "No Lost Energy (Normal)" then
                -- Keep normal elasticity (0.5) and zero friction
                part.CustomPhysicalProperties = PhysicalProperties.new(0.7, 0, 0.5)
                
                -- Continuously restore velocity to prevent energy loss
                local connection = RunService.Heartbeat:Connect(function()
                    if part.Parent then
                        local currentSpeed = part.AssemblyLinearVelocity.Magnitude
                        
                        -- If moving, maintain that speed by countering any slowdown
                        if currentSpeed > 0.1 then
                            -- Store the velocity direction
                            local direction = part.AssemblyLinearVelocity.Unit
                            
                            -- Reapply the velocity to counter air resistance and other losses
                            part.AssemblyLinearVelocity = direction * currentSpeed
                        end
                    else
                        connection:Disconnect()
                    end
                end)
                physicsPaints[part] = {type = "No Lost Energy (Normal)", connection = connection}
            elseif paintType == "Buoyancy" then
                -- Remove any existing buoyancy objects
                if part:FindFirstChild("BuoyancyBodyPosition") then
                    part:FindFirstChild("BuoyancyBodyPosition"):Destroy()
                end
                if part:FindFirstChild("BuoyancyBodyGyro") then
                    part:FindFirstChild("BuoyancyBodyGyro"):Destroy()
                end
                
                -- Store the last known position on water
                local lockedOnWater = false
                local lastWaterY = nil
                
                local connection = RunService.Heartbeat:Connect(function()
                    if part.Parent then
                        -- Check for water below the part
                        local checkPos = part.Position - Vector3.new(0, part.Size.Y/2 + 1, 0)
                        local region = Region3.new(checkPos - Vector3.new(3, 3, 3), checkPos + Vector3.new(3, 3, 3))
                        region = region:ExpandToGrid(4)
                        
                        local terrain = workspace.Terrain
                        local materials, sizes = terrain:ReadVoxels(region, 4)
                        local size = materials.Size
                        
                        local waterFound = false
                        local waterLevel = -math.huge
                        
                        for x = 1, size.X do
                            for y = 1, size.Y do
                                for z = 1, size.Z do
                                    if materials[x][y][z] == Enum.Material.Water then
                                        waterFound = true
                                        local worldPos = region.CFrame * Vector3.new(
                                            (x - size.X/2) * 4,
                                            (y - size.Y/2) * 4,
                                            (z - size.Z/2) * 4
                                        )
                                        waterLevel = math.max(waterLevel, worldPos.Y)
                                    end
                                end
                            end
                        end
                        
                        if waterFound then
                            local bottomY = part.Position.Y - part.Size.Y/2
                            
                            -- If bottom is at or below water, lock it
                            if bottomY <= waterLevel + 0.1 then
                                if not lockedOnWater then
                                    lockedOnWater = true
                                    lastWaterY = waterLevel + part.Size.Y/2
                                end
                                
                                -- Force position to stay on water surface
                                local currentPos = part.Position
                                part.CFrame = CFrame.new(currentPos.X, lastWaterY, currentPos.Z) * (part.CFrame - part.CFrame.Position)
                                
                                -- Zero out all velocities completely
                                part.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                                part.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                                part.RotVelocity = Vector3.new(0, 0, 0)
                                
                                -- Make sure part doesn't interact with other physics
                                if part:IsA("BasePart") then
                                    part.CustomPhysicalProperties = PhysicalProperties.new(100, 0, 0, 1, 1)
                                end
                            else
                                lockedOnWater = false
                                lastWaterY = nil
                            end
                        else
                            lockedOnWater = false
                            lastWaterY = nil
                        end
                    else
                        connection:Disconnect()
                    end
                end)
                physicsPaints[part] = {type = "Buoyancy", connection = connection}
            end
            print("Applied " .. paintType .. " paint to " .. part.Name)
        end
    end

